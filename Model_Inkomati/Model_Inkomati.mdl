land_use_area_productive_uses[FOREST_PLANTATIONS]= INTEG (
	land_use_changes_productive_uses[FOREST_PLANTATIONS],
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS]) ~~|
land_use_area_productive_uses[SHRUBLAND]= INTEG (
	land_use_changes_productive_uses[SHRUBLAND],
		0) ~~|
