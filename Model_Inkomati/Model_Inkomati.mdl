{UTF-8}
WEF_economy_indicator=
	IF_THEN_ELSE(SWITCH_POPULATION=0,ZIDZ((GDP_Mid-GDP_per_capita_min), (GDP_per_capita_max\
		-GDP_per_capita_min)),ZIDZ((GDP_per_capita-GDP_per_capita_min), (GDP_per_capita_max\
		-GDP_per_capita_min)))
	~	
	~		|

WEF_food_indicator=
	ZIDZ((sum_total_food-MIN_TOTAL_FOOD_PRODUCED), (MAX_TOTAL_FOOD_PRODUCED-MIN_TOTAL_FOOD_PRODUCED\
		) )
	~	
	~		|

sum_total_food=
	SUM(total_food_produced[LAND_PRODUCTS_I!])
	~	
	~		|

WEF_land_indicator=
	ZIDZ( (total_forest_area_world-MIN_TOTAL_FOREST) , (MAX_TOTAL_FOREST-MIN_TOTAL_FOREST\
		) )
	~	
	~		|

MAX_TOTAL_FOOD_PRODUCED=
	420000
	~	
	~		|

MAX_TOTAL_FOREST=
	560000
	~	
	~		|

MAX_TOTAL_WATER_OUTPUT=
	2000*10^6
	~	
	~		|

WEF_water_indicator=
	1-(tot_Water_use/MAX_TOTAL_WATER_OUTPUT)
	~	m3/Year
	~		|

MIN_TOTAL_FOOD_PRODUCED=
	150000
	~	
	~		|

MIN_TOTAL_FOREST=
	440000
	~	
	~		|

GDP_Mid:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'time_GDP' , 'GDP_med' )
	~	
	~		|

GDP_per_capita_min:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'time_GDP' , 'GDP_min' )
	~	
	~		|

GDP_per_capita_max:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'time_GDP' , 'GDP_max' )
	~	
	~		|

POLICY_NEW_POWER_DESIRE_BY_TECHNOLOGY[ENERGY_TECHS]=
	IF_THEN_ELSE(SELECT_PLANNING_OF_POWER_DESIRE_BY_TECH_MODE=0, POWER_DESIRE_BY_TECH_CURRENT_TRENDS\
		[ENERGY_TECHS],IF_THEN_ELSE(SELECT_PLANNING_OF_POWER_DESIRE_BY_TECH_MODE = 1, POWER_DESIRE_BY_TECH_RES_LOW_EXPANSION\
		[ENERGY_TECHS] , 
	IF_THEN_ELSE(SELECT_PLANNING_OF_POWER_DESIRE_BY_TECH_MODE=2, POWER_DESIRE_BY_TECH_RES_MED_EXPANSION\
		[ENERGY_TECHS],
	IF_THEN_ELSE(SELECT_PLANNING_OF_POWER_DESIRE_BY_TECH_MODE=3, POWER_DESIRE_BY_TECH_RES_EXPANSION\
		[ENERGY_TECHS] , PLANNING_OF_POWER_DESIRE_BY_TECH_USER_DEFINED_SCENARIO
	[ENERGY_TECHS] ) )))
	~	MW/Year
	~	Exogenous policy for power capacity installation in the case study to generate \
		electricity.
		BAU      -> ENERGY_INSTALLATION_BAU
		POLICY 1 -> ENERGY_INSTALLATION_RES_NO_COAL
	|

POWER_DESIRE_BY_TECH_RES_LOW_EXPANSION[ENERGY_TECHS]:INTERPOLATE::=
	GET_DIRECT_DATA(  'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'POWER_DESIRE_BY_TECH_LOW'\
		 )
	~	
	~		|

CURRENT_TRENDS_DISTRIBUTION_ELECTRICITY_LOSSES:=
	GET_DIRECT_DATA(  'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS', 'CURRENT_TRENDS_ELECTRICITY_LOSSES'\
		 )
	~	
	~		|

POLICY_ELECTRICITY_DISTRIBUTION_LOSSES=
	IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES=0, CURRENT_TRENDS_DISTRIBUTION_ELECTRICITY_LOSSES\
		, IF_THEN_ELSE( SELECT_ELECTRICITY_DISTRIBUTION_LOSSES=1, HIGH_DISTRIBUTION_ELECTRICITY_LOSSES\
		 , IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES
	=2, MEDIUM_DISTRIBUTION_ELECTRICITY_LOSSES , IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES\
		=3, LOW_DISTRIBUTION_ELECTRICITY_LOSSES
	 , USER_DEFINED_DISTRIBUTION_ELECTRICITY_LOSSES ) ) ))
	~	
	~		|

CH4_emissions_enteric_fermentation_pre=
	SUM(CH4_emissions_enteric_fermentation[ANIMALS_TYPES_I!])
	~	
	~		|

CH4_emissions_enteric_fermentation_by_region=
	CH4_emissions_enteric_fermentation_pre*(1+SHARE_REST_CH4_ENTERIC_FERMENTATION_EMISSIONS\
		)
	~	MtCH4/Year
	~	Equation for CH4 emissions based on activity data (animals) and factor \
		emissions (from IPCC),
	|

CROPLAND_LOST_DUE_TO_FLOODS=
	IF_THEN_ELSE(SWITCH_CLIMATE_CHANGE_DAMAGE=0,0, 
	
	Loss_of_land_due_to_Flood*EFFECTIVE_PERCENT_OF_LAND_CHANGE_PER_METER_OF_FLOODING
	)
	~	ha/Year
	~	land lost due to floods
	|

vector_of_land_use_changes[CROPLAND_RAINFED]=
	CROPLAND_LOST_DUE_TO_FLOODS+
	
	SUM(matrix_of_land_use_changes[LANDS_I!,CROPLAND_RAINFED])-
	SUM(matrix_of_land_use_changes[CROPLAND_RAINFED,LANDS_I!])- CROPLAND_LOST_DUE_TO_FLOODS\
		 ~~|
vector_of_land_use_changes[CROPLAND_IRRIGATED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,CROPLAND_IRRIGATED])-
	SUM(matrix_of_land_use_changes[CROPLAND_IRRIGATED,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_MANAGED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_MANAGED])-
	SUM(matrix_of_land_use_changes[FOREST_MANAGED,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_PRIMARY]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_PRIMARY])-
	SUM(matrix_of_land_use_changes[FOREST_PRIMARY,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_PLANTATIONS]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_PLANTATIONS])-
	SUM(matrix_of_land_use_changes[FOREST_PLANTATIONS,LANDS_I!]) ~~|
vector_of_land_use_changes[SHRUBLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,SHRUBLAND])-
	SUM(matrix_of_land_use_changes[SHRUBLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[GRASSLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,GRASSLAND])-
	SUM(matrix_of_land_use_changes[GRASSLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[WETLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,WETLAND])-
	SUM(matrix_of_land_use_changes[WETLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[URBAN_LAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,URBAN_LAND])-
	SUM(matrix_of_land_use_changes[URBAN_LAND,LANDS_I!]) ~~|
vector_of_land_use_changes[WATERBODIES]=
	SUM(matrix_of_land_use_changes[LANDS_I!,WATERBODIES])-
	SUM(matrix_of_land_use_changes[WATERBODIES,LANDS_I!]) ~~|
vector_of_land_use_changes[OTHER_LAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,OTHER_LAND])-
	SUM(matrix_of_land_use_changes[OTHER_LAND,LANDS_I!])
	~	ha/Year
	~		|

factor_of_maximum_land_limit[LANDS_I,LANDS_MAP_I] :EXCEPT:               [LANDS_I,CROPLAND_RAINFED
], [
LANDS_I,FOREST_PLANTATIONS]=
	IF_THEN_ELSE( matrix_of_accumulated_land_use_changes[LANDS_I,LANDS_MAP_I]>= 
	
	MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,LANDS_MAP_I]  :AND: land_use_changes_demanded\
		[LANDS_MAP_I
	]>0  ,
	
	0, 1) ~~|
factor_of_maximum_land_limit[LANDS_I,CROPLAND_RAINFED]=
	IF_THEN_ELSE( SWITCH_LAW_LIMITS_LAND_BY_SOURCE=0,
	
	IF_THEN_ELSE( matrix_of_accumulated_land_use_changes[LANDS_I,CROPLAND_RAINFED]>= 
	
	MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,CROPLAND_RAINFED]:AND: land_use_changes_demanded\
		[CROPLAND_RAINFED]>0 , 0, 1),
	
	IF_THEN_ELSE(  land_use_area_by_region[CROPLAND_RAINFED]  >=  MAXIMUM_LAND_USES_BY_SOURCE\
		[CROPLAND_RAINFED]*INITIAL_LAND_USE_BY_REGION_2015[CROPLAND_RAINFED] ,0, 1)
	
	) ~~|
factor_of_maximum_land_limit[LANDS_I,FOREST_PLANTATIONS]=
	IF_THEN_ELSE( SWITCH_LAW_LIMITS_LAND_BY_SOURCE=0,
	
	IF_THEN_ELSE( matrix_of_accumulated_land_use_changes[LANDS_I,FOREST_PLANTATIONS]>= 
	
	MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,FOREST_PLANTATIONS] :AND: land_use_changes_demanded\
		[FOREST_PLANTATIONS]>0 , 0, 1),
	
	IF_THEN_ELSE(  land_use_area_by_region[FOREST_PLANTATIONS]  >=  MAXIMUM_LAND_USES_BY_SOURCE\
		[FOREST_PLANTATIONS]*INITIAL_LAND_USE_BY_REGION_2015[FOREST_PLANTATIONS] ,0, 1)
	
	)
	~	Dmnl
	~	factor of maximum land use changes by region
	|

EFFECTIVE_PERCENT_OF_LAND_CHANGE_PER_METER_OF_FLOODING=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'LOST_CROPLAND*')
	~	Dmnl
	~		|

SWITCH_CLIMATE_CHANGE_DAMAGE=
	1
	~	Dmnl
	~		|

Loss_of_land_due_to_Flood=
	1
	~	ha/Year
	~		|

tot_Water_use=
	agri_water_use_P4_P1_on_off+domestic_water_use_P2_P3_on_off+environmental_flow_requirement\
		+industrial_water_withdrawal+tot_Water_use_for_electricity_production
	~	m3/Year
	~	Tot Water use in Inkomati
	|

domestic_water_use_P2_on=
	domestic_water_use_p3_on_off*0.85
	~	m3/Year
	~	15% reduction of water losses in domestic water
	|

Total_Water_demand=
	Agriculture_Water_Demand+Domestic_Water_demand+Industrial_Water_Demand
	~	m3
	~		|

total_CO2_emissions_per_capita=
	f_co2_emission_from_all_economy/Total_population
	~	kg/(Year*people)
	~	Refer to the total amount of carbon dioxide emissions produced by a \
		country, divided by its population. This variable measures the average CO2 \
		emissions attributable to each individual.
	|

water_balance= INTEG (
	total_water_available-tot_Water_use,
		0)
	~	m3
	~	Water balance
	|

HH_electricity_consumption_per_capita=
	demand_of_ELEC_by_sector[HOUSEHOLDS,ELEC]/Total_population
	~	MWh/(Year*people)
	~		|

initial_urban_land_density=
	ZIDZ(
	        UNIT_CONVERSION_m2_km2_0 *
	        HISTORICAL_LAND_USE_BY_REGION[ URBAN_LAND](INITIAL_TIME),
	        Total_population)
	~	people/m2
	~		|

direct_CO2_emissions_per_capita_from_electricity=
	SUM(direct_electricity_CO2_emissions[ENERGY_TECHS!])/Total_population
	~	kg/(Year*people)
	~		|

historical_data_of_population_with_time=
	Total_population
	~	people
	~		|

Domestic_Water_demand=
	IF_THEN_ELSE(Time>=2021, Average_Water_Intensity_Domestic*HH_Consumption , domestic_water_use_P2_P3_on_off\
		 )
	~	
	~		|

increment_of_urban_land_demanded=
	MAX(0 , SMOOTH(Total_population,10)*urban_land_density/UNIT_CONVERSION_m2_km2_0
	  )
	~	km2/Year
	~		|

domestic_water_use_P2_P3_on_off=
	IF_THEN_ELSE (switch_p2=1, domestic_water_use_P2_on, domestic_water_use_p3_on_off)
	~	m3/Year
	~		|

domestic_water_use_p3_on_off=
	Total_population*water_use_per_capita_P3_on_off
	~	m3/Year
	~		|

water_scarcity_index=
	IF_THEN_ELSE(Total_Water_demand > 0,
	    MAX(0, min(1, Water_Suppply / Total_Water_demand)),
	    1
	  )
	~	1/Year
	~		|

Energy_index=
	SMOOTH(MAX(Relative_level_of_consumption *LEVEL_OF_ELEC_CONSUMPTION_WEIGHT + co2_emissions_indicator
	*EMISSION_WEIGHT
	 + Ratio_between_the_electricity_generated_with_local_resources_and_the_total_electricity_generation\
		*RATIO_OF_IMPORTS_WEIGHT
	 ,0), 1 )
	~	
	~	An energy index has been calculated using the variables that could be \
		modeled, aiming to represent 3 out of the five dimensions analyzed in \
		"Alternatives for Improving Energy Security in Cape Verde" by Leuzinger \
		Coutinho et. al 2020 (https://doi.org/10.1016/j.jup.2020.101112). The four \
		dimensions included are: Availability, Affordability, Technology \
		Development and Efficiency, and Environmental and Social Sustainability. \
		Each dimension is represented by a single variable, which has been \
		normalized on a scale from 0 to 1. To aggregate the index, weights have \
		been assigned to each dimension, following the proportions used in the \
		referenced article, although users can adjust these weights if desired. \
		For the sustainability dimension, represented by emissions, the reciprocal \
		of emissions has been used so that higher emissions negatively impact the \
		energy security score.
	|

co2_emissions_indicator=
	IF_THEN_ELSE(total_CO2_emissions_per_capita>ini_emissions_per_capita, 0 , -total_CO2_emissions_per_capita\
		/ini_emissions_per_capita + 1 )
	~	
	~		|

land_products_available_from_cropland_per_capita_0[LAND_PRODUCTS_I]=
	land_products_available_from_croplands[LAND_PRODUCTS_I]/Total_population
	~	t/(Year*person)
	~		|

food_demanded_by_households_per_region[FOODS_I]=
	diet[FOODS_I]*Total_population*UNIT_CONVERSION_t_kg_0
	~	t/Year
	~		|

land_products_available_from_cropland_per_capita[LAND_PRODUCTS_I]=
	land_products_available_from_croplands[LAND_PRODUCTS_I]/Total_population
	~	t/(Year*people)
	~		|

Water_Intensity_Domestic=
	domestic_water_use_P2_P3_on_off/HH_Consumption
	~	m3/M$
	~		|

Land_Product_demanded_for_food_per_capita[LAND_PRODUCTS_I]=
	land_products_demanded_for_food[LAND_PRODUCTS_I]/Total_population
	~	t/(Year*people)
	~		|

Land_Product_demanded_for_food_per_capita_0[LAND_PRODUCTS_I]=
	land_products_demanded_for_food[LAND_PRODUCTS_I]/Total_population
	~	t/(Year*person)
	~		|

Relative_level_of_consumption=
	HH_electricity_consumption_per_capita/MINIMUM_TIER_CONSIDERED
	~	MWh/(Year*people)
	~	Is a standardized variable that classifies electricity consumption into \
		five access levels, from Tier 1 (basic/low development) to Tier 5 (high \
		development). Each tier reflects the potential electricity services and \
		applications available to users at that level of access. TIER 4 is \
		considered as a minimum.
	|

delay_HH_electricity_consumption_per_capita= DELAY_FIXED (
	HH_electricity_consumption_per_capita, TIME_STEP , 0)
	~	MWh/(Year*people)
	~		|

total_electricity_consumption_per_capita=
	check_total_electricity_consumption/Total_population
	~	MWh/(Year*people)
	~	This variable represents the availability of electricity.
	|

food_demand[LAND_PRODUCTS_I]=
	land_products_demanded_for_food[LAND_PRODUCTS_I]/Total_population
	~	t/Year
	~	per capita?
	|

Water_Stress=
	Total_Water_demand/(total_water_available-New_Enviromental_FLows)
	~	
	~	Indicator 6.4.2 tracks how much freshwater that is being withdrawn by all \
		economic activities, compared to the total renewable freshwater resources \
		available. It also takes into account environmental flow \
		requirements.https://www.unwater.org/our-work/sdg-6-integrated-monitoring-i\
		nitiative/indicator-642-level-water-stress-freshwater?ut
	|

ini_emissions_per_capita= INITIAL(
	total_CO2_emissions_per_capita)
	~	kg/(Year*people)
	~		|

GDP_per_capita=
	ZIDZ(Real_GDP, Total_population )*UNIT_CONVERSION_MUSD_USD
	~	$/people/Year
	~		|

delayed_urban_land_density= DELAY_FIXED (
	urban_land_density_trends , 1 , initial_urban_land_density)
	~	people/m2
	~		|

SWITCH_URBAN_LAND_DENSITY_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx' , 'land' , 'SWITCH_URBAN_LAND_DENSITY_SP'\
		 )
	~	Dmnl
	~		|

change_of_urban_land_density_trends=
	urban_land_density_trends-delayed_urban_land_density
	~	people/(Year*m2)
	~		|

urban_land_density= INTEG (
	change_of_urban_land_density,
		initial_urban_land_density)
	~	people/m2
	~	the urban land density in the case study
	|

YEAR_FINAL_URBAN_LAND_DENSITY_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx' , 'land' , 'YEAR_FINAL_URBAN_LAND_DENSITY_SP'\
		 )
	~	Year
	~		|

change_of_urban_land_density=
	IF_THEN_ELSE( Time<TIME_HISTORICAL_DATA_LAND_MODULE, change_of_urban_land_density_trends\
		,
	
	
	IF_THEN_ELSE( SWITCH_URBAN_LAND_DENSITY_SP=1:AND:Time>YEAR_INITIAL_URBAN_LAND_DENSITY_SP\
		 :AND:Time<YEAR_FINAL_URBAN_LAND_DENSITY_SP
	,(OBJECTIVE_URBAN_LAND_DENSITY_SP-urban_land_density_trends)/(YEAR_FINAL_URBAN_LAND_DENSITY_SP\
		-YEAR_INITIAL_URBAN_LAND_DENSITY_SP
	)
	 , change_of_urban_land_density_trends  ) )
	~	people/(m2*Year)
	~		|

historical_data_of_urban_land_with_time=
	HISTORICAL_LAND_USE_BY_REGION[URBAN_LAND](Time)
	~	ha
	~		|

OBJECTIVE_URBAN_LAND_DENSITY_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx' , 'land' , 'OBJECTIVE_URBAN_LAND_DENSITY_SP'\
		 )
	~	people/m2
	~		|

YEAR_INITIAL_URBAN_LAND_DENSITY_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx' , 'land' , 'YEAR_INITIAL_URBAN_LAND_DENSITY_SP'\
		 )
	~	Year
	~	urban land density policy initial year
	|

urban_land_density_trends=
	(historical_data_of_urban_land_with_time*UNIT_CONVERSION_m2_km2_0)/historical_data_of_population_with_time
	~	people/m2
	~		|

YIELDS_OF_WOOD_FROM_PLANTATIONS=
	8
	~	t/(Year*ha)
	~	Wood production factor for Pinus patula plantations in Mpumalanga (South \
		Africa): approximately 8 t/ha·yr, derived from an average productivity of  \
		15 m³/ha·yr and a wood density of  0.50 t/m³. Studies report that P. \
		patula shows higher volume productivity than species such as Pinus \
		elliottii in high-altitude Mpumalanga sites (see: Growth and fibre yield \
		of Pinus patula and Pinus elliottii pulpwood plantations at high altitude \
		in Mpumalanga).
	|

wood_production_of_plantations=
	effective_area_for_plantations*YIELDS_OF_WOOD_FROM_PLANTATIONS
	~	t/Year
	~		|

UNIT_CONVERSION_day_year=
	365
	~	days/Year
	~		|

CH4_emissions_wheat=
	area_of_irrigated_wheat* ((FACTOR_EMISSIONS_BASELINE_WHEAT*CULTIVATION_PERIOD_WHEAT/\
		UNIT_CONVERSION_day_year
	)*SCALING_FACTOR_WATER_REGIME_WHEAT_IRRIGATED
	*SCALING_FACTOR_WATER_REGIME_PRESEASON
	*SCALING_FACTOR_ORGANIC_AMENDMENT*UNIT_CONVERSION_t_kg_0
	*UNIT_CONVERSION_Mt_t) +
	
	area_of_rainfed_wheat
	
	*((FACTOR_EMISSIONS_BASELINE_WHEAT*CULTIVATION_PERIOD_WHEAT/UNIT_CONVERSION_day_year\
		)*SCALING_FACTOR_WATER_REGIME_WHEAT_RAINFED
	*(1-SHARE_UPLAND_WHEAT_BY_REGION
	)*SCALING_FACTOR_ORGANIC_AMENDMENT
	*UNIT_CONVERSION_t_kg_0
	*SCALING_FACTOR_WATER_REGIME_PRESEASON
	*UNIT_CONVERSION_Mt_t)
	~	Mt/Year
	~		|

WEF_Indicators= INTEG (
	1,
		1)
	~	Year
	~		|

self_sufficiency_food=
	IF_THEN_ELSE(land_prod_sum_demanded > 0,
	    MAX(0, min(1, land_prod_sum_available / land_prod_sum_demanded)),
	    1
	  )
	~	
	~		|

RES_INI_PLANNING_TIME[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_pv'\
		 ) ~~|
RES_INI_PLANNING_TIME[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_wind'\
		 ) ~~|
RES_INI_PLANNING_TIME[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_hydro'\
		 ) ~~|
RES_INI_PLANNING_TIME[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_biomass_pp'\
		 )
	~	
	~		|

RES_INI_PLANNING_DELAY[PV]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[PV], RES_INI_PLANNING_TIME[PV] , 0) ~~|
RES_INI_PLANNING_DELAY[WIND]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[WIND], RES_INI_PLANNING_TIME[WIND] , \
		0) ~~|
RES_INI_PLANNING_DELAY[HYDRO]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[HYDRO], RES_INI_PLANNING_TIME[HYDRO] \
		, 0) ~~|
RES_INI_PLANNING_DELAY[BIOMASS_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[BIOMASS_PP], RES_INI_PLANNING_TIME[BIOMASS_PP\
		] , 0)
	~	
	~	PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[RENEWABLES], \
		RES_INI_TIME_PLANIFICATION[RENEWABLES] , 0
	|

FOSSIL_INI_PLANIFICATION_DELAY[COAL_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_PLANNED[COAL_PP], FOSSIL_INI_TIME_PLANIFICATION[\
		COAL_PP] , 0) ~~|
FOSSIL_INI_PLANIFICATION_DELAY[GAS_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_PLANNED[GAS_PP], FOSSIL_INI_TIME_PLANIFICATION[GAS_PP\
		] , 0) ~~|
FOSSIL_INI_PLANIFICATION_DELAY[OIL]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_PLANNED[OIL], FOSSIL_INI_TIME_PLANIFICATION[OIL]\
		 , 0)
	~	
	~		|

f1_planning_delay[PV]= DELAY_FIXED (
	 f1_effective_planned[PV], RES_TIME_PLAN[PV] , 0) ~~|
f1_planning_delay[WIND]= DELAY_FIXED (
	 f1_effective_planned[WIND], RES_TIME_PLAN[WIND] , 0) ~~|
f1_planning_delay[HYDRO]= DELAY_FIXED (
	f1_effective_planned[HYDRO], RES_TIME_PLAN[HYDRO] , 0) ~~|
f1_planning_delay[BIOMASS_PP]= DELAY_FIXED (
	 f1_effective_planned[BIOMASS_PP], RES_TIME_PLAN[BIOMASS_PP] , 0)
	~	
	~		|

fossil_f1_planning_delay[COAL_PP]= DELAY_FIXED (
	 fossil_f1_effective_planned[COAL_PP], FOSSIL_TIME_PLAN[COAL_PP] , 0) ~~|
fossil_f1_planning_delay[GAS_PP]= DELAY_FIXED (
	 fossil_f1_effective_planned[GAS_PP], FOSSIL_TIME_PLAN[GAS_PP] , 0) ~~|
fossil_f1_planning_delay[OIL]= DELAY_FIXED (
	 fossil_f1_effective_planned[OIL], FOSSIL_TIME_PLAN[OIL] , 0)
	~	
	~		|

fossil_f1_construction[FOSSIL]=
	FOSSIL_INI_PLANIFICATION_DELAY[FOSSIL]+fossil_f1_planning_delay[FOSSIL]
	~	MW/Year
	~	Construction annual power flow by type of renewable technology.
	|

f1_construction[RENEWABLES]=
	f1_planning_delay[RENEWABLES]+RES_INI_PLANNING_DELAY[RENEWABLES]
	~	MW/Year
	~	Construction annual power flow by type of renewable technology.
	|

New_Enviromental_FLows=
	water_available*ENVIROMENTAL_FLOWS_SHARE
	~	
	~		|

ENVIROMENTAL_FLOWS_SHARE=
	0.35
	~	
	~	https://onlinelibrary.wiley.com/doi/10.1002/rra.736
	|

self_sufficiency_index[LAND_PRODUCTS_I]=
	IF_THEN_ELSE(land_products_demanded_for_food[LAND_PRODUCTS_I] > 0,
	    MAX(0, min(1, land_products_available_from_croplands[LAND_PRODUCTS_I] / land_products_demanded_for_food\
		[LAND_PRODUCTS_I])),
	    1
	  )
	~	Dmnl
	~		|

Food_Module= INTEG (
	1,
		1)
	~	
	~		|

Water_Module= INTEG (
	1,
		1)
	~	
	~		|

Food=
	0
	~	
	~		|

Water=
	0
	~	
	~		|

Socioeconomy=
	0
	~	
	~		|

SUM_OF_TOTAL_FOOD=
	SUM(total_food_produced[LAND_PRODUCTS_I!])
	~	t/Year
	~	Sum of all items
	|

land_prod_sum_available=
	SUM(land_products_available_from_croplands[LAND_PRODUCTS_I!])
	~	
	~		|

land_prod_sum_demanded=
	SUM(land_products_demanded_for_food[LAND_PRODUCTS_I!])
	~	
	~		|

POWER_DESIRE_BY_TECH_RES_MED_EXPANSION[ENERGY_TECHS]:INTERPOLATE::=
	GET_DIRECT_DATA(  'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'POWER_DESIRE_BY_TECH_MED_RES'\
		 )
	~	
	~		|

SWITCH_SEASONALITY=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'energy' , 'SWITCH_SEASONALITY' )
	~	
	~		|

CF_PERIODICAL[RENEWABLES]=
	IF_THEN_ELSE(SWITCH_SEASONALITY=1, INI_CF_PERIODICAL[RENEWABLES] , MAX(aux_delay2[RENEWABLES\
		],aux_delay1[RENEWABLES])+IF_THEN_ELSE(Time<INITIAL_TIME+1, INI_CF_PERIODICAL[RENEWABLES\
		], 0 ) )
	~	
	~	The ratio of the electrical energy produced by a renewable generating unit \
		in a year to the electrical energy that could have been produced in \
		continuous operation at full power during that year.
	|

FOSSIL_POWER_PLANTS_DECOMISSION[GAS_PP]=
	IF_THEN_ELSE(Time-INITIAL_TIME>=FOSSIL_LIFETIME[GAS_PP], 0, FOSSIL_INI_INSTALLED[GAS_PP\
		]/FOSSIL_LIFETIME[GAS_PP] ) ~~|
FOSSIL_POWER_PLANTS_DECOMISSION[OIL]=
	IF_THEN_ELSE(Time-INITIAL_TIME>=FOSSIL_LIFETIME[OIL], 0, FOSSIL_INI_INSTALLED[OIL]/FOSSIL_LIFETIME\
		[OIL] ) ~~|
FOSSIL_POWER_PLANTS_DECOMISSION[COAL_PP]=
	IF_THEN_ELSE( fossil_installed[COAL_PP]<=0 , 0 , POLICY_COAL_POWER_PLANT_PHASE_OUT )
	~	
	~	Programming auxiliary variable. Coal power plants are not decommissioned \
		unless a phase-out is carried out.
	|

