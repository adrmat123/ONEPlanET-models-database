	land_use_changes_productive_uses[ WATERBODIES],
		0) ~~|
land_use_area_productive_uses[OTHER_LAND]= INTEG (
	land_use_changes_productive_uses[OTHER_LAND]+land_use_changes_productive_uses[WATERBODIES
	]+land_use_changes_productive_uses[WETLAND]+land_use_changes_productive_uses[SHRUBLAND\
		],
		 INITIAL_LAND_USE_BY_REGION[OTHER_LAND]+INITIAL_LAND_USE_BY_REGION
		[WATERBODIES]+INITIAL_LAND_USE_BY_REGION[WETLAND]+INITIAL_LAND_USE_BY_REGION[
		SHRUBLAND])
