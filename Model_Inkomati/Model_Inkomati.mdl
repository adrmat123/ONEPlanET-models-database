	IF_THEN_ELSE(SELECT_POLICY_COAL_POWER_PLANT_PHASE_OUT=0, NO_COAL_POWER_PLANTS_PHASE_OUT\
		 , IF_THEN_ELSE(SELECT_POLICY_COAL_POWER_PLANT_PHASE_OUT
	=1, LOW_COAL_POWER_PLANTS_PHASE_OUT, IF_THEN_ELSE(SELECT_POLICY_COAL_POWER_PLANT_PHASE_OUT\
		=2, PARTIAL_COAL_POWER_PLANTS_PHASE_OUT
	 , IF_THEN_ELSE(SELECT_POLICY_COAL_POWER_PLANT_PHASE_OUT=3, HIGH_COAL_POWER_PLANTS_PHASE_OUT\
		 , USER_DEFINED_PHASE_OUT_OF_COAL_POWER_PLANTS ))))
