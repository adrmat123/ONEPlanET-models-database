		 )
	~	Dmnl
	~		|

INITIAL_YIELDS_OF_IRRIGATED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I]=
	0.8
	~	t/ha
	~		|

irrigated_crops_available_by_region[LAND_PRODUCTS_I]=
	area_of_irrigated_crops[LAND_PRODUCTS_I]*yields_of_irrigated_crops[LAND_PRODUCTS_I
	]
	~	t/Year
	~		|

ANIMALS_TYPES_I:
	DAIRY_CATTLE, OTHER_CATTLE, SHEEP, CHICKENS, SWINE
	~	
	~		|

area_for_plantations= INTEG (
	increase_of_area_for_plantations-increase_of_effective_area_for_plantations,
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS])
	~	ha
	~		|

N_FRACTION_VOLATILISES=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land', 'FRACTION_VOLATILISES')
	~	kgvolatilised/kgN
	~	fraction of Volatile nitrogen in indirect emissions
	|

area_of_forests= INTEG (
	increase_of_area_of_forests-increase_of_effective_area_of_forests,
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED])
	~	ha
	~		|

area_of_irrigated_crops[LAND_PRODUCTS_I]=
	land_use_area_by_region[CROPLAND_IRRIGATED]*LAND_AREA_ADJUST_COEFFICIENT
	~	ha
	~		|

area_of_irrigated_wheat=
	area_of_irrigated_crops[WHEAT]
	~	ha
	~		|

area_of_rainfed_crops[LAND_PRODUCTS_I]=
