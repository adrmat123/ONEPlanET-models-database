	~	ha
	~		|

area_of_rainfed_wheat=
	area_of_rainfed_crops[WHEAT]
	~	ha
	~		|

land_products_available_from_croplands[CORN]=
	irrigated_crops_available_by_region[CORN]+rainfed_crops_available_by_region[CORN] ~~|
land_products_available_from_croplands[WHEAT]=
	irrigated_crops_available_by_region[WHEAT]+rainfed_crops_available_by_region[WHEAT] ~~|
land_products_available_from_croplands[SORGHUM]=
	irrigated_crops_available_by_region[SORGHUM]+rainfed_crops_available_by_region[SORGHUM\
		] ~~|
land_products_available_from_croplands[TUBERS]=
	irrigated_crops_available_by_region[TUBERS]+rainfed_crops_available_by_region[TUBERS\
		] ~~|
land_products_available_from_croplands[SOY]=
	irrigated_crops_available_by_region[SOY]+rainfed_crops_available_by_region[SOY] ~~|
land_products_available_from_croplands[LEGUMES]=
	irrigated_crops_available_by_region[LEGUMES]+rainfed_crops_available_by_region[LEGUMES
	] ~~|
land_products_available_from_croplands[SUNFLOWER]=
	irrigated_crops_available_by_region[SUNFLOWER]+rainfed_crops_available_by_region[SUNFLOWER
	] ~~|
land_products_available_from_croplands[FRUITS_VEGETABLES]=
	irrigated_crops_available_by_region[FRUITS_VEGETABLES]+rainfed_crops_available_by_region\
		[
	FRUITS_VEGETABLES] ~~|
land_products_available_from_croplands[SUGAR_CROPS]=
	irrigated_crops_available_by_region[SUGAR_CROPS]+rainfed_crops_available_by_region[SUGAR_CROPS
	] ~~|
land_products_available_from_croplands[MACADAMIA]=
	irrigated_crops_available_by_region[MACADAMIA]+rainfed_crops_available_by_region[MACADAMIA
	]
	~	t/Year
	~		|

land_products_demanded_for_food[LAND_PRODUCTS_I]=
	land_products_demanded_for_food_before_losses[LAND_PRODUCTS_I]*LOSS_FACTOR_OF_LAND_PRODUCTS\
		[LAND_PRODUCTS_I]
	~	t/Year
	~		|

land_products_demanded_for_food_before_losses[LAND_PRODUCTS_I]=
	AGROFOOD_TRANSFORM_MATRIX[CEREALS_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[CEREALS_DIET
	] + 
	AGROFOOD_TRANSFORM_MATRIX[TUBERS_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[TUBERS_DIET
	] + 
	AGROFOOD_TRANSFORM_MATRIX[PULSES_LEGUMES_NUTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[
	PULSES_LEGUMES_NUTS] + 
	AGROFOOD_TRANSFORM_MATRIX[FRUITS_VEGETABLES_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FRUITS_VEGETABLES_DIET] + 
	AGROFOOD_TRANSFORM_MATRIX[FATS_VEGETAL,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FATS_VEGETAL
	] + 
	AGROFOOD_TRANSFORM_MATRIX[FATS_ANIMAL,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FATS_ANIMAL
	] + 
	AGROFOOD_TRANSFORM_MATRIX[DAIRY,LAND_PRODUCTS_I]*food_demanded_from_land_products[DAIRY\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[EGGS,LAND_PRODUCTS_I]*food_demanded_from_land_products[EGGS\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[MEAT_RUMINANTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[MEAT_RUMINANTS
	] + 
	AGROFOOD_TRANSFORM_MATRIX[MEAT_MONOGASTRIC,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[MEAT_MONOGASTRIC
	] + 
	AGROFOOD_TRANSFORM_MATRIX[FISH,LAND_PRODUCTS_I]*food_demanded_from_land_products[FISH\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[SUGARS,LAND_PRODUCTS_I]*food_demanded_from_land_products[SUGARS\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[BEVERAGES,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[BEVERAGES]
	 + 
	AGROFOOD_TRANSFORM_MATRIX[STIMULANTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[STIMULANTS
	]
	~	t/Year
	~		|

LAND_PRODUCTS_I:
	CORN, WHEAT, SORGHUM, TUBERS, SOY, LEGUMES, SUNFLOWER, FRUITS_VEGETABLES, SUGAR_CROPS\
		, MACADAMIA
	~	
	~		|

aux_trends_of_yield_change_R_and_I[LAND_PRODUCTS_I]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE,
	
	TRENDS_OF_YIELD_CHANGE_RAINFED[LAND_PRODUCTS_I],
	
	MAX(0, TRENDS_OF_YIELD_CHANGE_RAINFED[LAND_PRODUCTS_I]))
	~	t/(Year*ha)
	~		|

land_use_area_by_region[CROPLAND_RAINFED]=
	land_use_area_productive_uses[CROPLAND_RAINFED] ~~|
land_use_area_by_region[CROPLAND_IRRIGATED]=
	land_use_area_productive_uses[CROPLAND_IRRIGATED] ~~|
land_use_area_by_region[FOREST_MANAGED]=
	land_use_area_productive_uses[FOREST_MANAGED] ~~|
land_use_area_by_region[FOREST_PRIMARY]=
	land_use_area_productive_uses[FOREST_PRIMARY] ~~|
land_use_area_by_region[FOREST_PLANTATIONS]=
	land_use_area_productive_uses[FOREST_PLANTATIONS] ~~|
land_use_area_by_region[SHRUBLAND]=
	land_use_area_productive_uses[SHRUBLAND]*SHARE_OF_SHRUBLAND ~~|
land_use_area_by_region[GRASSLAND]=
	land_use_area_productive_uses[GRASSLAND] ~~|
land_use_area_by_region[WETLAND]=
	wetland_area ~~|
land_use_area_by_region[URBAN_LAND]=
	land_use_area_productive_uses[URBAN_LAND] ~~|
land_use_area_by_region[WATERBODIES]=
	waterbodies_area ~~|
land_use_area_by_region[OTHER_LAND]=
	(land_use_area_productive_uses[OTHER_LAND]-wetland_area-waterbodies_area)*(1-SHARE_OF_SHRUBLAND\
		)
	~	ha
	~	land use area by region
	|

land_use_changes_demanded[LANDS_I]=
	IF_THEN_ELSE( Time<TIME_HISTORICAL_DATA_LAND_MODULE,
	trends_of_land_use_changes[LANDS_I],
	
	SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS*(land_use_changes_demanded_before_exogenous[LANDS_I\
		])+
	
	(1-SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS)*CHECK_EXOGENOUS_LAND_USE_DEMANDS[LANDS_I] \
		)
	~	ha/Year
	~		|

land_use_changes_demanded_before_exogenous[CROPLAND_RAINFED]=
	trends_of_land_use_changes[CROPLAND_RAINFED]+land_use_changes_driven_by_demands[CROPLAND_RAINFED
	] ~~|
land_use_changes_demanded_before_exogenous[CROPLAND_IRRIGATED]=
	trends_of_land_use_changes[CROPLAND_IRRIGATED] ~~|
land_use_changes_demanded_before_exogenous[FOREST_MANAGED]=
	trends_of_land_use_changes[FOREST_MANAGED]+land_use_changes_driven_by_demands[FOREST_MANAGED\
		] ~~|
land_use_changes_demanded_before_exogenous[FOREST_PRIMARY]=
	trends_of_land_use_changes[FOREST_PRIMARY]+land_use_changes_driven_by_demands[FOREST_PRIMARY\
		] ~~|
land_use_changes_demanded_before_exogenous[FOREST_PLANTATIONS]=
	trends_of_land_use_changes[FOREST_PLANTATIONS]+land_use_changes_driven_by_demands[FOREST_PLANTATIONS
	] ~~|
land_use_changes_demanded_before_exogenous[SHRUBLAND]=
	0 ~~|
land_use_changes_demanded_before_exogenous[GRASSLAND]=
	trends_of_land_use_changes[GRASSLAND] ~~|
land_use_changes_demanded_before_exogenous[WETLAND]=
	0 ~~|
land_use_changes_demanded_before_exogenous[URBAN_LAND]=
	land_use_changes_driven_by_demands[URBAN_LAND] ~~|
land_use_changes_demanded_before_exogenous[WATERBODIES]=
	0 ~~|
land_use_changes_demanded_before_exogenous[OTHER_LAND]=
	0
	~	ha/Year
	~		|

land_use_changes_driven_by_demands[CROPLAND_RAINFED]=
	IF_THEN_ELSE( Time<TIME_HISTORICAL_DATA_LAND_MODULE, 0,  increment_of_cropland_rainfed_demanded\
		   ) ~~|
land_use_changes_driven_by_demands[CROPLAND_IRRIGATED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, 0, increment_of_cropland_irrigated_demanded\
		  ) ~~|
land_use_changes_driven_by_demands[FOREST_MANAGED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, 0,   afforestation_due_to_policies\
		 ) ~~|
land_use_changes_driven_by_demands[FOREST_PRIMARY]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, 0,   afforestation_due_to_policies\
		 ) ~~|
land_use_changes_driven_by_demands[FOREST_PLANTATIONS]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, 0,   forest_plantations_growth_due_to_policies\
		 ) ~~|
land_use_changes_driven_by_demands[SHRUBLAND]=
	0 ~~|
land_use_changes_driven_by_demands[GRASSLAND]=
	0 ~~|
land_use_changes_driven_by_demands[WETLAND]=
	0 ~~|
land_use_changes_driven_by_demands[URBAN_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, 0,   increment_of_urban_land_demanded\
		 ) ~~|
land_use_changes_driven_by_demands[WATERBODIES]=
	0 ~~|
land_use_changes_driven_by_demands[OTHER_LAND]=
	0
	~	ha/Year
	~		|

land_use_changes_productive_uses[CROPLAND_RAINFED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[CROPLAND_RAINFED
	](Time) , vector_of_land_use_changes[CROPLAND_RAINFED] ) ~~|
land_use_changes_productive_uses[CROPLAND_IRRIGATED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[CROPLAND_IRRIGATED
	](Time) , vector_of_land_use_changes[CROPLAND_IRRIGATED] ) ~~|
land_use_changes_productive_uses[FOREST_MANAGED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[FOREST_MANAGED
	]
	(Time) , vector_of_land_use_changes[FOREST_MANAGED] ) ~~|
land_use_changes_productive_uses[FOREST_PRIMARY]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[FOREST_PRIMARY
	]
	(Time) , vector_of_land_use_changes[FOREST_PRIMARY] ) ~~|
land_use_changes_productive_uses[FOREST_PLANTATIONS]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[FOREST_PLANTATIONS
	](Time) , vector_of_land_use_changes[FOREST_PLANTATIONS] ) ~~|
land_use_changes_productive_uses[SHRUBLAND]=
	0 ~~|
land_use_changes_productive_uses[GRASSLAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[GRASSLAND](Time
	) , vector_of_land_use_changes[GRASSLAND] ) ~~|
land_use_changes_productive_uses[WETLAND]=
	0 ~~|
land_use_changes_productive_uses[URBAN_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[URBAN_LAND](
Time
	) , vector_of_land_use_changes[URBAN_LAND] ) ~~|
land_use_changes_productive_uses[WATERBODIES]=
	0 ~~|
land_use_changes_productive_uses[OTHER_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , 
	HISTORICAL_LAND_USE_CHANGE_BY_REGION[OTHER_LAND](Time)+HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[WATERBODIES
	](Time)+
	HISTORICAL_LAND_USE_CHANGE_BY_REGION[WETLAND](Time)+HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[
SHRUBLAND
	](Time) , 
	vector_of_land_use_changes[OTHER_LAND]+vector_of_land_use_changes[WATERBODIES] +
	vector_of_land_use_changes[WETLAND])+vector_of_land_use_changes[SHRUBLAND]
	~	ha/Year
	~		|

CH4_emissions_agriculture=
	CH4_emissions_livestock
	~	MtCH4/Year
	~	Total CH4 emissions from agricultur BY region.
		Important note: the emissions calculated in this variable from agriculture \
		are ONLY those related to "Enteric fermentation", "Manure management", \
		"Rice cultivation" , and "Synthetic Fertilizers. The rest of agriculture \
		emissions are not included in this variable such as crop residues, burning \
		of crop residues, manure left on pasture, manure applied to soils, or \
		energy use in agriculture.
	|

CH4_emissions_enteric_fermentation[ANIMALS_TYPES_I]=
	FACTOR_EMISSIONS_ENTERIC_FERMENTATION[ANIMALS_TYPES_I]*EXOGENOUS_NUMBER_OF_ANIMALS[ANIMALS_TYPES_I
	]*(UNIT_CONVERSION_Mt_t
	*UNIT_CONVERSION_t_kg_0)
	~	Mt/Year
	~	Equation for CH4 emissions based on activity data (animals) and factor \
		emissions (from IPCC)
	|

DAIRY_CATTLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT[MANURE_MANAGEMENT_SYSTEM_I\
		]=
	METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]*DAIRY_CATTLE_MANURE_SYSTEM\
		[MANURE_MANAGEMENT_SYSTEM_I]
	~	Dmnl
	~		|

CH4_emissions_livestock=
	CH4_emissions_enteric_fermentation_by_region+CH4_emissions_manure_management_by_region
	~	MtCH4/Year
	~		|

CH4_emissions_manure_management[ANIMALS_TYPES_I]=
	EXOGENOUS_NUMBER_OF_ANIMALS[ANIMALS_TYPES_I]*EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED\
		[ANIMALS_TYPES_I]*UNIT_CONVERSION_t_kg_0*UNIT_CONVERSION_Mt_t
	~	MtCH4/Year
	~		|

CH4_emissions_manure_management_by_region=
	SUM(CH4_emissions_manure_management[ANIMALS_TYPES_I!])*(1+SHARE_REST_CH4_MANURE_MANAGEMENT_EMISSIONS\
		)
	~	MtCH4/Year
	~		|

CHECK_EXOGENOUS_LAND_USE_DEMANDS[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'EXOGENOUS_LAND_USE_DEMANDS')
	~	ha/Year
	~	Exogenous land use demands
	|

SWINE_MANURE_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'SWINE_CATTLE_MANURE_SYSTEM'
	 )
	~	Dmnl
	~	% MS by default. The "less emissions" options are: solid storage, dry lot, \
		range/paddock, daily spread and Pit storage <1month
		From IPCC 2006 Chapter livestock, adapted to WILIAM regions
		 % of the types  manure systems by type of animal , for the calculation of \
		methane emissions due to manure management.
	|

CHEMICAL_FERTILIZERS_PER_CROPLAND_AREA=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'CHEMICAL_FERTILIZERS_PER_CROPLAND_AREA'\
		 )
	~	t/(Year*ha)
	~		|

matrix_of_accumulated_land_use_changes[LANDS_I,LANDS_MAP_I]= INTEG (
	matrix_of_acumulated_land_use_changes[LANDS_I,LANDS_MAP_I],
		0)
	~	ha
	~		|

matrix_of_acumulated_land_use_changes[LANDS_I,LANDS_MAP_I]=
	matrix_of_land_use_changes[LANDS_I,LANDS_MAP_I]
	~	ha/Year
	~		|

matrix_of_land_use_change_demands[LANDS_I,CROPLAND_RAINFED]=
	land_use_changes_demanded[CROPLAND_RAINFED]*share_of_land_use_change_from_others[LANDS_I\
		,CROPLAND_RAINFED] ~~|
matrix_of_land_use_change_demands[LANDS_I,CROPLAND_IRRIGATED]=
	land_use_changes_demanded[CROPLAND_IRRIGATED]*share_of_land_use_change_from_others[LANDS_I\
		,CROPLAND_IRRIGATED] ~~|
matrix_of_land_use_change_demands[LANDS_I,FOREST_MANAGED]=
	land_use_changes_demanded[FOREST_MANAGED]
	*share_of_land_use_change_from_others[LANDS_I,FOREST_MANAGED] ~~|
matrix_of_land_use_change_demands[LANDS_I,FOREST_PRIMARY]=
	land_use_changes_demanded[FOREST_PRIMARY]*share_of_land_use_change_from_others[LANDS_I\
		,FOREST_PRIMARY] ~~|
matrix_of_land_use_change_demands[LANDS_I,FOREST_PLANTATIONS]=
	land_use_changes_demanded[FOREST_PLANTATIONS]*share_of_land_use_change_from_others[LANDS_I\
		,FOREST_PLANTATIONS] ~~|
matrix_of_land_use_change_demands[LANDS_I,SHRUBLAND]=
	land_use_changes_demanded[SHRUBLAND]*share_of_land_use_change_from_others
	[LANDS_I,SHRUBLAND] ~~|
matrix_of_land_use_change_demands[LANDS_I,GRASSLAND]=
	land_use_changes_demanded[GRASSLAND]*share_of_land_use_change_from_others
	[LANDS_I,GRASSLAND] ~~|
matrix_of_land_use_change_demands[LANDS_I,WETLAND]=
	land_use_changes_demanded[WETLAND]*share_of_land_use_change_from_others[LANDS_I
	,WETLAND] ~~|
matrix_of_land_use_change_demands[LANDS_I,URBAN_LAND]=
	land_use_changes_demanded[URBAN_LAND]*share_of_land_use_change_from_others[LANDS_I,URBAN_LAND\
		] ~~|
matrix_of_land_use_change_demands[LANDS_I,WATERBODIES]=
	land_use_changes_demanded[WATERBODIES]*share_of_land_use_change_from_others[
	LANDS_I, WATERBODIES] ~~|
matrix_of_land_use_change_demands[LANDS_I,OTHER_LAND]=
	land_use_changes_demanded[OTHER_LAND]*share_of_land_use_change_from_others[LANDS_I,OTHER_LAND\
		]
	~	ha/Year
	~		|

matrix_of_land_use_changes[LANDS_I,LANDS_MAP_I]=
	factor_of_minimum_land_limit[LANDS_I]*factor_of_maximum_land_limit[LANDS_I,LANDS_MAP_I\
		]* (matrix_of_land_use_change_demands[LANDS_I,LANDS_MAP_I])
	~	ha/Year
	~	matrix of land use changes
	|

MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,LANDS_MAP_I]=
	INITIAL_LAND_USE_BY_REGION_2015[LANDS_I]*LIMITS_TO_LAND_USE_CHANGES_BY_REGION[LANDS_I\
		,LANDS_MAP_I
	]
	~	ha
	~		|

MATURATION_TIME_OF_FOREST_MANAGED_MP=
	20
	~	Year
	~		|

MATURATION_TIME_OF_PLANTATIONS_MP=
	20
	~	Year
	~		|

TIME_HISTORICAL_DATA_LAND_MODULE=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'TIME_HISTORICAL_DATA_LAND_MODULE'\
		 )
	~	Year
	~		|

UNIT_CONVERSION_N2ON_N2O=
	44/28
	~	N2O/N2ON
	~	N2O-N_TO_N2O
		N2O = N2O-N ? 44/28 (IPCC)
	|

CULTIVATION_PERIOD_WHEAT=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx','land', 'CULTIVATION_PERIOD_RICE')
	~	days/Year
	~	cultivation period! (120 days?)--> \
		https://www.fao.org/3/s2022e/s2022e02.htm (total grown period:Rice 90-150) \
		(average value)
	|

MAXIMUM_YIELDS_IRRIGATED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'MAXIMUM_YIELDS_IRRIGATED_INDUSTRIAL'
	 )
	~	t/(ha*Year)
	~		|

MAXIMUM_YIELDS_RAINFED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'MAXIMUM_YIELDS_R_AND_I' )
	~	t/ha
	~		|

meat_obtained_from_grasslands=
	INITIAL_MEAT_OBTAINED_FROM_GRASSLANDS*ZIDZ(land_use_area_by_region[GRASSLAND],INITIAL_LAND_USE_BY_REGION
	[GRASSLAND])
	~	t/Year
	~		|

METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'METHANE_CONVERSION_FACTOR_BY_SYSTEM'\
		 )
	~	
	~	 methane conversion factors for each manure management system S by WILIAM \
		region. From IPCC 2006 Chapter livestock, adapted to WILIAM regions
	|

plantations_harvesting=
	0
	~	ha/Year
	~		|

DAIRY_CATTLE_MANURE_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'DAIRY_CATTLE_MANURE_SYSTEM'
	 )
	~	Dmnl
	~	% MS by default. The "less emissions" options are: solid storage, dry lot, \
		range/paddock, daily spread and Pit storage <1month
		From IPCC 2006 Chapter livestock,
		 % of the types  manure systems by type of animal , for the calculation of \
		methane emissions due to manure management .
	|

MINIMUM_LAND_USES_BY_REGION[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'MINIMUM_LAND_USES_BY_REGION'\
		 )
	~	ha
	~		|

dairy_obtained_from_grasslands[GRASSLAND]=
	INITIAL_DAIRY_OBTAINED_FROM_GRASSLANDS*ZIDZ(land_use_area_by_region[GRASSLAND],INITIAL_LAND_USE_BY_REGION\
		 [GRASSLAND])
	~	t/Year
	~		|

model_explorer_manure_management_system[ANIMALS_TYPES_I,MANURE_MANAGEMENT_SYSTEM_I]=
	0
	~	Dmnl
	~		|

total_forest_area_world=
	land_use_area_by_region[FOREST_MANAGED]+land_use_area_by_region[FOREST_PRIMARY]
	~	ha
	~		|

deforested_area=
	IF_THEN_ELSE (land_use_changes_productive_uses[FOREST_MANAGED]<0, land_use_changes_productive_uses\
		[FOREST_MANAGED], 0)
	~	ha/Year
	~		|

N_application=
	fertilizers_demanded* 1/(UNIT_CONVERSION_t_kg_0)
	~	kgN/Year
	~		|

total_plantations_world=
	land_use_area_by_region[FOREST_PLANTATIONS]
	~	ha
	~		|

N20_emissions_agriculture=
	N2O_emissions_fertilizers+N2O_emissions_livestock
	~	Mt_N2O/Year
	~		|

N2O_emissions_livestock=
	N2O_emissions_manure_management
	~	Mt_N2O/Year
	~		|

N2O_emissions_manure_management=
	CH4_emissions_manure_management_by_region*SHARE_REST_N2O_MANURE_MANAGEMENT_EMISSIONS
	~	Mton_N/Year
	~		|

trends_of_land_use_changes[CROPLAND_RAINFED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[CROPLAND_RAINFED
	]
	, TRENDS_OF_LAND_USE_DEMAND[CROPLAND_RAINFED]) ~~|
trends_of_land_use_changes[CROPLAND_IRRIGATED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE,HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[CROPLAND_IRRIGATED
	], TRENDS_OF_LAND_USE_DEMAND[CROPLAND_IRRIGATED]) ~~|
trends_of_land_use_changes[FOREST_MANAGED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[FOREST_MANAGED],
	 
	
	
	TRENDS_OF_LAND_USE_DEMAND[FOREST_MANAGED] ) ~~|
trends_of_land_use_changes[FOREST_PRIMARY]=
	0 ~~|
trends_of_land_use_changes[FOREST_PLANTATIONS]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[FOREST_PLANTATIONS
	] , 
	
	TRENDS_OF_LAND_USE_DEMAND[FOREST_PLANTATIONS]) ~~|
trends_of_land_use_changes[SHRUBLAND]=
	0 ~~|
trends_of_land_use_changes[GRASSLAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[GRASSLAND] ,
	
	
	TRENDS_OF_LAND_USE_DEMAND[GRASSLAND]) ~~|
trends_of_land_use_changes[WETLAND]=
	0 ~~|
trends_of_land_use_changes[URBAN_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[URBAN_LAND] , 
	
	
	TRENDS_OF_LAND_USE_DEMAND[URBAN_LAND]) ~~|
trends_of_land_use_changes[ WATERBODIES]=
	0 ~~|
trends_of_land_use_changes[OTHER_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE,HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION\
		[OTHER_LAND
	], TRENDS_OF_LAND_USE_DEMAND[OTHER_LAND])
	~	ha/Year
	~		|

OTHER_CATTLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT[MANURE_MANAGEMENT_SYSTEM_I\
		]=
	METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]*OTHER_CATTLE_MANURE_SYSTEM\
		[MANURE_MANAGEMENT_SYSTEM_I]
	~	kg/(Year*number_animals)
	~	IPCC 2006 Guidelines (Tier 1) (Eggleston, Buendia, Miwa, Ngara, & Tanabe, 2006) \
		tABLES 10.14 TO 10.16
		Adapted to WILIAM regions. 
		Not used the ones of "goat", sheep and chickens, as this factor is to \
		applied to the rest in which policies about manure system can be applied
	|

diet[FOODS_I]=
	DIETS_INITIAL[FOODS_I]
	~	kg/(Year*people)
	~		|

DIETS_INITIAL[FOODS_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'DIETS_INITIAL')
	~	kg/(Year*people)
	~	Initial diet
	|

UNIT_CONVERSION_Mt_t=
	1/UNIT_CONVERSION_t_Mt_0
	~	Mt/t
	~		|

OTHER_CATTLE_MANURE_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'OTHER_CATTLE_MANURE_SYSTEM'
	 )
	~	Dmnl
	~	% MS by default. The "less emissions" options are: solid storage, dry lot, \
		range/paddock, daily spread and Pit storage <1month
		From IPCC 2006 Chapter livestock
		 % of the types  manure systems by type of animal , for the calculation of \
		methane emissions due to manure management .
	|

growth_of_plantation_area=
	IF_THEN_ELSE(land_use_changes_productive_uses[FOREST_PLANTATIONS]>0, land_use_changes_productive_uses\
		[FOREST_PLANTATIONS], 0)
	~	ha/Year
	~		|

effective_area_for_plantations= INTEG (
	increase_of_effective_area_for_plantations-plantations_harvesting,
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS])
	~	ha
	~		|

effective_area_of_forests= INTEG (
	increase_of_effective_area_of_forests-deforested_area,
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED])
	~	ha
	~		|

yields_of_rainfed_industrial_crops[LAND_PRODUCTS_I]= INTEG (
	increase_of_yields_industrial_R_and_I[LAND_PRODUCTS_I],
		INITIAL_YIELDS_OF_INDUSTRIAL_RAINFED_CROPS[LAND_PRODUCTS_I])
	~	t/ha
	~		|

SHARE_REST_CH4_MANURE_MANAGEMENT_EMISSIONS=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'SHARE_REST_CH4_MANURE_MANAGEMENT_EMISSIONS'\
		 )
	~	Dmnl
	~		|

HISTORICAL_LAND_USE_CHANGE_BY_REGION[CROPLAND_RAINFED]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_CROPLAND_RAINFED_VARIATION_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[CROPLAND_IRRIGATED](
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_CROPLAND_IRRIGATED_VARIATION_BY_REGION'\
		)) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[FOREST_MANAGED](
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_MANAGED_VARIATION_BY_REGION'\
		)) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[FOREST_PRIMARY](
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PRIMARY_VARIATION_BY_REGION'\
		)) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[FOREST_PLANTATIONS](
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PLANTATIONS_VARIATION_BY_REGION'\
		)) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[SHRUBLAND](
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_SHRUBLAND_VARIATION_BY_REGION'\
		)) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[GRASSLAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_GRASSLAND_VARIATION_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[WETLAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_WETLAND_VARIATION_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[URBAN_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_URBAN_LAND_VARIATION_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[WATERBODIES]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_WATERBODIES_VARIATION_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[OTHER_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx' , 'land'   , 'TIME_LAND_USE', 'HISTORICAL_OTHER_LAND_VARIATION_BY_REGION'\
		)
	~	ha/Year
	~		|

SHARE_UPLAND_WHEAT_BY_REGION=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'SHARE_UPLAND_WHEAT_BY_REGION*'\
		 )
	~	Dmnl
	~	Share of upland wheat with respect to the total "rainfed" area
	|

HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,CROPLAND_RAINFED]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'HISTORICAL_SHARE_OF_CROPLAND_RAINFED_FROM_OTHERS_BY_REGION'\
		 ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,CROPLAND_IRRIGATED]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'INITIAL_SHARE_OF_CROPLAND_IRRIGATED_FROM_OTHERS_BY_REGION'\
		 ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_MANAGED]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'INITIAL_SHARE_OF_AFFORESTATION_FROM_OTHERS_BY_REGION'\
		 ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_PRIMARY]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_PLANTATIONS]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'INITIAL_SHARE_OF_FOREST_PLANTATIONS_FROM_OTHERS_BY_REGION'\
		 ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,SHRUBLAND]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,GRASSLAND]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'HISTORICAL_SHARE_OF_GRASSLAND_FROM_OTHERS_BY_REGION'\
		 ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,WETLAND]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,URBAN_LAND]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'INITIAL_SHARE_OF_URBAN_LAND_FROM_OTHERS_BY_REGION'\
		) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,WATERBODIES]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,OTHER_LAND]=
	0
	~	Dmnl
	~		|

HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION'\
		 )
	~	ha/Year
	~		|

total_food_produced[LAND_PRODUCTS_I]=
	dairy_obtained_from_grasslands[GRASSLAND] +land_products_available_from_croplands[LAND_PRODUCTS_I\
		]+meat_obtained_from_grasslands
	~	t/Year
	~		|

LOSS_FACTOR_OF_LAND_PRODUCTS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx' , 'land' , 'LOSS_FACTOR_LAND_PRODUCTS*'\
		)
	~	Dmnl
	~	Factor representing the losses of land products in the supply chain (from \
		land to supermarket)
	|

EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT'\
		 )
	~	kg/(Year*number_animals)
	~		|

EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[DAIRY_CATTLE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT\
		[DAIRY_CATTLE]* SUM
	 (model_explorer_manure_management_system
	[DAIRY_CATTLE,MANURE_MANAGEMENT_SYSTEM_I!]) , 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[DAIRY_CATTLE]* SUM (DAIRY_CATTLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) ) ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[OTHER_CATTLE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[OTHER_CATTLE]* SUM (model_explorer_manure_management_system
	[OTHER_CATTLE,MANURE_MANAGEMENT_SYSTEM_I!]) ,
	 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[OTHER_CATTLE]* SUM (OTHER_CATTLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) ) ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[SHEEP]=
	EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[SHEEP] ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[CHICKENS]=
	EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[CHICKENS] ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[SWINE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT\
		[SWINE]*SUM(model_explorer_manure_management_system
	[SWINE,MANURE_MANAGEMENT_SYSTEM_I!]) , 
	
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[SWINE]*SUM(SWINE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) )
	~	kg/(Year*number_animals)
	~		|

EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT'\
		 )
	~	Dmnl
	~	Methane factor emission of manure management
	|

increase_of_effective_area_of_forests=
	IF_THEN_ELSE(increase_of_area_of_forests>0, area_of_forests*(1/MATURATION_TIME_OF_FOREST_MANAGED_MP\
		), 0)
	~	ha/Year
	~		|

increase_of_effective_area_for_plantations=
	IF_THEN_ELSE(increase_of_area_for_plantations>0, area_for_plantations*(1/MATURATION_TIME_OF_PLANTATIONS_MP
	), 0)
	~	ha/Year
	~		|

rainfed_crops_available_by_region[LAND_PRODUCTS_I]=
	area_of_rainfed_crops[LAND_PRODUCTS_I]*yields_of_rainfed_crops[LAND_PRODUCTS_I]
	~	t/Year
	~		|

increase_of_yields_rainfed_industrial[LAND_PRODUCTS_I]=
	IF_THEN_ELSE( yields_of_irrigated_industrial_crops[LAND_PRODUCTS_I]<MAXIMUM_YIELDS_IRRIGATED_INDUSTRIAL_CROPS\
		[LAND_PRODUCTS_I],  TRENDS_OF_INDUSTRIAL_IRRIGATED_YIELDS[LAND_PRODUCTS_I], 0)
	~	t/(ha*Year)
	~		|

SCALING_FACTOR_WATER_REGIME_WHEAT_RAINFED=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'SCALING_FACTOR_WATER_REGIME_WHEAT_RAINFED'\
		)
	~	Dmnl
	~	water regime during the cultivation period default scaling factors and \
		error ranges reflecting different water regimes. (tABLE 5.12, ipcc 2006 \
		Tier 1). ( DURING THE CULTIVATION PERIOD RELATIVE TO CONTINUOUSLY FLOODED \
		FIELDS )
	|

SWITCH_LAW_LIMITS_LAND_BY_SOURCE=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'SWITH_LAW_LIMITS_LAND_BY_SOURCE'\
		 )
	~	Dmnl
	~		|

wetland_area= INTEG (
	variation_of_wetland_area,
		INITIAL_LAND_USE_BY_REGION[WETLAND])
	~	ha
	~		|

FACTOR_EMISSION_N_APPLICATION=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'EF_N2O_direct_fertilizers')
	~	kg_N2ON/kgN
	~	IPCC 2006 (Tier 1, Chapter 11, Table 11.1) default values for direct emissions  N2O \
		emitted from the various synthetic and organic N applications to soils, \
		including crop residue and mineralisation of soil organic carbon in \
		mineral soils due to land-use change or management
		"Conversion of N2O-N emissions to N2O emissions for reporting purposes is performed \
		by using the following 
		equation: N2O = N2O-N * 44/28 
		1 kg N2O-N = 1 kg de N= (44/28)*1 kg N2O (factor from kg of N to kg of \
		N2O) (N2O= 44 g/mol and N=28 g/mol, and 1N2Omol=1N mol)
	|

yields_of_irrigated_crops[LAND_PRODUCTS_I]=
	yields_of_irrigated_industrial_crops[LAND_PRODUCTS_I]
	~	t/(ha*Year)
	~		|

