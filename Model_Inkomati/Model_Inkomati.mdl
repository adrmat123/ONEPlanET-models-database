	MATRIX_UNIT_PREFIXES[BASE_UNIT,kilo]*km_per_m_units
	~	km/m
	~		|

UNIT_CONVERSION_kt_Gt=
	MATRIX_UNIT_PREFIXES[mega,BASE_UNIT]*kt_per_Gt_units
	~	Kt/Gt
	~		|

UNIT_CONVERSION_m_mm=
	MATRIX_UNIT_PREFIXES[BASE_UNIT,kilo]*m_per_mm_units
	~	m/mm
	~		|

ha_per_Mha_units=
	1
	~	ha/MHa
	~		|

UNIT_CONVERSION_t_kg_0=
	MATRIX_UNIT_PREFIXES[kilo,mega]*t_per_kg_units
	~	t/kg
	~		|

UNIT_CONVERSION_Mt_Gt=
	MATRIX_UNIT_PREFIXES[giga,mega]*Mt_per_Gt_units
	~	Mt/Gt
	~		|

UNIT_CONVERSION_Mt_kt=
	MATRIX_UNIT_PREFIXES[kilo,mega]*Mt_per_kt_units
	~	Mt/Kt
	~		|

t_per_Gt_units=
	1
	~	t/Gt
	~		|

UNIT_CONVERSION_Mt_t_0=
	1/UNIT_CONVERSION_t_Mt_0
	~	Mt/t
	~		|

t_per_kt_units=
