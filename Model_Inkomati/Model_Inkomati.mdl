	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx' , 'land' , 'YEAR_FINAL_FOREST_PLANTATIONS*'\
		 )
	~	Year
	~		|

afforestation_due_to_policies=
	IF_THEN_ELSE( SWITCH_AFFORESTATION_SP=1:AND:Time>YEAR_INITIAL_AFFORESTATION_SP :AND:\
		Time<YEAR_FINAL_AFFORESTATION_SP
	,
	 (OBJECTIVE_AFFORESTATION_SP*INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED] )/
	
	(YEAR_FINAL_AFFORESTATION_SP-YEAR_INITIAL_AFFORESTATION_SP) , 0
	 )
	~	ha/Year
	~		|

increment_of_cropland_irrigated_demanded=
	IF_THEN_ELSE( SWITCH_CROPLAND_IRRIGATED_SP=1:AND:Time>YEAR_INITIAL_CROPLAND_IRRIGATED_SP\
		 :AND:Time
	<YEAR_FINAL_CROPLAND_IRRIGATED_SP
	,
	 (OBJECTIVE_CROPLAND_IRRIGATED_SP*INITIAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED] )/
	
	(YEAR_FINAL_CROPLAND_IRRIGATED_SP-YEAR_INITIAL_CROPLAND_IRRIGATED_SP) , 0
	 )
	~	ha
	~		|

increment_of_cropland_rainfed_demanded=
	IF_THEN_ELSE( SWITCH_CROPLAND_RAINFED_SP=1:AND:Time>YEAR_INITIAL_CROPLAND_RAINFED_SP\
		 :AND:Time
	<YEAR_FINAL_CROPLAND_RAINFED_SP
	,
	 (OBJECTIVE_CROPLAND_RAINFED_SP*INITIAL_LAND_USE_BY_REGION[CROPLAND_RAINFED] )/
	
	(YEAR_FINAL_CROPLAND_RAINFED_SP-YEAR_INITIAL_CROPLAND_RAINFED_SP) , 0
	 )
	~	
	~		|

OBJECTIVE_AFFORESTATION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx' , 'land' , 'POLICY_OBJECTIVE_AFFORESTATION_SP*'\
		 )
	~	ha
	~	-Policy of increase of managed forest.
		-This is an increase of the high biodiversity forest (not the increase of tree \
		plantations)
		-The OBJECTIVE area of forest is achieved in the FINAL TIME with a lineal evolution.
		-OBJECTIVE of this policy is expressed as a % of the historical value of the area of \
		forest of 2015 (0=0%, means that there is no increase of forest;  1=100%,  \
		means that the area reforested equals forest area in 2015).
		-This policy competes with the rest of land uses, therefore, the forest \
		area objective might not be achieved in the final year due to land use \
		changes from forest to other uses.
	|

