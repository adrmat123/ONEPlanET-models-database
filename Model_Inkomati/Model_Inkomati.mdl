	|

INITIAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS_MP[LANDS_I,CROPLAND_RAINFED]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'INITIAL_SHARE_OF_CROPLAND_RAINFED_FROM_OTHERS_BY_REGION'\
		 ) ~~|
