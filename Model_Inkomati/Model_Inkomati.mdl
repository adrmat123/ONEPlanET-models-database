land_use_area_productive_uses[CROPLAND_IRRIGATED]= INTEG (
	land_use_changes_productive_uses[CROPLAND_IRRIGATED],
		INITIAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED]) ~~|
land_use_area_productive_uses[FOREST_MANAGED]= INTEG (
	land_use_changes_productive_uses[FOREST_MANAGED],
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED]) ~~|
land_use_area_productive_uses[FOREST_PRIMARY]= INTEG (
	land_use_changes_productive_uses[FOREST_PRIMARY],
