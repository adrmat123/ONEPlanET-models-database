		 ) ~~|
INITIAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS_MP[LANDS_I,FOREST_MANAGED]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'land' , 'INITIAL_SHARE_OF_AFFORESTATION_FROM_OTHERS_BY_REGION'\
		 ) ~~|
