aux_gradual_construction_of_RES=
	0.25/2*(PULSE(2015 , 2 )+PULSE( 2017 , 2 )+PULSE( 2019 ,2 )+PULSE( 2021 ,2))
	~	
	~		|

RES_INI_CONSTRUCTION_DELAY[PV]= DELAY_FIXED (
	aux_gradual_construction_of_RES*RES_INI_CONSTRUCTION[PV], RES_INI_TIME_CONSTRUCTION[\
		PV] ,
	 0) ~~|
RES_INI_CONSTRUCTION_DELAY[WIND]= DELAY_FIXED (
	aux_gradual_construction_of_RES*RES_INI_CONSTRUCTION[WIND], RES_INI_TIME_CONSTRUCTION\
		[WIND] ,
	 0) ~~|
RES_INI_CONSTRUCTION_DELAY[HYDRO]= DELAY_FIXED (
	aux_gradual_construction_of_RES*RES_INI_CONSTRUCTION[HYDRO], RES_INI_TIME_CONSTRUCTION\
		[HYDRO] ,
	 0) ~~|
RES_INI_CONSTRUCTION_DELAY[BIOMASS_PP]= DELAY_FIXED (
	aux_gradual_construction_of_RES*RES_INI_CONSTRUCTION[BIOMASS_PP], RES_INI_TIME_CONSTRUCTION\
		[BIOMASS_PP] ,
	 0)
	~	
	~	Programming auxiliary variable
	|

