	IF_THEN_ELSE( switch_land_production_policy[LANDS_I]=1:AND:Time>year_initial_land_protection_policy\
		[LANDS_I] :AND:Time<year_final_land_protection_policy[LANDS_I], 
	
	objective_land_protection_policy[LANDS_I]  , 0 )
	~	Dmnl
	~	share of the initial land of each type in 2015 that is protected from \
		changes to other uses
	|

agri_water_use=
	crop_water_use_on_off+livestock_water_use
	~	m3/Year
	~	Agri water use, so crop water use + livestock water use
	|

agri_water_use_P1_on=
	agri_water_use*0.7
	~	m3/Year
	~	agri water use with P1 on 30% reduction of total agricultural water demand
	|

agri_water_use_P4_P1_on_off=
	IF_THEN_ELSE (switch_p1=1, agri_water_use_P1_on, agri_water_use)
	~	m3/Year
	~	agri_water_use_P4_P1_on_off. The value changes if the policy/ies are on or \
		off
	|

water_use_per_capita_P3_on=
	water_use_per_capita_b*0.9
	~	m3/(Year*people)
	~	10% per capita water demand reduction
	|

water_use_per_capita_P3_on_off=
	IF_THEN_ELSE (switch_P3=1, water_use_per_capita_P3_on, water_use_per_capita_b)
	~	m3/(Year*people)
	~		|

