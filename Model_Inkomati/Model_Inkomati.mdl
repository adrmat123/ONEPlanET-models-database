environmental_flow_requirement:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'environmental_flow_requirement'\
		 )
	~	m3/Year
	~	Environmental_Flow_Requirement
		1.36705e+09
	|

water_available=
	total_water_available
	~	
	~		|

Average_Water_Intensity_Industry=
	530.296
	~	m3/M$
	~	Average industrial water withdrawal per unit of real value added, \
		calculated as the 2015–2020 mean. Feeds Industrial_Water_Demand in \
		projection years. Unit: m³/M$. Treat as an exogenous series; document any \
		assumed efficiency improvements
	|

Total_Industrial_Water_use=
	industrial_water_withdrawal+tot_Water_use_for_electricity_production
	~	m3
	~		|

Industrial_Water_Demand=
	IF_THEN_ELSE(Time>=2021, Average_Water_Intensity_Industry*RVA_Industry , Total_Industrial_Water_use\
		)
	~	m3
	~		|

RVA_Agriculture=
	Real_Value_Added_by_sector[AGRICULTURE_FORESTRY_FISHING]
	~	M$
	~		|

Agriculture_Water_Demand=
	IF_THEN_ELSE(Time>=2021, Average_Water_Intensity_Agriculture*RVA_Agriculture , agri_water_use\
		 )
	~	m3
	~		|

RVA_Industry=
	Real_Value_Added_by_sector[INDUSTRY]
	~	M$
	~		|

Water_Suppply=
	total_water_available*0.2
	~	m3/Year
	~		|

Water_Intensity_Industry=
	Total_Industrial_Water_use/RVA_Industry
	~	m3/M$
	~		|

Average_Water_Intensity_Agriculture=
	17576
	~	m3/M$
	~	Average water withdrawn per unit of real value added in agriculture, \
		forestry and fishing. Computed as the 2015–2020 mean and used to project \
		Agriculture_Water_Demand when the exogenous mode is active. Unit: m³/M$. \
		Update with local data if available.
	|

water_scarcity_indicator=
	min(1,ZIDZ(Water_availability,Water_demand_by_sector))
	~	
	~	This variable quantifies the ratio of available water resources to \
		Water_Demand, expressed as a value between 0 and 1. A value of 1 signifies \
		sufficient water availability to meet demand, while a value closer to 0 \
		indicates increasing levels of water scarcity, which could limit \
		agricultural and industrial production. This indicator provides critical \
		insights into the effects of water scarcity on overall economic \
		performance and resource management.
	|

Water_Intensity_Agriculture=
	agri_water_use/RVA_Agriculture
	~	m3/M$
	~		|

Average_Water_Intensity_Domestic=
	40520
	~	m3/M$
	~	Average domestic water use per unit of household consumption (proxy for \
		service output), using the 2015–2020 mean. Applied to \
		Domestic_Water_Demand in projection years. Unit: m³/M$. Calibrate to \
		utility records where possible; otherwise keep the scenario series.
	|

EXPECTED_INVESTMENT_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'INVESTMENT_SSP3'\
		 )
	~	M$
	~		|

EXPECTED_LABOUR_SHARE_SP:INTERPOLATE::=
	IF_THEN_ELSE( Switch_Scenarios=1 , Exogenous_Labour_Share_SSP1 , IF_THEN_ELSE( Switch_Scenarios\
		=2, Exogenous_Labour_Share_SSP2 ,  Exogenous_Labour_Share_SSP3) )
	~	Dmnl
	~	This variable projects the future share of Real_Value_Added allocated to employee \
		compensation under different scenarios beyond 2020. It reflects \
		anticipated changes in the distribution of economic output, adjusting to \
		potential shifts in income policies, labor market dynamics, or economic \
		structure. This projected share allows the model to explore how the labor \
		share of GDP might evolve under various future conditions.
		
		
		GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , \
		'SCENARIO_TIME_ECO' , 'EXPECTED_LABOUR_SHARE' )
	|

EXPECTED_NET_EXPORTS_SP=
	IF_THEN_ELSE( Switch_Scenarios=1 , EXPECTED_NET_EXPORTS_SSP1 , IF_THEN_ELSE( Switch_Scenarios\
		=2, EXPECTED_NET_EXPORTS_SSP2 ,  EXPECTED_NET_EXPORTS_SSP3) )
	~	M$
	~		|

EXPECTED_NET_EXPORTS_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'NET_EXPORTS_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_NET_EXPORTS_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'NET_EXPORTS_SSP2'\
		 )
	~	M$
	~		|

EXPECTED_NET_EXPORTS_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'NET_EXPORTS_SSP3'\
		 )
	~	M$
	~		|

Expected_Real_Value_Added=
	IF_THEN_ELSE(Time<2021, (Expected_GDP - EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS) \
		, (Expected_GDP - EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP
	)
	 )
	~	M$
	~	 This variable calculates the anticipated real value added for the entire \
		economy by adjusting Expected_GDP to exclude taxes less subsidies on \
		products. It uses the Taxes_Less_Subsidies_On_Product_Share up to 2021 and \
		the externally defined Expected_Taxes_Less_Subsidies_On_Product_Share_SP \
		afterward, depending on scenario assumptions. This adjustment provides a \
		net measure of economic output, reflecting the true value added across all \
		productive sectors after fiscal modifications.
	|

Total_population=
	IF_THEN_ELSE(SWITCH_POPULATION=0, SUM(Population[GENDER_I!,AGE_COHORTS_I!]) , SSP_POPULATION\
		 )
	~	people
	~	Sum of populations by cohort and age
	|

EXPECTED_SECTOR_SHARE_SP[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	IF_THEN_ELSE( Switch_Scenarios=1 , EXPECTED_SECTOR_SHARE_SSP1[PRODUCTIVE_SECTORS] , \
		IF_THEN_ELSE( Switch_Scenarios=2, EXPECTED_SECTOR_SHARE_SSP2[PRODUCTIVE_SECTORS] ,  \
		EXPECTED_SECTOR_SHARE_SSP3[PRODUCTIVE_SECTORS]) )
	~	Dmnl
	~	This variable provides a projection of each sector’s share—Industry, \
		Transport, Commercial, and Agriculture, Forestry, and Fishing—in the \
		Expected_Real_Value_Added, used in future scenarios beyond 2021. It allows \
		for sector shares to be adapted under different assumptions, aligning the \
		model with potential economic shifts across sectors. This enables a \
		flexible approach to projecting sectoral contributions in a changing \
		economic landscape.
	|

EXPECTED_SECTOR_SHARE_SSP1[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'SECTOR_SHARE_SSP1'\
		 )
	~	Dmnl
	~		|

EXPECTED_SECTOR_SHARE_SSP2[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'SECTOR_SHARE_SSP2'\
		 )
	~	Dmnl
	~		|

EXPECTED_SECTOR_SHARE_SSP3[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'SECTOR_SHARE_SSP3'\
		 )
	~	Dmnl
	~		|

EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP:INTERPOLATE::=
	IF_THEN_ELSE( Switch_Scenarios=1 ,EXPECTED_TAXES_SSP1 , IF_THEN_ELSE( Switch_Scenarios\
		=2, EXPECTED_TAXES_SSP2 ,  EXPECTED_TAXES_SSP3) )
	~	M$
	~	This variable represents the expected total value of taxes less subsidies \
		on products for future scenarios beyond 2020. It is used as a monetary \
		amount rather than a percentage, providing a direct fiscal adjustment to \
		the calculation of Real_GDP. This approach allows for specific \
		scenario-based projections of fiscal policy impacts on GDP.
	|

EXPECTED_TAXES_SSP1:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'TAXES_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_TAXES_SSP2:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'TAXES_SSP2'\
		 )
	~	M$
	~		|

EXPECTED_TAXES_SSP3:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'TAXES_SSP3'\
		 )
	~	M$
	~		|

Exogenous_Labour_Share_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'LABOUR_SHARE_SSP1'\
		 )
	~	Dmnl
	~		|

Exogenous_Labour_Share_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'LABOUR_SHARE_SSP2'\
		 )
	~	Dmnl
	~		|

GOVERNMENT_EXPENDITURE_SP:INTERPOLATE::=
	IF_THEN_ELSE( Switch_Scenarios=1 , EXPECTED_GOVERNMENT_EXPENDITURE_SSP1 , IF_THEN_ELSE\
		( Switch_Scenarios=2, EXPECTED_GOVERNMENT_EXPENDITURE_SSP2 ,  EXPECTED_GOVERNMENT_EXPENDITURE_SSP3\
		) )
	~	M$
	~	This variable projects future government spending based on policy \
		assumptions and historical trends beyond 2020. It allows the model to \
		evaluate how expected changes in fiscal policy and government priorities \
		will impact overall consumption and economic activity.
	|

Exogenous_Labour_Share_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'LABOUR_SHARE_SSP3'\
		 )
	~	Dmnl
	~		|

SSP1_POP:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'population' , 'SCENARIO_TIME_POP' , 'POPULATION_SSP1'\
		 )
	~	people
	~		|

SSP2_POP:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'population' , 'SCENARIO_TIME_POP' , 'POPULATION_SSP2'\
		 )
	~	people
	~		|

SWITCH_POPULATION=
	0
	~	
	~	0 = endogenous; 1 = SSP.
	|

Expected_GDP=
	IF_THEN_ELSE(Time<2020, Final_consumption+INVESTMENT+Net_Exports+EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS\
		 , Final_consumption+INVESTMENT+Net_Exports+EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP\
		)
	~	M$
	~	This variable represents the anticipated total Gross Domestic Product \
		(GDP), calculated by summing Final Consumption, Investment, and Net \
		Exports. It reflects the model’s expected economic output and serves as \
		a proxy for aggregate demand, capturing the total demand for goods and \
		services within the economy. This value provides insight into the \
		economy's projected performance based on domestic consumption, investment \
		levels, and trade balance.
	|

EXPECTED_GOVERNMENT_EXPENDITURE_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'GOV_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_GOVERNMENT_EXPENDITURE_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'GOV_SSP2'\
		 )
	~	M$
	~		|

SSP_POPULATION=
	IF_THEN_ELSE( Switch_Scenarios=1 , SSP1_POP , IF_THEN_ELSE( Switch_Scenarios=2, SSP2_POP\
		 ,  SSP3_POP) )
	~	people
	~		|

EXPECTED_GOVERNMENT_EXPENDITURE_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'GOV_SSP3'\
		 )
	~	M$
	~		|

EXOGENOUS_HH_CONSUMPTION_SP=
	IF_THEN_ELSE( Switch_Scenarios=1 , EXPECTED_HH_CONSUMPTION_SSP1 , IF_THEN_ELSE( Switch_Scenarios\
		=2, EXPECTED_HH_CONSUMPTION_SSP2 ,  EXPECTED_HH_CONSUMPTION_SSP3) )
	~	M$
	~		|

SSP3_POP:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'population' , 'SCENARIO_TIME_POP' , 'POPULATION_SSP3'\
		 )
	~	people
	~		|

EXPECTED_HH_CONSUMPTION_SSP3:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'HH_CONSUMPTION_SSP3'\
		 )
	~	M$
	~		|

EXPECTED_INVESTMENT_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'INVESTMENT_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_INVESTMENT_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'INVESTMENT_SSP2'\
		 )
	~	M$
	~		|

Real_GDP=
	IF_THEN_ELSE(Time<2021, Real_Value_Added+EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS \
		, Real_Value_Added+EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP
	 )
	~	M$
	~	This variable calculates GDP by adding Real_Value_Added to Taxes Less \
		Subsidies. Up to 2020, Taxes Less Subsidies is calculated as a percentage \
		of GDP, while after 2020, it is represented as a monetary value based on \
		scenario projections. This approach ensures that the model reflects the \
		impact of fiscal elements on GDP accurately, adapting to different methods \
		of estimating taxes and subsidies in future scenarios.
	|

UNIT_CONVERSION_MUSD_USD=
	1e+06
	~	
	~		|

EXOGENOUS_LABOUR_SHARE:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'LABOUR_SHARE' )
	~	Dmnl
	~	This variable captures the historical distribution of Real_Value_Added \
		allocated to employees, based on externally sourced data up to 2020. It \
		serves as a baseline for labor's share of GDP before scenario-based \
		adjustments are applied. After 2020, this historical share is replaced by \
		Expected_Labour_Share, which adapts to different future scenarios, \
		providing continuity and reference for past income distribution patterns \
		in the model.
	|

EXPECTED_HH_CONSUMPTION_SSP1:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'HH_CONSUMPTION_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_HH_CONSUMPTION_SSP2:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'HH_CONSUMPTION_SSP2'\
		 )
	~	M$
	~		|

Net_Exports=
	IF_THEN_ELSE(Time<=2021, EXOGENOUS_NET_EXPORTS ,EXPECTED_NET_EXPORTS_SP )
	~	M$
	~		|

EXPECTED_INVESTMENT:INTERPOLATE::=
	IF_THEN_ELSE( Switch_Scenarios=1 , EXPECTED_INVESTMENT_SSP1 , IF_THEN_ELSE( Switch_Scenarios\
		=2, EXPECTED_INVESTMENT_SSP2 ,  EXPECTED_INVESTMENT_SSP3) )
	~	M$
	~	Historical investment values
	|

Switch_Scenarios=
	2
	~	
	~	1 = SSP1 (Stimulus), 2 = SSP2 (BAU), 3 = SSP3 (Crisis)
	|

Food_Scarcity=
	0
	~	
	~		|

Water_Scarcity=
	0
	~	m3/people/Year
	~		|

REAL_VALUE_ADDED_EXCL_HH=
	Expected_Real_Value_Added-HH_Consumption
	~	
	~		|

HH_Consumption=
	IF_THEN_ELSE(Time<=2020, EXOGENOUS_HH_CONSUMPTION_MP , EXOGENOUS_HH_CONSUMPTION_SP )
	~	M$
	~		|

Final_consumption=
	IF_THEN_ELSE(Time<=2020, 
	EXOGENOUS_GOVERNMENT_EXPENDITURE+HH_Consumption , 
	HH_Consumption+GOVERNMENT_EXPENDITURE_SP )
	~	M$
	~	This variable calculates the total consumption in the economy by summing \
		Household_Consumption, Expected_Government_Expenditure, and \
		Expected_NPISH_Consumption. It represents the overall demand for goods and \
		services, making it a crucial component of GDP. This variable reflects the \
		total economic activity driven by consumption across all sectors.
	|

MINIMUM_TIER_CONSIDERED=
	GET_DIRECT_CONSTANTS('scenario_parameters.xlsx', 'energy' , 'MINIMUM_TIER_CONSIDERED'\
		 )
	~	
	~	Average electricity consumption per capita in South Africa: \
		https://www.iea.org/countries/south-africa/electricity
	|

EMISSION_WEIGHT=
	GET_DIRECT_CONSTANTS('scenario_parameters.xlsx',  'energy' , 'EMISSION_WEIGHT' )
	~	
