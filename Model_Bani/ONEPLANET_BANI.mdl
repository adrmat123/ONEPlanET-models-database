	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO' , 'PLANIFICATION_OF_POWER_DESIRE_BY_TECH_USER_DEFINED_SCENARIO'\
		 )
	~	
	~		|

Unit_m3_Mm3=
	1e+06
	~	
	~		|

HH_Consumption_Dolar=
	HH_Consumption*Unit_M$_to_$
	~	$
	~		|

Domestic_Water_demand=
	IF_THEN_ELSE(Time>=2021, (Average_Water_Intensity_Domestic*HH_Consumption)*Unit_m3_Mm3\
		 , domestic_water_use )
	~	
	~		|

Water_Intensity_Agriculture=
