objective_land_protection_policy[WETLAND]=
	0 ~~|
objective_land_protection_policy[URBAN_LAND]=
	0 ~~|
objective_land_protection_policy[WATERBODIES]=
	0
	~	Dmnl
	~		|

OBJECTIVE_MANAGED_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_OBJECTIVE_MANAGED_FOREST_PROTECTION_SP*')
	~	Dmnl
	~	-If this policy is applied, the managed forest is protected and its area does not go \
		down the value given in OBJECTIVE. 
		-The protection starts in INITIAL YEAR and ends in FINAL YEAR.
		-If managed forest area in INITIAL YEAR is lower than OBJECTIVE*forest area in 2015 \
		(TIME HISTORICAL DATA LAND MODULE), the area in INITIAL YEAR is maintained.
		-OBJECTIVE of policy is expressed as a share of the initial area of \
		managed forest in 2015 (from 0 to 1; =1 means that an area equal to the \
		managed forest we had in 2015 is protected, =0 means that there are no \
		limits to deforestation).
	|

OBJECTIVE_NATURAL_LAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_OBJECTIVE_NATURAL_LAND_PROTECTION_SP*')
	~	Dmnl
	~	-If this policy is applied, the natural land is protected and its area does not go \
		down the value given in OBJECTIVE. 
		-The protection starts in INITIAL YEAR and ends in FINAL YEAR.
		-If natural land area in INITIAL YEAR is lower than OBJECTIVE*natural land area in \
		2015 (TIME HISTORICAL DATA LAND MODULE), the area in INITIAL YEAR is \
		maintained.
		-OBJECTIVE of policy is expressed as a share of the initial area of \
		natural land in 2015 (from 0 to 1; =1 means that an area equal to the land \
		natural we had in 2015 is protected, =0 means that there are no limits to \
		natural land loss).
	|

OBJECTIVE_PRIMARY_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_OBJECTIVE_PRIMARY_FOREST_PROTECTION_SP*')
	~	Dmnl
	~	-If this policy is applied, the primary forest is protected and its area does not go \
		down the value given in OBJECTIVE. 
		-The protection starts in INITIAL YEAR and ends in FINAL YEAR.
		-If primary forest area in INITIAL YEAR is lower than OBJECTIVE*forest area in 2015 \
		(TIME HISTORICAL DATA LAND MODULE), the area in INITIAL YEAR is maintained.
		-OBJECTIVE of policy is expressed as a share of the initial area of \
		primary forest in 2015 (from 0 to 1; =1 means that an area equal to the \
		primary forest we had in 2015 is protected, =0 means that there are no \
		limits to deforestation).
	|

OTHER_CATLLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT[MANURE_MANAGEMENT_SYSTEM_I\
		]=
	METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]*OTHER_CATTLE_MANURE_SYSTEM\
		[MANURE_MANAGEMENT_SYSTEM_I]
	~	Dmnl
	~	IPCC 2006 Guidelines (Tier 1) (Eggleston, Buendia, Miwa, Ngara, & Tanabe, 2006) \
		tABLES 10.14 TO 10.16
		Adapted to WILIAM regions. 
		Not used the ones of "goat", sheep and chkens, as this factor is to \
		applied to the rest in which policies about manure system can be applied
	|

OTHER_CATTLE_MANURE_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'Emissions'\
		 , 'OTHER_CATTLE_MANURE_SYSTEM'
	 )
	~	Dmnl
	~	% MS by default. The "less emissions" options are: solid storage, dry lot, \
		range/paddock, daily spread and Pit storage <1month
		From IPCC 2006 Chapter livestock
		 % of the types  manure systems by type of animal , for the calculation of \
		methane emissions due to manure management .
	|

