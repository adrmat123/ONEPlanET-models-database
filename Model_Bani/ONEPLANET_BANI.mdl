	OBJECTIVE_NATURAL_LAND_PROTECTION_SP ~~|
objective_land_protection_policy[GRASSLAND]=
	OBJECTIVE_GRASSLAND_PROTECTION_SP ~~|
objective_land_protection_policy[OTHER_LAND]=
