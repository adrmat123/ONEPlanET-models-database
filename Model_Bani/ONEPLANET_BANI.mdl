	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'WEF_INDICATORS' , 'TIME_WEF_FOOD' , 'SSP2_2'\
		)
	~	
	~		|

SSP2_3:=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'WEF_INDICATORS' , 'TIME_WEF_FOOD' , 'SSP2_3'\
		)
	~	
	~		|

WEF_food_indicator=
	IF_THEN_ELSE( SWITCH_POPULATION=0 :AND: SWITCH_CROPLAND_IRRIGATED_SP=0 :AND:SWITCH_CROPLAND_RAINFED_SP\
		=0 , SSP0_0 , IF_THEN_ELSE(SWITCH_POPULATION=0:AND:SWITCH_CROPLAND_IRRIGATED_SP=1:AND:\
		SWITCH_CROPLAND_RAINFED_SP=0, SSP0_1 , IF_THEN_ELSE(SWITCH_POPULATION=0:AND:SWITCH_CROPLAND_IRRIGATED_SP\
		=0:AND:SWITCH_CROPLAND_RAINFED_SP=1, SSP0_2 , IF_THEN_ELSE( SWITCH_POPULATION=0:AND:\
		SWITCH_CROPLAND_IRRIGATED_SP=1:AND:SWITCH_CROPLAND_RAINFED_SP=1 , SSP0_3 , IF_THEN_ELSE\
		( SWITCH_POPULATION=1:AND:Switch_Scenarios=1:AND:SWITCH_CROPLAND_IRRIGATED_SP=0:AND:\
		SWITCH_CROPLAND_RAINFED_SP=0 , SSP1_0 , IF_THEN_ELSE(SWITCH_POPULATION=1:AND:Switch_Scenarios\
		=1:AND:SWITCH_CROPLAND_IRRIGATED_SP=1:AND:SWITCH_CROPLAND_RAINFED_SP=0, SSP1_1 , IF_THEN_ELSE\
		( SWITCH_POPULATION=1:AND:Switch_Scenarios=1:AND:SWITCH_CROPLAND_IRRIGATED_SP=0:AND:\
		SWITCH_CROPLAND_RAINFED_SP=1 , SSP1_2 , IF_THEN_ELSE(SWITCH_POPULATION=1:AND:Switch_Scenarios\
		=1:AND:SWITCH_CROPLAND_IRRIGATED_SP=1:AND:SWITCH_CROPLAND_RAINFED_SP=1, SSP1_3 , IF_THEN_ELSE\
		(SWITCH_POPULATION=1:AND:Switch_Scenarios=2:AND:SWITCH_CROPLAND_IRRIGATED_SP=0:AND:\
		SWITCH_CROPLAND_RAINFED_SP=0, SSP2_0 , IF_THEN_ELSE(SWITCH_POPULATION=1:AND:Switch_Scenarios\
		=2:AND:SWITCH_CROPLAND_IRRIGATED_SP=1:AND:SWITCH_CROPLAND_RAINFED_SP=0, SSP2_1 , IF_THEN_ELSE\
		(SWITCH_POPULATION=1:AND:Switch_Scenarios=2:AND:SWITCH_CROPLAND_IRRIGATED_SP=0:AND:\
		SWITCH_CROPLAND_RAINFED_SP=1, SSP2_2 , IF_THEN_ELSE(SWITCH_POPULATION=1:AND:Switch_Scenarios\
		=2:AND:SWITCH_CROPLAND_IRRIGATED_SP=1:AND:SWITCH_CROPLAND_RAINFED_SP=1, SSP2_3 , IF_THEN_ELSE\
		(SWITCH_POPULATION=1:AND:Switch_Scenarios=3:AND:SWITCH_CROPLAND_IRRIGATED_SP=0:AND:\
		SWITCH_CROPLAND_RAINFED_SP=0, SSP3_0 , IF_THEN_ELSE(SWITCH_POPULATION=1:AND:Switch_Scenarios\
		=3:AND:SWITCH_CROPLAND_IRRIGATED_SP=1:AND:SWITCH_CROPLAND_RAINFED_SP=0, SSP3_1 , IF_THEN_ELSE\
		(SWITCH_POPULATION=1:AND:Switch_Scenarios=3:AND:SWITCH_CROPLAND_IRRIGATED_SP=0:AND:\
		SWITCH_CROPLAND_RAINFED_SP=1, SSP3_2 , SSP3_3 ) ) ) ) ) ) ) ) ) ) ) ) ) ) )
	~	
	~		|

