	) , vector_of_land_use_changes[GRASSLAND] ) ~~|
land_use_changes_productive_uses[WETLAND]=
	0 ~~|
land_use_changes_productive_uses[URBAN_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[URBAN_LAND](
Time
	) , vector_of_land_use_changes[URBAN_LAND] ) ~~|
land_use_changes_productive_uses[WATERBODIES]=
	0 ~~|
land_use_changes_productive_uses[OTHER_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , 
	HISTORICAL_LAND_USE_CHANGE_BY_REGION[OTHER_LAND](Time)+HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[WATERBODIES
	](Time)+
	HISTORICAL_LAND_USE_CHANGE_BY_REGION[WETLAND](Time)+HISTORICAL_LAND_USE_CHANGE_BY_REGION\
		[
SHRUBLAND
	](Time) , 
	vector_of_land_use_changes[OTHER_LAND]+vector_of_land_use_changes[WATERBODIES] +
	vector_of_land_use_changes[WETLAND])+vector_of_land_use_changes[SHRUBLAND]
	~	ha/Year
	~		|

