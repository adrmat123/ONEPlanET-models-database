		   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PRIMARY_VARIATION_BY_REGION')) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[FOREST_PLANTATIONS](
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PLANTATIONS_VARIATION_BY_REGION')) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[SHRUBLAND](
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_SHRUBLAND_VARIATION_BY_REGION')) ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[GRASSLAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_GRASSLAND_VARIATION_BY_REGION') ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[WETLAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_WETLAND_VARIATION_BY_REGION') ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[URBAN_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_URBAN_LAND_VARIATION_BY_REGION') ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[WATERBODIES]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_WATERBODIES_VARIATION_BY_REGION') ~~|
HISTORICAL_LAND_USE_CHANGE_BY_REGION[OTHER_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_OTHER_LAND_VARIATION_BY_REGION')
	~	ha/Year
	~		|

SHARE_REST_N2O_MANURE_MANAGEMENT_EMISSIONS=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'Emissions'\
		 , 'SHARE_REST_N2O_MANURE_MANAGEMENT_EMISSIONS' )
	~	Dmnl
	~		|

HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,CROPLAND_RAINFED]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'HISTORICAL_SHARE_OF_CROPLAND_RAINFED_FROM_OTHERS_BY_REGION' ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,CROPLAND_IRRIGATED]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'INITIAL_SHARE_OF_CROPLAND_IRRIGATED_FROM_OTHERS_BY_REGION' ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_MANAGED]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'INITIAL_SHARE_OF_AFFORESTATION_FROM_OTHERS_BY_REGION' ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_PRIMARY]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_PLANTATIONS]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'INITIAL_SHARE_OF_FOREST_PLANTATIONS_FROM_OTHERS_BY_REGION' ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,SHRUBLAND]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,GRASSLAND]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'HISTORICAL_SHARE_OF_GRASSLAND_FROM_OTHERS_BY_REGION' ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,WETLAND]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,URBAN_LAND]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'INITIAL_SHARE_OF_URBAN_LAND_FROM_OTHERS_BY_REGION') ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,WATERBODIES]=
	0 ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,OTHER_LAND]=
	0
	~	Dmnl
	~		|

HISTORICAL_TRENDS_OF_LAND_USE_DEMAND[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'HISTORICAL_TRENDS_OF_LAND_USE_CHANGE_BY_REGION' )
	~	ha/Year
	~		|

MATURATION_TIME_OF_PLANTATIONS_MP=
	20
	~	Year
	~		|

yields_of_rainfed_industrial_crops[LAND_PRODUCTS_I]= INTEG (
	increase_of_yields_industrial_R_and_I[LAND_PRODUCTS_I],
		INITIAL_YIELDS_OF_INDUSTRIAL_RAINFED_CROPS[LAND_PRODUCTS_I])
	~	t/ha
	~		|

FACTOR_EMISSION_N_APPLICATION_INDIRECT=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx','Emissions'\
		, 'EF_N2O_direct_fertilizers')
	~	kg/kg
	~	IPCC 2006 (Tier 1, Chapter 11, Table 11.1) default values for direct emissions  N2O \
		emitted from the various synthetic and organic N applications to soils, \
		including crop residue and mineralisation of soil organic carbon in \
		mineral soils due to land-use change or management
		"Conversion of N2O-N emissions to N2O emissions for reporting purposes is performed \
		by using the following 
		equation: N2O = N2O-N * 44/28 
		1 kg N2O-N = 1 kg de N= (44/28)*1 kg N2O (factor from kg of N to kg of \
		N2O) (N2O= 44 g/mol and N=28 g/mol, and 1N2Omol=1N mol)
	|

FACTOR_EMISSIONS_BASELINE_RICE=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx','Emissions'\
		, 'FACTOR_EMISSIONS_BASELINE_RICE')
	~	kgCH4/(ha*Year)
	~	1,3 kgCH4/(ha*day)--> cultivation period! (120 days?)
		"FACTOR_EMISSIONS_BASELINE_RICE"  Baseline emission factor: the IPCC \
		default for EFc is 1.30 kg CH4 ha-1 day-1 (with error range of 0.80 - \
		2.20, Table 5.11), estimated by a statistical analysis of available field \
		measurement data (Yan et al., 2005,
	|

increase_of_area_for_plantations=
	growth_of_plantation_area
	~	ha/Year
	~		|

increase_of_area_of_forests=
	IF_THEN_ELSE (land_use_changes_productive_uses[FOREST_MANAGED]>0, land_use_changes_productive_uses\
		[FOREST_MANAGED], 0)
	~	ha/Year
	~		|

increase_of_efective_area_of_forests=
	IF_THEN_ELSE(increase_of_area_of_forests>0, area_of_forests*(1/MATURATION_TIME_OF_FOREST_MANAGED_MP\
		), 0)
	~	ha/Year
	~		|

increase_of_effective_area_for_plantations=
	IF_THEN_ELSE(increase_of_area_for_plantations>0, area_for_plantations*(1/MATURATION_TIME_OF_PLANTATIONS_MP
	), 0)
	~	ha/Year
	~		|

increase_of_yields_industrial_R_and_I[LAND_PRODUCTS_I]=
	IF_THEN_ELSE( 
	yields_of_rainfed_industrial_crops[LAND_PRODUCTS_I]<MAXIMUM_YIELDS_RAINFED_INDUSTRIAL_CROPS\
		[LAND_PRODUCTS_I
	],
	
	aux_trends_of_yield_change_R_and_I[LAND_PRODUCTS_I],
	0)
	~	t/(ha*Year)
	~		|

land_protection_by_policy[LANDS_I]=
	IF_THEN_ELSE( switch_land_production_policy[LANDS_I]=1:AND:Time>year_initial_land_protection_policy\
		[LANDS_I] :AND:Time<year_final_land_protection_policy[LANDS_I], 
	
	objective_land_protection_policy[LANDS_I]  , 0 )
	~	Dmnl
	~	share of the initial land of each type in 2015 that is protected from \
		changes to other uses
	|

effective_area_of_forests= INTEG (
	increase_of_efective_area_of_forests-deforested_area,
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED])
	~	ha
	~		|

increment_of_cropland_rainfed_demanded=
	IF_THEN_ELSE( SWITCH_CROPLAND_RAINFED_SP=1:AND:Time>YEAR_INITIAL_CROPLAND_RAINFED_SP\
		 :AND:Time
	<YEAR_FINAL_CROPLAND_RAINFED_SP
	,
	 (OBJECTIVE_CROPLAND_RAINFED_SP*INITIAL_LAND_USE_BY_REGION[CROPLAND_RAINFED] )/
	
	(YEAR_FINAL_CROPLAND_RAINFED_SP-YEAR_INITIAL_CROPLAND_RAINFED_SP) , 0
	 )
	~	ha/Year
	~		|

increment_of_urban_land_demanded=
	Population_change_rate *URBAN_LAND_PER_PERSON
	~	km2/Year
	~		|

UNIT_CONVERSION_t_kg=
	MATRIX_UNIT_PREFIXES[kilo,mega]*t_per_kg_units
	~	t/kg
	~		|

minimum_limit_land_use_by_policy[LANDS_I]=
	land_protection_by_policy[LANDS_I]*INITIAL_LAND_USE_BY_REGION_2015[LANDS_I]
	~	ha
	~	Minimum limit of land use by policy for each region
	|

UNIT_CONVERSION_t_Mt=
	MATRIX_UNIT_PREFIXES[mega,BASE_UNIT]*t_per_Mt_units
	~	t/Mt
	~		|

model_explorer_manure_management_system[ANIMALS_TYPES_I,MANURE_MANAGEMENT_SYSTEM_I]=
	0
	~	Dmnl
	~		|

wood_production_of_plantations=
	effective_area_for_plantations* WOOD_YIELD_OF_PLANTATIONS
	~	t/Year
	~		|

YEAR_FINAL_AFFORESTATION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_FINAL_AFFORESTATION_SP*' )
	~	Year
	~	Scenario parameter final year
	|

rainfed_crops_available_by_region[LAND_PRODUCTS_I]=
	area_of_rainfed_crops[LAND_PRODUCTS_I]*yields_of_rainfed_crops[LAND_PRODUCTS_I]
	~	t/Year
	~		|

EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'Emissions'\
		 , 'EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT' )
	~	kgCH4/(Year*number_animals)
	~		|

EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[DAIRY_CATTLE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT\
		[DAIRY_CATTLE]* SUM
	 (model_explorer_manure_management_system
	[DAIRY_CATTLE,MANURE_MANAGEMENT_SYSTEM_I!]) , 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[DAIRY_CATTLE]* SUM (DAIRY_CATLLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) ) ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[OTHER_CATTLE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[OTHER_CATTLE]* SUM (model_explorer_manure_management_system
	[OTHER_CATTLE,MANURE_MANAGEMENT_SYSTEM_I!]) ,
	 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[OTHER_CATTLE]* SUM (OTHER_CATLLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) ) ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[SHEEP]=
	EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[SHEEP] ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[CHICKENS]=
	EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[CHICKENS] ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[SWINE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT\
		[SWINE]*SUM(model_explorer_manure_management_system
	[SWINE,MANURE_MANAGEMENT_SYSTEM_I!]) , 
	
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[SWINE]*SUM(SWINE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) )
	~	kgCH4/(number_animals*Year)
	~		|

EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'Emissions'\
		 , 'EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT' )
	~	kgCH4/(Year*number_animals)
	~		|

INITIAL_LAND_USE_BY_REGION_2015[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'INITIAL_LAND_BY_REGION_2015*' )
	~	ha
	~		|

INITIAL_MEAT_OBTAINED_FROM_GRASSLANDS=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'Diet'\
		 , 'MEAT_GRASSLANDS*' )
	~	t/Year
	~		|

food_demanded_by_households_per_region[FOODS_I]=
	diet[FOODS_I]*Total_population_1*UNIT_CONVERSION_t_kg
	~	t/Year
	~		|

variation_of_waterbodies_area[WATERBODIES]=
	0
	~	ha/Year
	~		|

SWITCH_MODEL_EXPLORER=
	0
	~	Dmnl
	~		|

INITIAL_YIELDS_OF_INDUSTRIAL_RAINFED_CROPS[LAND_PRODUCTS_I]=
	200000
	~	t/ha
	~		|

INITIAL_YIELDS_OF_IRRIGATED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I]=
	0.8
	~	t/ha
	~		|

vector_of_land_use_changes[CROPLAND_RAINFED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,CROPLAND_RAINFED])-
	SUM(matrix_of_land_use_changes[CROPLAND_RAINFED,LANDS_I!])- CROPLAND_LOST_DUE_TO_FLOODS\
		[CROPLAND_RAINFED] ~~|
vector_of_land_use_changes[CROPLAND_IRRIGATED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,CROPLAND_IRRIGATED])-
	SUM(matrix_of_land_use_changes[CROPLAND_IRRIGATED,LANDS_I!])-CROPLAND_LOST_DUE_TO_FLOODS\
		[CROPLAND_IRRIGATED] ~~|
vector_of_land_use_changes[FOREST_MANAGED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_MANAGED])-
	SUM(matrix_of_land_use_changes[FOREST_MANAGED,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_PRIMARY]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_PRIMARY])-
	SUM(matrix_of_land_use_changes[FOREST_PRIMARY,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_PLANTATIONS]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_PLANTATIONS])-
	SUM(matrix_of_land_use_changes[FOREST_PLANTATIONS,LANDS_I!]) ~~|
vector_of_land_use_changes[SHRUBLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,SHRUBLAND])-
	SUM(matrix_of_land_use_changes[SHRUBLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[GRASSLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,GRASSLAND])-
	SUM(matrix_of_land_use_changes[GRASSLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[WETLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,WETLAND])-
	SUM(matrix_of_land_use_changes[WETLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[URBAN_LAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,URBAN_LAND])-
	SUM(matrix_of_land_use_changes[URBAN_LAND,LANDS_I!]) ~~|
vector_of_land_use_changes[WATERBODIES]=
	SUM(matrix_of_land_use_changes[LANDS_I!,WATERBODIES])-
	SUM(matrix_of_land_use_changes[WATERBODIES,LANDS_I!]) ~~|
vector_of_land_use_changes[OTHER_LAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,OTHER_LAND])-
	SUM(matrix_of_land_use_changes[OTHER_LAND,LANDS_I!])
	~	ha/Year
	~		|

irrigated_crops_available_by_region[LAND_PRODUCTS_I]=
	area_of_irrigated_crops[LAND_PRODUCTS_I]*yields_of_irrigated_crops[LAND_PRODUCTS_I]*\
		CROPPING_CYCLES_PER_YEAR
	~	t/Year
	~		|

YEAR_INITIAL_FOREST_PLANTATIONS_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'YEAR_INITIAL_FOREST_PLANTATIONS*' )
	~	Year
	~	Scenario parameter intial year
	|

land_use_changes_demanded[LANDS_I]=
	IF_THEN_ELSE( Time<TIME_HISTORICAL_DATA_LAND_MODULE,
	trends_of_land_use_changes[LANDS_I],
	
	SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS*(land_use_changes_demanded_before_exogenous[LANDS_I\
		])+
	
	(1-SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS)*CHECK_EXOGENOUS_LAND_USE_DEMANDS[LANDS_I] \
		)
	~	ha/Year
	~		|

YEAR_INITIAL_GRASSLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_INITIAL_GRASSLAND_PROTECTION_SP*' )
	~	Year
	~	Scenario parameter intial year
	|

SWITCH_LAW_LIMITS_LAND_BY_SOURCE=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx', 'exogeneous_inputs'\
		 , 'SWITH_LAW_LIMITS_LAND_BY_SOURCE' )
	~	Dmnl
	~		|

SHARE_REST_CH4_ENTERIC_FERMENTATION_EMISSIONS=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'Emissions'\
		 , 'SHARE_REST_CH4_ENTERIC_FERMENTATION_EMISSIONS' )
	~	Dmnl
	~		|

SHARE_REST_CH4_MANURE_MANAGEMENT_EMISSIONS=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'Emissions'\
		 , 'SHARE_REST_CH4_MANURE_MANAGEMENT_EMISSIONS' )
	~	Dmnl
	~		|

UNIT_CONVERSION_ha_km2=
	100
	~	ha/km2
	~		|

SHARE_UPLAND_RICE_BY_REGION=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'Emissions'\
		 , 'SHARE_UPLAND_RICE_BY_REGION*' )
	~	Dmnl
	~	Share of upland wheat with respect to the total "rainfed" area
	|

LAND_AREA_ADJUST_COEFFICIENT=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'croplands'\
		 , 'LAND_AREA_ADJUST_COEFFICIENT*' )
	~	Dmnl
	~		|

EXOGENOUS_NUMBER_OF_ANIMALS[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'Emissions'\
		 , 'ANIMALS_DISTRIBUTION_REGIONS' )
	~	number_animals
	~	total number of animals by type and by case study
	|

yields_of_irrigated_industrial_crops[LAND_PRODUCTS_I]= INTEG (
	increase_of_yields_rainfed_industrial[LAND_PRODUCTS_I],
		INITIAL_YIELDS_OF_IRRIGATED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I])
	~	t/ha
	~		|

yields_of_rainfed_crops[LAND_PRODUCTS_I]=
	yields_of_rainfed_industrial_crops[LAND_PRODUCTS_I]
	~	t/ha
	~		|

SCALING_FACTOR_WATER_REGIME_RICE_RAINFED=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx','Emissions'\
		, 'SCALING_FACTOR_WATER_REGIME_RICE_RAINFED')
	~	Dmnl
	~	water regime during the cultivation period default scaling factors and \
		error ranges reflecting different water regimes. (tABLE 5.12, ipcc 2006 \
		Tier 1). ( DURING THE CULTIVATION PERIOD RELATIVE TO CONTINUOUSLY FLOODED \
		FIELDS )
	|

land_products_available_from_croplands[CORN]=
	irrigated_crops_available_by_region[CORN]+rainfed_crops_available_by_region[CORN] ~~|
land_products_available_from_croplands[RICE]=
	irrigated_crops_available_by_region[RICE]+rainfed_crops_available_by_region[RICE] ~~|
land_products_available_from_croplands[SORGHUM]=
	irrigated_crops_available_by_region[SORGHUM]+rainfed_crops_available_by_region[SORGHUM\
		] ~~|
land_products_available_from_croplands[CASSAVA]=
	irrigated_crops_available_by_region[CASSAVA]+rainfed_crops_available_by_region[CASSAVA\
		] ~~|
land_products_available_from_croplands[COTTON]=
	irrigated_crops_available_by_region[COTTON]+rainfed_crops_available_by_region[COTTON\
		] ~~|
land_products_available_from_croplands[COWPEAS]=
	irrigated_crops_available_by_region[COWPEAS]+rainfed_crops_available_by_region[COWPEAS
	] ~~|
land_products_available_from_croplands[MILLET]=
	irrigated_crops_available_by_region[MILLET]+rainfed_crops_available_by_region[MILLET
	] ~~|
land_products_available_from_croplands[COFFEE]=
	irrigated_crops_available_by_region[COFFEE]+rainfed_crops_available_by_region[
	COFFEE] ~~|
land_products_available_from_croplands[YAM]=
	irrigated_crops_available_by_region[YAM]+rainfed_crops_available_by_region[YAM] ~~|
land_products_available_from_croplands[GROUNDNUT]=
	irrigated_crops_available_by_region[GROUNDNUT]+rainfed_crops_available_by_region[GROUNDNUT
	] ~~|
land_products_available_from_croplands[SUGAR_CROPS]=
	irrigated_crops_available_by_region[SUGAR_CROPS]+rainfed_crops_available_by_region[SUGAR_CROPS
	]
	~	t/Year
	~		|

land_products_demanded_for_food[LAND_PRODUCTS_I]=
	land_products_demanded_for_food_before_losses[LAND_PRODUCTS_I]*LOSS_FACTOR_OF_LAND_PRODUCTS\
		[LAND_PRODUCTS_I]
	~	t/Year
	~		|

land_products_demanded_for_food_before_losses[LAND_PRODUCTS_I]=
	AGROFOOD_TRANSFORM_MATRIX[CEREALS_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[CEREALS_DIET
	] + 
	AGROFOOD_TRANSFORM_MATRIX[TUBERS_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[TUBERS_DIET
	] + 
	AGROFOOD_TRANSFORM_MATRIX[PULSES_LEGUMES_NUTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[
	PULSES_LEGUMES_NUTS] + 
	AGROFOOD_TRANSFORM_MATRIX[FRUITS_VEGETABLES_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FRUITS_VEGETABLES_DIET] + 
	AGROFOOD_TRANSFORM_MATRIX[FATS_VEGETAL,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FATS_VEGETAL
	] + 
	AGROFOOD_TRANSFORM_MATRIX[FATS_ANIMAL,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FATS_ANIMAL
	] + 
	AGROFOOD_TRANSFORM_MATRIX[DAIRY,LAND_PRODUCTS_I]*food_demanded_from_land_products[DAIRY\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[EGGS,LAND_PRODUCTS_I]*food_demanded_from_land_products[EGGS\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[MEAT_RUMINANTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[MEAT_RUMINANTS
	] + 
	AGROFOOD_TRANSFORM_MATRIX[MEAT_MONOGASTRIC,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[MEAT_MONOGASTRIC
	] + 
	AGROFOOD_TRANSFORM_MATRIX[FISH,LAND_PRODUCTS_I]*food_demanded_from_land_products[FISH\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[SUGARS,LAND_PRODUCTS_I]*food_demanded_from_land_products[SUGARS\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[BEVERAGES,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[BEVERAGES]
	 + 
	AGROFOOD_TRANSFORM_MATRIX[STIMULANTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[STIMULANTS
	]
	~	t/Year
	~		|

waterbodies_area= INTEG (
	variation_of_waterbodies_area[WATERBODIES],
		INITIAL_LAND_USE_BY_REGION[WATERBODIES])
	~	ha
	~		|

UNIT_CONVERSION_Mt_t=
	1/UNIT_CONVERSION_t_Mt
	~	Mt/t
	~		|

YEAR_INITIAL_CROPLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_INITIAL_CROPLAND_PROTECTION_SP*' )
	~	Year
	~	Scenario parameter intial year
	|

land_use_area_by_region[CROPLAND_RAINFED]=
	land_use_area_productive_uses[CROPLAND_RAINFED] ~~|
land_use_area_by_region[CROPLAND_IRRIGATED]=
	land_use_area_productive_uses[CROPLAND_IRRIGATED] ~~|
land_use_area_by_region[FOREST_MANAGED]=
	land_use_area_productive_uses[FOREST_MANAGED] ~~|
land_use_area_by_region[FOREST_PRIMARY]=
	land_use_area_productive_uses[FOREST_PRIMARY] ~~|
land_use_area_by_region[FOREST_PLANTATIONS]=
	land_use_area_productive_uses[FOREST_PLANTATIONS] ~~|
land_use_area_by_region[SHRUBLAND]=
	land_use_area_productive_uses[SHRUBLAND]*SHARE_OF_SHRUBLAND ~~|
land_use_area_by_region[GRASSLAND]=
	land_use_area_productive_uses[GRASSLAND] ~~|
land_use_area_by_region[WETLAND]=
	wetland_area ~~|
land_use_area_by_region[URBAN_LAND]=
	land_use_area_productive_uses[URBAN_LAND] ~~|
land_use_area_by_region[WATERBODIES]=
	waterbodies_area ~~|
land_use_area_by_region[OTHER_LAND]=
	(land_use_area_productive_uses[OTHER_LAND]-wetland_area-waterbodies_area)*(1-SHARE_OF_SHRUBLAND\
		)
	~	ha
	~	land use area by region
	|

land_use_area_productive_uses[CROPLAND_RAINFED]= INTEG (
	land_use_changes_productive_uses[CROPLAND_RAINFED],
		INITIAL_LAND_USE_BY_REGION[CROPLAND_RAINFED]) ~~|
land_use_area_productive_uses[CROPLAND_IRRIGATED]= INTEG (
	land_use_changes_productive_uses[CROPLAND_IRRIGATED],
		INITIAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED]) ~~|
land_use_area_productive_uses[FOREST_MANAGED]= INTEG (
	land_use_changes_productive_uses[FOREST_MANAGED],
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED]) ~~|
land_use_area_productive_uses[FOREST_PRIMARY]= INTEG (
	land_use_changes_productive_uses[FOREST_PRIMARY],
		INITIAL_LAND_USE_BY_REGION[FOREST_PRIMARY]) ~~|
land_use_area_productive_uses[FOREST_PLANTATIONS]= INTEG (
	land_use_changes_productive_uses[FOREST_PLANTATIONS],
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS]) ~~|
land_use_area_productive_uses[SHRUBLAND]= INTEG (
	land_use_changes_productive_uses[SHRUBLAND],
		0) ~~|
land_use_area_productive_uses[GRASSLAND]= INTEG (
	land_use_changes_productive_uses[GRASSLAND],
		INITIAL_LAND_USE_BY_REGION[GRASSLAND]) ~~|
land_use_area_productive_uses[WETLAND]= INTEG (
	land_use_changes_productive_uses[WETLAND],
		0) ~~|
land_use_area_productive_uses[URBAN_LAND]= INTEG (
	land_use_changes_productive_uses[URBAN_LAND],
		INITIAL_LAND_USE_BY_REGION[URBAN_LAND]) ~~|
land_use_area_productive_uses[WATERBODIES]= INTEG (
	land_use_changes_productive_uses[ WATERBODIES],
		0) ~~|
land_use_area_productive_uses[OTHER_LAND]= INTEG (
	land_use_changes_productive_uses[OTHER_LAND]+land_use_changes_productive_uses[WATERBODIES
	]+land_use_changes_productive_uses[WETLAND]+land_use_changes_productive_uses[SHRUBLAND\
		],
		 INITIAL_LAND_USE_BY_REGION[OTHER_LAND]+INITIAL_LAND_USE_BY_REGION
		[WATERBODIES]+INITIAL_LAND_USE_BY_REGION[WETLAND]+INITIAL_LAND_USE_BY_REGION[SHRUBLAND\
		])
	~	ha
	~	stock of land uses area productive uses by region
	|

Population_change_rate=
	( Total_population_1 - DELAY1I( Total_population_1, TIME_STEP, Total_population_1 ) \
		)
	    / TIME_STEP
	~	person/Year
	~		|

land_use_changes_demanded_before_exogenous[CROPLAND_RAINFED]=
	trends_of_land_use_changes[CROPLAND_RAINFED]+land_use_changes_driven_by_demands[CROPLAND_RAINFED
	] ~~|
land_use_changes_demanded_before_exogenous[CROPLAND_IRRIGATED]=
	trends_of_land_use_changes[CROPLAND_IRRIGATED] ~~|
land_use_changes_demanded_before_exogenous[FOREST_MANAGED]=
	trends_of_land_use_changes[FOREST_MANAGED]+land_use_changes_driven_by_demands[FOREST_MANAGED\
		] ~~|
land_use_changes_demanded_before_exogenous[FOREST_PRIMARY]=
	trends_of_land_use_changes[FOREST_PRIMARY]+land_use_changes_driven_by_demands[FOREST_PRIMARY\
		] ~~|
land_use_changes_demanded_before_exogenous[FOREST_PLANTATIONS]=
	trends_of_land_use_changes[FOREST_PLANTATIONS]+land_use_changes_driven_by_demands[FOREST_PLANTATIONS
	] ~~|
land_use_changes_demanded_before_exogenous[SHRUBLAND]=
	0 ~~|
land_use_changes_demanded_before_exogenous[GRASSLAND]=
	trends_of_land_use_changes[GRASSLAND] ~~|
land_use_changes_demanded_before_exogenous[WETLAND]=
	0 ~~|
land_use_changes_demanded_before_exogenous[URBAN_LAND]=
	land_use_changes_driven_by_demands[URBAN_LAND] ~~|
land_use_changes_demanded_before_exogenous[WATERBODIES]=
	0 ~~|
land_use_changes_demanded_before_exogenous[OTHER_LAND]=
	0
	~	ha/Year
	~		|

wetland_area= INTEG (
	variation_of_wetland_area,
		INITIAL_LAND_USE_BY_REGION[WETLAND])
	~	ha
	~		|

SWINE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT[MANURE_MANAGEMENT_SYSTEM_I]=
	METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]*SWINE_MANURE_SYSTEM[\
		MANURE_MANAGEMENT_SYSTEM_I
	]
	~	Dmnl
	~		|

matrix_of_acumulated_land_use_changes[LANDS_I,LANDS_MAP_I]=
	matrix_of_land_use_changes[LANDS_I,LANDS_MAP_I]
	~	ha/Year
	~		|

