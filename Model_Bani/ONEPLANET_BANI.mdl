		   , 'TIME_LAND_USE', 'HISTORICAL_CROPLAND_RAINFED_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_CROPLAND_IRRIGATED_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[FOREST_MANAGED]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_MANAGED_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[FOREST_PRIMARY]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PRIMARY_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PLANTATIONS_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[SHRUBLAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_SHRUBLAND_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[GRASSLAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_GRASSLAND_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[WETLAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_WETLAND_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[URBAN_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_URBAN_LAND_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[WATERBODIES]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_WATERBODIES_BY_REGION') ~~|
HISTORICAL_LAND_USE_BY_REGION[OTHER_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		   , 'TIME_LAND_USE', 'HISTORICAL_OTHER_LAND_BY_REGION')
	~	ha
	~		|

YEAR_FINAL_CROPLAND_IRRIGATED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_FINAL_CROPLAND_IRRIGATED_SP*' )
	~	Year
	~		|

YEAR_FINAL_CROPLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_FINAL_CROPLAND_PROTECTION_SP*')
	~	Year
	~	Scenario parameter final year
	|

total_forest_area_world=
	land_use_area_by_region[FOREST_MANAGED]+land_use_area_by_region[FOREST_PRIMARY]
	~	ha
	~		|

SCALING_FACTOR_WATER_REGIME_PRESEASON=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx','Emissions'\
		, 'SCALING_FACTOR_WATER_REGIME_PRESEASON')
	~	Dmnl
	~	scaling factor to account for the differences in water regime in the pre-season \
		before the cultivation 
		period (from Table 5.13)    ipcc 2006 Tier 1). --> No more information: The \
		aggregated case (1.22  refers to a situation when activity data are only 
		available for rice ecosystem types, but not for flooding patterns
	|

SCALING_FACTOR_WATER_REGIME_RICE_IRRIGATED=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx','Emissions'\
		, 'SCALING_FACTOR_WATER_REGIME_RICE_IRRIGATED')
	~	Dmnl
	~	water regime during the cultivation period default scaling factors and \
		error ranges reflecting different water regimes. (tABLE 5.12, ipcc 2006 \
		Tier 1). ( DURING THE CULTIVATION PERIOD RELATIVE TO CONTINUOUSLY FLOODED \
		FIELDS )
	|

food_balance[LAND_PRODUCTS_I]= INTEG (
	food_supply[LAND_PRODUCTS_I]-food_demand[LAND_PRODUCTS_I],
		0)
	~	t
	~		|

year_final_land_protection_policy[CROPLAND_RAINFED]=
	YEAR_FINAL_CROPLAND_PROTECTION_SP ~~|
year_final_land_protection_policy[CROPLAND_IRRIGATED]=
	YEAR_FINAL_CROPLAND_PROTECTION_SP ~~|
year_final_land_protection_policy[FOREST_MANAGED]=
	YEAR_FINAL_MANAGED_FOREST_PROTECTION_SP ~~|
year_final_land_protection_policy[FOREST_PRIMARY]=
	YEAR_FINAL_PRIMARY_FOREST_PROTECTION_SP ~~|
year_final_land_protection_policy[FOREST_PLANTATIONS]=
	0 ~~|
year_final_land_protection_policy[SHRUBLAND]=
	YEAR_FINAL_NATURAL_LAND_PROTECTION_SP ~~|
year_final_land_protection_policy[GRASSLAND]=
	YEAR_FINAL_GRASSLAND_PROTECTION_SP ~~|
year_final_land_protection_policy[OTHER_LAND]=
	YEAR_FINAL_NATURAL_LAND_PROTECTION_SP ~~|
year_final_land_protection_policy[WETLAND]=
	0 ~~|
year_final_land_protection_policy[URBAN_LAND]=
	0 ~~|
year_final_land_protection_policy[WATERBODIES]=
	0
	~	Year
	~	final year of land protection policies
	|

LOSS_FACTOR_OF_LAND_PRODUCTS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters/land_and_water/land_and_water.xlsx' , 'intermodule_global_allocate'\
		 , 'LOSS_FACTOR_LAND_PRODUCTS*')
	~	Dmnl
	~		|

YEAR_FINAL_PRIMARY_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_FINAL_NATURAL_LAND_PROTECTION_SP*')
	~	Year
	~	Scenario parameter final year
	|

YEAR_INITIAL_AFFORESTATION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_INITIAL_AFFORESTATION_SP*' )
	~	Year
	~	Scenario parameter intial year
	|

YEAR_INITIAL_CROPLAND_IRRIGATED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_INITIAL_CROPLAND_IRRIGATED_SP*' )
	~	Year
	~		|

variation_of_wetland_area=
	0
	~	ha/Year
	~		|

YEAR_INITIAL_CROPLAND_RAINFED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_INITIAL_CROPLAND_RAINFED_SP*' )
	~	Year
	~		|

forest_plantations_growth_due_to_policies=
	IF_THEN_ELSE( SWITCH_FOREST_PLANTATIONS_SP=1:AND:Time>YEAR_INITIAL_FOREST_PLANTATIONS_SP\
		 :AND:Time<YEAR_FINAL_FOREST_PLANTATIONS_SP
	,
	 (OBJECTIVE_FOREST_PLANTATIONS_SP*INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS] )/
	
	(YEAR_FINAL_FOREST_PLANTATIONS_SP-YEAR_INITIAL_FOREST_PLANTATIONS_SP) , 0
	 )
	~	ha/Year
	~	Growth of forest plantations driven by policies, it is added to the trends.
	|

UNIT_CONVERSION_MtCH4_kgCH4=
	1e-09
	~	MtCH4/kgCH4
	~		|

MINIMUM_LAND_USES_BY_REGION[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'MINIMUM_LAND_USES_BY_REGION' )
	~	ha
	~		|

SHARE_OF_SHRUBLAND=
	GET_DIRECT_CONSTANTS('model_parameters/land_and_water/land_and_water.xlsx', 'land_uses'\
		 , 'SHARE_OF_SHRUBLAND*' )
	~	Dmnl
	~		|

matrix_of_accumulated_land_use_changes[LANDS_I,LANDS_MAP_I]= INTEG (
	matrix_of_acumulated_land_use_changes[LANDS_I,LANDS_MAP_I],
		0)
	~	ha
	~		|

factor_of_minimum_land_limit[LANDS_I]=
	IF_THEN_ELSE( land_use_area_by_region[LANDS_I]<=MINIMUM_LAND_USES_BY_REGION[LANDS_I]\
		 :OR:
	 land_use_area_by_region
	[LANDS_I]<=minimum_limit_land_use_by_policy[LANDS_I]
	
	
	, 0 , 1 )
	~	Dmnl
	~		|

SWITCH_MANAGED_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_SWITCH_MANAGED_FOREST_PROTECTION_SP*' )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

matrix_of_land_use_changes[LANDS_I,LANDS_MAP_I]=
	factor_of_minimum_land_limit[LANDS_I]*factor_of_maximum_land_limit[LANDS_I,LANDS_MAP_I\
		]* (matrix_of_land_use_change_demands[LANDS_I,LANDS_MAP_I])
	~	ha/Year
	~	matrix of land use changes
	|

MATURATION_TIME_OF_FOREST_MANAGED_MP=
	20
	~	Year
	~		|

yields_of_irrigated_crops[LAND_PRODUCTS_I]=
	yields_of_irrigated_industrial_crops[LAND_PRODUCTS_I]
	~	t/ha
	~		|

YEAR_INITIAL_PRIMARY_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_YEAR_INITIAL_PRIMARY_FOREST_PROTECTION_SP*' )
	~	Year
	~	Scenario parameter intial year
	|

SWITCH_GRASSLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'POLICY_SWITCH_GRASSLAND_PROTECTION_SP*' )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

YEAR_FINAL_FOREST_PLANTATIONS_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters/scenario_parameters.xlsx' , 'land_and_water'\
		 , 'YEAR_FINAL_FOREST_PLANTATIONS*' )
	~	Year
