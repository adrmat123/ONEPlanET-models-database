RES_power_desire[GAS_PP]=
	0 ~~|
RES_power_desire[WIND]=
	POLICY_NEW_POWER_DESIRE_BY_TECHNOLOGY[WIND] ~~|
RES_power_desire[HYDRO]=
	POLICY_NEW_POWER_DESIRE_BY_TECHNOLOGY[HYDRO]
	~	MW/Year
	~	This variable expresses the desire to expand electricity generation \
		capacity and influences the planning of new plants.
	|

