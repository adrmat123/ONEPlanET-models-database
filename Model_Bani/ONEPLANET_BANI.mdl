	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'energy' , 'SELECT_ELECTRICITY_DISTRIBUTION_LOSSES'\
		 )
	~	
	~		|

total_demand_of_ELEC[ELEC]=
	ZIDZ( SUM(demand_of_ELEC_by_sector[SECTORS!,ELEC]) , POLICY_ELECTRICITY_DISTRIBUTION_LOSSES\
		)
	~	MWh/Year
	~	Total aggregate annual electricity demand.
	|

ratio_electricity_autonomy=
	ZIDZ( SUM(total_electricity_mix[ELEC_SUPPLIERS!])-total_electricity_mix[IMPORTS] , SUM\
		(total_electricity_mix[ELEC_SUPPLIERS!]) )
	~	
	~	Ratio between the electricity generated with local resources and the total \
		electricity_generation
	|

Energy_index=
	SMOOTH(MAX(Relative_level_of_consumption *LEVEL_OF_ELEC_CONSUMPTION_WEIGHT + co2_emissions_indicator
	*EMISSION_WEIGHT
	 + ratio_electricity_autonomy*RATIO_OF_IMPORTS_WEIGHT
	 ,0), 1 )
	~	
	~	+ 0.1787*12
		An energy security index has been calculated using the variables that \
		could be modeled, aiming to represent four out of the five dimensions \
		analyzed in "Alternatives for Improving Energy Security in Cape Verde" by \
		Leuzinger Coutinho et. al 2020 \
		(https://doi.org/10.1016/j.jup.2020.101112). The four dimensions included \
		are: Availability, Affordability, Technology Development and Efficiency, \
		and Environmental and Social Sustainability. Each dimension is represented \
		by a single variable, which has been normalized on a scale from 0 to 1. To \
		aggregate the index, weights have been assigned to each dimension, \
		following the proportions used in the referenced article, although users \
		can adjust these weights if desired. For the sustainability dimension, \
		represented by emissions, the reciprocal of emissions has been used so \
		that higher emissions negatively impact the energy security score.
	|

LOW_DISTRIBUTION_ELECTRICITY_LOSSES:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS', 'LOW_DISTRIBUTION_ELECTRICITY_LOSSES'\
		 )
	~	Dmnl
	~	The annual electricity loss percentage in transmission and distribution \
		networks represents the share of electricity that is lost as it travels \
		from power plants to end users. These losses occur due to resistance in \
		power lines, transformer inefficiencies, and other technical factors. They \
		are typically expressed as a percentage of the total electricity injected \
		into the grid.
	|

