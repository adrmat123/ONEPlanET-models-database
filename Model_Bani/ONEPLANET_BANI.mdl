{UTF-8}
POLICY_ELECTRICITY_DISTRIBUTION_LOSSES=
	IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES=0, CURRENT_TRENDS_ELECTRICITY_LOSSES\
		, IF_THEN_ELSE (SELECT_ELECTRICITY_DISTRIBUTION_LOSSES=1, HIGH_DISTRIBUTION_ELECTRICITY_LOSSES\
		 , IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES
	=2, MEDIUM_DISTRIBUTION_ELECTRICITY_LOSSES , IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES\
		=3, LOW_DISTRIBUTION_ELECTRICITY_LOSSES
	 , USER_DEFINED_DISTRIBUTION_ELECTRICITY_LOSSES ) ) ))
	~	
	~		|

CURRENT_TRENDS_ELECTRICITY_LOSSES:=
	GET_DIRECT_DATA(  'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS', 'CURRENT_TRENDS_ELECTRICITY_LOSSES'\
		 )
	~	
	~		|

GDP_pc_MAX:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'WEF_INDICATORS' , 'TIME_WEF_FOOD' , 'GDPpc_MAX'\
		)
	~	
	~		|

GDP_pc_MED:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'WEF_INDICATORS' , 'TIME_WEF_FOOD' , 'GDPpc_MED'\
		)
	~	
	~		|

GDP_pc_MIN:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'WEF_INDICATORS' , 'TIME_WEF_FOOD' , 'GDPpc_MIN'\
		)
	~	
	~		|

WEF_land_indicator=
	1-0.9*(1-WEF_food_indicator)^1.2
	~	
	~		|

WEF_economy_indicator=
	IF_THEN_ELSE(SWITCH_POPULATION=0, GDP_pc_MED , IF_THEN_ELSE( Switch_Scenarios=1, GDP_pc_MAX\
		 , IF_THEN_ELSE( Switch_Scenarios=2 , GDP_pc_MED , GDP_pc_MIN ) ) )
	~	
	~		|

