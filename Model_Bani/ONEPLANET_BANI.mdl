Policy_4_ON=
	1
	~	
	~		|

domestic_water_use_effective=
	domestic_water_use*(1-domestic_loss_frac)
	~	
	~		|

P1_agri_reduction_frac=
	0.2
	~	
	~		|

policy_progress_0_1=
	min( 1 ,
	MAX( 0 ,
	(Time - policy_start_year) / (policy_target_year - policy_start_year) ) )
	~	
	~		|

policy_start_year=
	2020
	~	
	~		|

Water_demand=
	Crop_Water_Demand_after_Policy+Livestock_water_demand+domestic_water_use_effective
	~	m3
	~		|

Crop_Water_Demand_after_Policy=
	Crop_water_demand*P1_agri_factor*P3_irrig_factor
	~	
	~		|

domestic_loss_frac_base=
	0.2
	~	
	~		|

P2_loss_reduction_frac=
	0.35
	~	
	~		|

P3_irrig_factor=
	1 - Policy_3_ON * P3_irrig_reduction_frac * policy_progress_0_1
	~	
	~		|

policy_target_year=
	2050
	~	
	~		|

domestic_loss_frac=
	domestic_loss_frac_base * ( 1 - Policy_2_ON * P2_loss_reduction_frac * policy_progress_0_1\
		 )
	~	
	~		|

Policy_3_ON=
	0
	~	
	~		|

Policy_2_ON=
	0
	~	
	~		|

P1_agri_factor=
	1 - Policy_1_ON *P1_agri_reduction_frac * policy_progress_0_1
	~	
	~		|

P3_irrig_reduction_frac=
	0.25
	~	
	~		|

