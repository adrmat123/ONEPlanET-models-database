Expected_Real_Value_Added=
	IF_THEN_ELSE(Time<2021, (Expected_GDP - EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS) \
		, (Expected_GDP - EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP
	)
	 )
	~	M$
	~	 This variable calculates the anticipated real value added for the entire \
		economy by adjusting Expected_GDP to exclude taxes less subsidies on \
		products. It uses the Taxes_Less_Subsidies_On_Product_Share up to 2021 and \
		the externally defined Expected_Taxes_Less_Subsidies_On_Product_Share_SP \
		afterward, depending on scenario assumptions. This adjustment provides a \
		net measure of economic output, reflecting the true value added across all \
		productive sectors after fiscal modifications.
	|

Total_population=
	IF_THEN_ELSE(Time<=2020, SUM(Population[GENDER_I!,AGE_COHORTS_I!]) , IF_THEN_ELSE(SWITCH_POPULATION\
		=0, SUM(Population[GENDER_I!,AGE_COHORTS_I!]) , SSP_POPULATION ) )
	~	people
	~	Sum of populations by cohort and age
	|

EXPECTED_SECTOR_SHARE_SP[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	IF_THEN_ELSE( Switch_Scenarios=1 , EXPECTED_SECTOR_SHARE_SSP1[PRODUCTIVE_SECTORS] , \
		IF_THEN_ELSE( Switch_Scenarios=2, EXPECTED_SECTOR_SHARE_SSP2[PRODUCTIVE_SECTORS] ,  \
		EXPECTED_SECTOR_SHARE_SSP3[PRODUCTIVE_SECTORS]) )
	~	
	~	This variable provides a projection of each sector’s share—Industry, \
		Transport, Commercial, and Agriculture, Forestry, and Fishing—in the \
		Expected_Real_Value_Added, used in future scenarios beyond 2021. It allows \
		for sector shares to be adapted under different assumptions, aligning the \
		model with potential economic shifts across sectors. This enables a \
		flexible approach to projecting sectoral contributions in a changing \
		economic landscape.
	|

