	|

effective_dammed_water_for_hydroelectricity=
	dam_contribution_P2_on_off-(PERCENTAGE_OF_OTHER_USES_OF_DAMMED_WATER*dam_contribution_P2_on_off\
		+PERCENTAGE_OF_WATER_DAMMED_FOR_DOMESTIC_USE
	*WEF_domestic_water_use+PERCENTAGE_OF_WATER_DAMMED_FOR_LIVESTOCK_USE*livestock_water_use\
		+PERCENTAGE_OF_WATER_DAMMED_FOR_USE_IN_AGRICULTURE
	*agri_water_use)
	~	
	~	Amount of water in reservoirs that can be used for electricity production.
	|

