		 )
	~	M$
	~		|

EXPECTED_LABOUR_SHARE_SP:INTERPOLATE::=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , Exogenous_Labour_Share_SSP1 , IF_THEN_ELSE( SWITCH_SCENARIOS\
		=2, Exogenous_Labour_Share_SSP2 ,  Exogenous_Labour_Share_SSP3) )
	~	Dmnl
	~	This variable projects the future share of Real_Value_Added allocated to employee \
		compensation under different scenarios beyond 2020. It reflects \
		anticipated changes in the distribution of economic output, adjusting to \
		potential shifts in income policies, labor market dynamics, or economic \
		structure. This projected share allows the model to explore how the labor \
		share of GDP might evolve under various future conditions.
		
		
		GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , \
		'SCENARIO_TIME_ECO' , 'EXPECTED_LABOUR_SHARE' )
	|

EXPECTED_NET_EXPORTS_SP=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , EXPECTED_NET_EXPORTS_SSP1 , IF_THEN_ELSE( SWITCH_SCENARIOS\
		=2, EXPECTED_NET_EXPORTS_SSP2 ,  EXPECTED_NET_EXPORTS_SSP3) )
	~	M$
	~		|

EXPECTED_NET_EXPORTS_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'NET_EXPORTS_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_NET_EXPORTS_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'NET_EXPORTS_SSP2'\
		 )
	~	M$
	~		|

EXPECTED_NET_EXPORTS_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'NET_EXPORTS_SSP3'\
		 )
	~	M$
	~		|

Expected_Real_Value_Added=
	IF_THEN_ELSE(Time<2021, (Expected_GDP - EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS) \
		, (Expected_GDP - EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP
	)
	 )
	~	M$
	~	 This variable calculates the anticipated real value added for the entire \
		economy by adjusting Expected_GDP to exclude taxes less subsidies on \
		products. It uses the Taxes_Less_Subsidies_On_Product_Share up to 2021 and \
		the externally defined Expected_Taxes_Less_Subsidies_On_Product_Share_SP \
		afterward, depending on scenario assumptions. This adjustment provides a \
		net measure of economic output, reflecting the true value added across all \
		productive sectors after fiscal modifications.
	|

Total_population=
	IF_THEN_ELSE(Time<=2020, SUM(Population[GENDER_I!,AGE_COHORTS_I!]) , IF_THEN_ELSE(SWITCH_POPULATION\
		=0, SUM(Population[GENDER_I!,AGE_COHORTS_I!]) , SSP_POPULATION ) )
	~	people
	~	Sum of populations by cohort and age
	|

EXPECTED_SECTOR_SHARE_SP[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , EXPECTED_SECTOR_SHARE_SSP1[PRODUCTIVE_SECTORS] , \
		IF_THEN_ELSE( SWITCH_SCENARIOS=2, EXPECTED_SECTOR_SHARE_SSP2[PRODUCTIVE_SECTORS] ,  \
		EXPECTED_SECTOR_SHARE_SSP3[PRODUCTIVE_SECTORS]) )
	~	Dmnl
	~	This variable provides a projection of each sector’s share—Industry, \
		Transport, Commercial, and Agriculture, Forestry, and Fishing—in the \
		Expected_Real_Value_Added, used in future scenarios beyond 2021. It allows \
		for sector shares to be adapted under different assumptions, aligning the \
		model with potential economic shifts across sectors. This enables a \
		flexible approach to projecting sectoral contributions in a changing \
		economic landscape.
	|

EXPECTED_SECTOR_SHARE_SSP1[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'SECTOR_SHARE_SSP1'\
		 )
	~	Dmnl
	~		|

EXPECTED_SECTOR_SHARE_SSP2[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'SECTOR_SHARE_SSP2'\
		 )
	~	Dmnl
	~		|

EXPECTED_SECTOR_SHARE_SSP3[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'SECTOR_SHARE_SSP3'\
		 )
	~	Dmnl
	~		|

EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP:INTERPOLATE::=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 ,EXPECTED_TAXES_SSP1 , IF_THEN_ELSE( SWITCH_SCENARIOS\
		=2, EXPECTED_TAXES_SSP2 ,  EXPECTED_TAXES_SSP3) )
	~	M$
	~	This variable represents the expected total value of taxes less subsidies \
		on products for future scenarios beyond 2020. It is used as a monetary \
		amount rather than a percentage, providing a direct fiscal adjustment to \
		the calculation of Real_GDP. This approach allows for specific \
		scenario-based projections of fiscal policy impacts on GDP.
	|

EXPECTED_TAXES_SSP1:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'TAXES_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_TAXES_SSP2:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'TAXES_SSP2'\
		 )
	~	M$
	~		|

EXPECTED_TAXES_SSP3:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'TAXES_SSP3'\
		 )
	~	M$
	~		|

Exogenous_Labour_Share_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'LABOUR_SHARE_SSP1'\
		 )
	~	Dmnl
	~		|

Exogenous_Labour_Share_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'LABOUR_SHARE_SSP2'\
		 )
	~	Dmnl
	~		|

GOVERNMENT_EXPENDITURE_SP:INTERPOLATE::=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , EXPECTED_GOVERNMENT_EXPENDITURE_SSP1 , IF_THEN_ELSE\
		( SWITCH_SCENARIOS=2, EXPECTED_GOVERNMENT_EXPENDITURE_SSP2 ,  EXPECTED_GOVERNMENT_EXPENDITURE_SSP3\
		) )
	~	M$
	~	This variable projects future government spending based on policy \
		assumptions and historical trends beyond 2020. It allows the model to \
		evaluate how expected changes in fiscal policy and government priorities \
		will impact overall consumption and economic activity.
	|

Exogenous_Labour_Share_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'LABOUR_SHARE_SSP3'\
		 )
	~	Dmnl
	~		|

SSP1_POP:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'population' , 'SCENARIO_TIME_POP' , 'POPULATION_SSP1'\
		 )
	~	people
	~		|

SSP2_POP:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'population' , 'SCENARIO_TIME_POP' , 'POPULATION_SSP2'\
		 )
	~	people
	~		|

SWITCH_POPULATION=
	0
	~	
	~	0 ENDOGENO
		1 SSP
	|

Expected_GDP=
	IF_THEN_ELSE(Time<2020, Final_consumption+INVESTMENT+Net_Exports+EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS\
		 , Final_consumption+INVESTMENT+Net_Exports+EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP\
		)
	~	M$
	~	This variable represents the anticipated total Gross Domestic Product \
		(GDP), calculated by summing Final Consumption, Investment, and Net \
		Exports. It reflects the model’s expected economic output and serves as \
		a proxy for aggregate demand, capturing the total demand for goods and \
		services within the economy. This value provides insight into the \
		economy's projected performance based on domestic consumption, investment \
		levels, and trade balance.
	|

EXPECTED_GOVERNMENT_EXPENDITURE_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'GOV_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_GOVERNMENT_EXPENDITURE_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'GOV_SSP2'\
		 )
	~	M$
	~		|

SSP_POPULATION=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , SSP1_POP , IF_THEN_ELSE( SWITCH_SCENARIOS=2, SSP2_POP\
		 ,  SSP3_POP) )
	~	people
	~		|

EXPECTED_GOVERNMENT_EXPENDITURE_SSP3:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'GOV_SSP3'\
		 )
	~	M$
	~		|

EXOGENOUS_HH_CONSUMPTION_SP=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , EXPECTED_HH_CONSUMPTION_SSP1 , IF_THEN_ELSE( SWITCH_SCENARIOS\
		=2, EXPECTED_HH_CONSUMPTION_SSP2 ,  EXPECTED_HH_CONSUMPTION_SSP3) )
	~	M$
	~		|

SSP3_POP:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'population' , 'SCENARIO_TIME_POP' , 'POPULATION_SSP3'\
		 )
	~	people
	~		|

EXPECTED_HH_CONSUMPTION_SSP3:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'HH_CONSUMPTION_SSP3'\
		 )
	~	M$
	~		|

EXPECTED_INVESTMENT_SSP1:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'INVESTMENT_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_INVESTMENT_SSP2:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'INVESTMENT_SSP2'\
		 )
	~	M$
	~		|

Real_GDP=
	IF_THEN_ELSE(Time<2021, Real_Value_Added+EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS \
		, Real_Value_Added+EXPECTED_TAXES_LESS_SUBSIDES_ON_PRODUCT_SP
	 )
	~	M$
	~	This variable calculates GDP by adding Real_Value_Added to Taxes Less \
		Subsidies. Up to 2020, Taxes Less Subsidies is calculated as a percentage \
		of GDP, while after 2020, it is represented as a monetary value based on \
		scenario projections. This approach ensures that the model reflects the \
		impact of fiscal elements on GDP accurately, adapting to different methods \
		of estimating taxes and subsidies in future scenarios.
	|

conversion1=
	1e+06
	~	
	~		|

EXOGENOUS_LABOUR_SHARE:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'LABOUR_SHARE' )
	~	Dmnl
	~	This variable captures the historical distribution of Real_Value_Added \
		allocated to employees, based on externally sourced data up to 2020. It \
		serves as a baseline for labor's share of GDP before scenario-based \
		adjustments are applied. After 2020, this historical share is replaced by \
		Expected_Labour_Share, which adapts to different future scenarios, \
		providing continuity and reference for past income distribution patterns \
		in the model.
	|

EXPECTED_HH_CONSUMPTION_SSP1:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'HH_CONSUMPTION_SSP1'\
		 )
	~	M$
	~		|

EXPECTED_HH_CONSUMPTION_SSP2:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx' , 'economy' , 'SCENARIO_TIME_ECO' , 'HH_CONSUMPTION_SSP2'\
		 )
	~	M$
	~		|

Net_Exports=
	IF_THEN_ELSE(Time<=2021, EXOGENOUS_NET_EXPORTS ,EXPECTED_NET_EXPORTS_SP )
	~	M$
	~		|

EXPECTED_INVESTMENT:INTERPOLATE::=
	IF_THEN_ELSE( SWITCH_SCENARIOS=1 , EXPECTED_INVESTMENT_SSP1 , IF_THEN_ELSE( SWITCH_SCENARIOS\
		=2, EXPECTED_INVESTMENT_SSP2 ,  EXPECTED_INVESTMENT_SSP3) )
	~	M$
	~	Historical investment values
	|

SWITCH_SCENARIOS=
	2
	~	
	~	scenario = 1 {1 = SSP1 (Estímulo), 2 = SSP2 (BAU), 3 = SSP3 (Crise)}
	|

GDP_per_capita=
	ZIDZ(Real_GDP, Total_population )*conversion1
	~	$/people/Year
	~		|

Water_Demand=
	0
	~	
	~		|

REAL_VALUE_ADDED_RESTO_HH=
	Expected_Real_Value_Added-HH_Consumption
	~	
	~		|

HH_Consumption=
	IF_THEN_ELSE(Time<=2020, EXOGENOUS_HH_CONSUMPTION_MP , EXOGENOUS_HH_CONSUMPTION_SP )
	~	M$
	~		|

Final_consumption=
	IF_THEN_ELSE(Time<=2020, 
	EXOGENOUS_GOVERNMENT_EXPENDITURE+HH_Consumption , 
	HH_Consumption+GOVERNMENT_EXPENDITURE_SP )
	~	M$
	~	This variable calculates the total consumption in the economy by summing \
		Household_Consumption, Expected_Government_Expenditure, and \
		Expected_NPISH_Consumption. It represents the overall demand for goods and \
		services, making it a crucial component of GDP. This variable reflects the \
		total economic activity driven by consumption across all sectors.
	|

direct_CO2_emissions_per_capita_from_electricity=
	SUM(direct_electricity_CO2_emissions[ENERGY_TECHS!])/Total_population
	~	kg/(Year*people)
	~		|

MINIMUN_TIER_CONSIDERED=
	3.49
	~	
	~	Average electricity consumption per capita in South Africa: \
		https://www.iea.org/countries/south-africa/electricity
	|

EMISSION_WEIGHT=
	0.15
	~	
	~		|

LEVEL_OF_ELEC_CONSUMPTION_WEIGHT=
	0.31
	~	
	~		|

RATIO_OF_IMPORTS_WEIGHT=
	0.3637
	~	
	~		|

f_co2_emission_from_all_economy=
	CO2_emissions_from_the_rest_of_the_economy[SOLIDS]+CO2_emissions_from_the_rest_of_the_economy\
		[LIQUIDS]+CO2_emissions_from_the_rest_of_the_economy[GAS]+f_Co2_emissions
	~	kg/Year
	~		|

CO2_emissions_from_the_rest_of_the_economy[LIQUIDS]=
	SUM(PE_consumption_by_sector_and_energy_type[SECTORS!,LIQUIDS])*CO2_EMISSION_FACTORS\
		[OIL]*(1/GJ_to_MWh) ~~|
CO2_emissions_from_the_rest_of_the_economy[SOLIDS]=
	SUM(PE_consumption_by_sector_and_energy_type[SECTORS!,SOLIDS])*CO2_EMISSION_FACTORS[\
		COAL_PP]*(1/GJ_to_MWh) ~~|
CO2_emissions_from_the_rest_of_the_economy[GAS]=
	SUM(PE_consumption_by_sector_and_energy_type[SECTORS!,GAS])*CO2_EMISSION_FACTORS[GAS_PP\
		]*(1/GJ_to_MWh)
	~	kg/Year
	~	The variable accounts for CO2 emissions due to the combustion of fuels \
		such as coal, gas and oil by the different productive sectors and \
		households excluding the electricity sector.
	|

total_CO2_emissions_per_capita=
	f_co2_emission_from_all_economy/Total_population
	~	kg/(Year*people)
	~	Refer to the total amount of carbon dioxide emissions produced by a \
		country, divided by its population. This variable measures the average CO2 \
		emissions attributable to each individual.
	|

total_cumulative_CO2_emissions_from_all_economy= INTEG (
	f_co2_emission_from_all_economy,
		0)
	~	
	~		|

ratio_electricity_autonomy=
	
	ZIDZ( SUM(total_electricity_mix[ELEC_SUPPLIERS!])-total_electricity_mix[IMPORTS] , SUM\
		(total_electricity_mix[ELEC_SUPPLIERS!]) )
	~	
	~	Ratio between the electricity generated with local resources and the total \
		electricity_generation
	|

total_electricity_consumption_per_capita=
	check_total_electricity_consumption/Total_population
	~	MWh/(Year*people)
	~	This variable represents the availability of electricity.
	|

UNIT_PREFIXES_I:
	pico,nano,micro,mili,centi,deci,BASE_UNIT,deca,hecto,kilo,mega,giga,tera,peta,exa,zetta
	~	
	~		|

UNIT_PREFIXES1_I:
	pico,nano,micro,mili,centi,deci,BASE_UNIT,deca,hecto,kilo,mega,giga,tera,peta,exa,zetta
	~	
	~		|

ANIMALS_TYPES_I:
	DAIRY_CATTLE, OTHER_CATTLE, GOATS, CHICKENS, SWINE
	~	
	~		|

LAND_PRODUCTS_I:
	CORN, RICE, COFFEE, CASSAVA, GROUNDNUTS, SESAME, SWEETPOT, BEAN, SUNFLOWER, SORGHUM
	~	
	~		|

LANDS_MAP_I:
	LANDS_I
	~	
	~		|

LANDS_I:
	CROPLAND_RAINFED, CROPLAND_IRRIGATED, FOREST_MANAGED, FOREST_PRIMARY, FOREST_PLANTATIONS\
		, SHRUBLAND, GRASSLAND, WETLAND, URBAN_LAND, WATERBODIES, OTHER_LAND
	~	ha
	~		|

FOODS_I:
	CEREALS_DIET, TUBERS_DIET, PULSES_LEGUMES_NUTS, FRUITS_VEGETABLES_DIET, FATS_VEGETAL\
		, FATS_ANIMAL, DAIRY, EGGS, MEAT_RUMINANTS, MEAT_MONOGASTRIC, FISH, SUGARS, BEVERAGES\
		, STIMULANTS
	~	
	~		|

MANURE_MANAGEMENT_SYSTEM_I:
	LAGOON, LIQUID_SLURRY, SOLID_STORAGE, DRY_LOT, PASTURE_RANGE, DAILY_SPREAD, DIGESTER\
		, BURNED_FUEL, PIT_LESS_MONTH, PIT_MORE_MONTH, OTHER_SYSTEMS
	~	Dmnl
	~		|

WEF_total_area_occupied_by_power_plants=
	SUM(area_occupied_by_power_plants[FOSSIL!])+SUM(area_occupied_by_power_plants[RENEWABLES\
		!])
	~	km2
	~		|

TRANSFORMER_EFFICIENCY=
	1
	~	
	~		|

PERCENTAGE_OF_WATER_DAMMED_FOR_LIVESTOCK_USE=
	0.001
	~	Dmnl
	~		|

tot_Water_use_for_electricity_production=
	WEF_total_water_consumption_by_fossil_power_plants+WEF_total_water_consumption_by_renewables
	~	m3
	~	TOT Water use for electricity production, so from RES and FF (excluding \
		the use of hydroelectric power).
	|

NET_ANNUAL_AVERAGE_HEAD=
	11
	~	m
	~		|

water_consumption_by_renewables[RENEWABLES]=
	FACTOR_OF_WATER_CONSUMED_TO_PRODUCE_ELECTRICITY_BY_TYPE_OF_POWER_PLANT[RENEWABLES]*ALLOCATE_DEMAND_TO_TECHS\
		[RENEWABLES]
	~	m3/Year
	~		|

WEF_maximum_energy_can_be_produced_with_hydro=
	effective_dammed_water_for_hydroelectricity*CONVERSION_FACTOR_WATER_TO_ENERGY
	~	
	~		|

WATER_DENSITY=
	1
	~	
	~		|

FACTOR_OF_WATER_CONSUMED_TO_PRODUCE_ELECTRICITY_BY_TYPE_OF_POWER_PLANT[ELEC_SUPPLIERS\
		]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'WATER_FACTORS' )
	~	m3/MWh
	~		|

CONVERSION_FACTOR_WATER_TO_ENERGY=
	NET_ANNUAL_AVERAGE_HEAD*GRAVITY*TRANSFORMER_EFFICIENCY*TURBINE_EFFICIENCY*WATER_DENSITY
	~	
	~	This factor converts the potential energy of the dammed water into the \
		amount of electricity that can be produced in a maximum of one year, if \
		the necessary installed capacity is available. Electrical losses are \
		accounted for.
	|

PERCENTAGE_OF_OTHER_USES_OF_DAMMED_WATER=
	0.001
	~	Dmnl
	~		|

area_occupied_by_power_plants[FOSSIL]=
	fossil_installed[FOSSIL]*LAND_OCCUPATION_FACTOR_BY_POWER_PLANTS[FOSSIL] ~~|
area_occupied_by_power_plants[RENEWABLES]=
	RES_installed[RENEWABLES]*LAND_OCCUPATION_FACTOR_BY_POWER_PLANTS[RENEWABLES]
	~	km2
	~		|

PERCENTAGE_OF_WATER_DAMMED_FOR_DOMESTIC_USE=
	0.001
	~	Dmnl
	~		|

GRAVITY=
	1
	~	
	~		|

PERCENTAGE_OF_WATER_DAMMED_FOR_USE_IN_AGRICULTURE=
	0.001
	~	Dmnl
	~		|

TURBINE_EFFICIENCY=
	1
	~	
	~		|

WEF_total_water_consumption_by_fossil_power_plants=
	SUM(water_consumption_by_fossil_power_plants[FOSSIL!])
	~	m3/Year
	~		|

water_consumption_by_fossil_power_plants[FOSSIL]=
	ALLOCATE_DEMAND_TO_TECHS[FOSSIL]*FACTOR_OF_WATER_CONSUMED_TO_PRODUCE_ELECTRICITY_BY_TYPE_OF_POWER_PLANT\
		[FOSSIL]
	~	m3/Year
	~		|

WEF_total_water_consumption_by_renewables=
	SUM(water_consumption_by_renewables[RENEWABLES!])
	~	m3/Year
	~		|

chicken_water_use=
	chicken_head*CHICKEN_WATER_USE_PER_HEAD
	~	m3
	~	Chicken water use
	|

chicken_head:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'chicken_head' )
	~	head
	~	n of chickens
	|

CHICKEN_WATER_USE_PER_HEAD:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'CHICKEN_WATER_USE_PER_HEAD'\
		 )
	~	m3/head
	~	CHICKEN_WATER_USE_PER_HEAD
	|

industrial_water_withdrawal:INTERPOLATE::=
	0
	~	m3
	~	Industrial_water_withdrawal
		sources: gfdl-esm4; ipsl-cm6a-lr; mpi-esm1-2-hr / h08. Reference: Hanasaki \
		N., Yoshikawa S., Pokhrel Y., Kanae S. 2018. A global hydrological \
		simulation to specify the sources of water used by humans. Hydrology and \
		Earth System Sciences. 22: 789–817. DOI: 10.5194/hess-22-789-2018 \
		GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', \
		'industrial_water_withdrawal' )
	|

WEF_domestic_water_use=
	Total_population*total_water_withdrawal_per_capita
	~	m3
	~	Domestic water use
	|

pig_water_use=
	pig_head*PIG_WATER_USE_PER_HEAD
	~	m3
	~	pig_water_use
	|

water_balance= INTEG (
	total_water_available-total_water_output,
		0)
	~	m3
	~	Water balance
	|

CWR_MAIZE:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'cwr_maize' )
	~	m3/ha
	~	Crop water requirement_Maize
	|

CWR_RICE:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'cwr_rice' )
	~	m3/ha
	~	RICE WATER REQUIRMENT
	|

cattle_water_use=
	cattle_head*CATTLE_WATER_USE_PER_HEAD
	~	m3
	~	cattle water use
	|

FOSSIL_INI_INSTALLED_DELAY[COAL_PP]= DELAY_FIXED (
	FOSSIL_INI_INSTALLED[COAL_PP]*aux_gradual_decomissioning_FF, FOSSIL_INI_TIME_DECOMMISION\
		[COAL_PP], 0) ~~|
FOSSIL_INI_INSTALLED_DELAY[GAS_PP]= DELAY_FIXED (
	FOSSIL_INI_INSTALLED[GAS_PP]*aux_gradual_decomissioning_FF, FOSSIL_INI_TIME_DECOMMISION\
		[GAS_PP], 0) ~~|
FOSSIL_INI_INSTALLED_DELAY[OIL]= DELAY_FIXED (
	FOSSIL_INI_INSTALLED[OIL]*aux_gradual_decomissioning_FF, FOSSIL_INI_TIME_DECOMMISION\
		[OIL], 0)
	~	
	~	Programming auxiliary variable
	|

fossil_f1_decommision[FOSSIL]=
	fossil_f1_decomision_delay[FOSSIL]+FOSSIL_INI_INSTALLED_DELAY[FOSSIL]
	~	MW/Year
	~	Annual decommissioning flow of power installations by type of renewable \
		technology.
	|

aux_gradual_decomissioning_FF=
	IF_THEN_ELSE(POLICY_COAL_PP_DECOMMISIONING = 1, 0.13/2*(PULSE(2015 , 2 )+PULSE( 2019\
		 , 2 )+PULSE( 2023 ,2 )+PULSE( 2026 ,2)) , 0.05/2*(PULSE(2015 , 2 )+PULSE( 2019 , 2\
		 )+PULSE( 2023 ,2 )+PULSE( 2026 ,2)) )
	~	
	~		|

f1_decommision[RENEWABLES]=
	RES_INI_DECOMISION_DELAY[RENEWABLES]+f1_decommision_delay[RENEWABLES]
	~	MW/Year
	~	Annual decommissioning flow of power installations by type of renewable \
		technology.
	|

RES_INI_DECOMISION_DELAY[PV]= DELAY_FIXED (
	 RES_INI_INSTALLED[PV]*aux_gradual_decommisioning_RES, RES_INI_TIME_DECOMMISION[PV] \
		,
	 0) ~~|
RES_INI_DECOMISION_DELAY[WIND]= DELAY_FIXED (
	RES_INI_INSTALLED[WIND]*aux_gradual_decommisioning_RES, RES_INI_TIME_DECOMMISION[WIND\
		] ,
	 0) ~~|
RES_INI_DECOMISION_DELAY[HYDRO]= DELAY_FIXED (
	RES_INI_INSTALLED[HYDRO]*aux_gradual_decommisioning_RES, RES_INI_TIME_DECOMMISION[HYDRO\
		] ,
	 0) ~~|
RES_INI_DECOMISION_DELAY[BIOMASS_PP]= DELAY_FIXED (
	RES_INI_INSTALLED[BIOMASS_PP]*aux_gradual_decommisioning_RES, RES_INI_TIME_DECOMMISION\
		[BIOMASS_PP] ,
	 0)
	~	
	~	Programming auxiliary variable
	|

aux_gradual_decommisioning_RES=
	0*(PULSE( 2040 , 2 )+PULSE( 2045 , 2 )+PULSE( 2050 ,2 )+PULSE( 2055 , 2))
	~	
	~		|

MWh_to_kWh=
	1000
	~	kWh/MWh
	~		|

total_electricity_produced_with_FF=
	SUM(ALLOCATE_DEMAND_TO_TECHS[FOSSIL!])
	~	MWh/Year
	~		|

total_electricity_produced_with_RES=
	SUM(ALLOCATE_DEMAND_TO_TECHS[RENEWABLES!])
	~	MWh/Year
	~		|

EXOGENOUS_HH_CONSUMPTION_MP:=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'HH_CONSUMPTION'\
		 )
	~	M$
	~		|

Households_transport_and_commercial_demand_of_elec_GWh=
	(demand_of_ELEC_by_sector[TRANSPORT,ELEC]+demand_of_ELEC_by_sector[HOUSEHOLDS,ELEC]+\
		demand_of_ELEC_by_sector[COMMERCIAL,ELEC])/1000
	~	GWh/yr
	~		|

total_demand_of_elec_GWh[ELEC]=
	total_demand_of_ELEC[ELEC]/1000
	~	GWh/yr
	~		|

total_ELEC_disponibility[ELEC]=
	SUM(ELEC_techs_supply[ENERGY_TECHS!])+ALLOCATE_DEMAND_TO_TECHS[IMPORTS]
	~	MWh/Year
	~	Maximum production capacity of installed power plants
	|

effective_elec_disponibility_for_productive_purposes=
	(total_ELEC_disponibility[ELEC]-demand_of_elec_households*HOUSEHOLDS_SCARCITY)
	~	MWh/Year
	~	Electricity available for productive purposes
	|

check_total_electricity_consumption=
	SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS!])
	~	MWh/Year
	~		|

LAND_OCCUPATION_FACTOR_BY_POWER_PLANTS[ENERGY_TECHS]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'LAND_OCCUPATION_FACTOR_BY_POWER_PLANTS'\
		 )
	~	km2/MW
	~		|

INITIAL_COAL_RESERVES=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'INITIAL_COAL_RESERVES' )
	~	MWh
	~	Initial value of local coal reserves.
	|

depletion_of_coal_resources=
	PE_consumption_by_energy_type[SOLIDS]
	~	
	~	Depletion flow of coal reserves as a function of primary energy consumed \
		(from coal).
	|

indirect_electricity_CO2_emissions=
	ALLOCATE_DEMAND_TO_TECHS[IMPORTS]*CO2_EMISSION_FACTOR_OF_ELECTRICITY_IMPORTS
	~	kg/Year
	~		|

PE_of_gas_counting_distribution_losses[SECTORS]=
	ZIDZ( FE_Demand[SECTORS,GAS] , LEAKS_FROM_NATURAL_GAS_PIPELINES )
	~	
	~		|

CO2_EMISSION_FACTOR_OF_ELECTRICITY_IMPORTS:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO' , 'CO2_EMISSION_FACTOR_OF_ELECTRICITY_IMPORTS'\
		 )
	~	kg/MWh
	~	Future evolution of the CO2 emission factor for electricity imports
	|

PE_consumption_by_sector_and_energy_type[SECTORS,SOLIDS]=
	FE_Demand[SECTORS,SOLIDS] ~~|
PE_consumption_by_sector_and_energy_type[SECTORS,GAS]=
	PE_of_gas_counting_distribution_losses[SECTORS] ~~|
PE_consumption_by_sector_and_energy_type[SECTORS,LIQUIDS]=
	FE_Demand[SECTORS,LIQUIDS] ~~|
PE_consumption_by_sector_and_energy_type[SECTORS,BIOMASS]=
	FE_Demand[SECTORS,BIOMASS]
	~	MWh/Year
	~	Primary energy consumed by the productive sectors and households of the \
		case study by type of energy (biomass, solids, liquids, gases). The \
		primary energy consumed in the transformation processes from primary to \
		secondary energy is not considered here.
	|

COAL_RESERVES= INTEG (
	-depletion_of_coal_resources,
		INITIAL_COAL_RESERVES)
	~	MWh
	~	Coal reserves are gradually depleting as they are consumed by coal-fired \
		power plants for electricity generation, as well as by other productive \
		sectors and households that use coal as a final energy source.
	|

PE_consumption_by_energy_type[PE]=
	SUM(PE_consumption_by_sector_and_energy_type[SECTORS!,PE])+primary_energy_consumption_in_power_plants\
		[PE]
	~	MWh/Year
	~		|

primary_energy_consumption_in_power_plants[SOLIDS]=
	TI_for_ELEC[COAL_PP] ~~|
primary_energy_consumption_in_power_plants[LIQUIDS]=
	TI_for_ELEC[OIL] ~~|
primary_energy_consumption_in_power_plants[GAS]=
	TI_for_ELEC[GAS_PP] ~~|
primary_energy_consumption_in_power_plants[BIOMASS]=
	TI_for_ELEC[BIOMASS_PP]
	~	MWh/Year
	~	primary energy consumption of power plants
	|

f_Co2_emissions=
	SUM( direct_electricity_CO2_emissions[ELEC_SUPPLIERS!] )+indirect_electricity_CO2_emissions
	~	kg/Year
	~	Flow of direct annual co2 emissions
	|

Mortality_rate_per_person[male,AGE_COHORTS_I]=
	Male_mortalility_per_person[male,AGE_COHORTS_I] ~~|
Mortality_rate_per_person[female,AGE_COHORTS_I]=
	Female_mortality_per_person[female,AGE_COHORTS_I]
	~	1/Year
	~	Annual mortality rate by cohort and age.
	|

FERTILITY_RATE_MP[AGE_COHORTS_I]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'population' , 'TIME_POP' , 'FERTILITY_RATE'\
		 )
	~	
	~		|

Male_mortalility_per_person[male, AGE_COHORTS_I]=
	MALE_MORTALITY_MP[AGE_COHORTS_I]/UNIT_CONVERSION_PER_1000_TO_PER_PERSON
	~	people
	~		|

Female_mortality_per_person[female,AGE_COHORTS_I]=
	FEMALE_MORTALITY_MP[AGE_COHORTS_I]/UNIT_CONVERSION_PER_1000_TO_PER_PERSON
	~	people
	~		|

UNIT_CONVERSION_PER_1000_TO_PER_PERSON=
	1000
	~	
	~		|

FEMALE_MORTALITY_MP[AGE_COHORTS_I]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'population' , 'TIME_POP' , 'FEMALE_MORTALITY'\
		 )
	~	people/Year
	~		|

Fertility_per_person[AGE_COHORTS_I]=
	FERTILITY_RATE_MP[AGE_COHORTS_I]/UNIT_CONVERSION_PER_1000_TO_PER_PERSON
	~	1/Year
	~	Annual fertility rate by cohort for women. The ages considered fertile are those \
		between 15 and 49 years.
		
		GET_DIRECT_CONSTANTS('model_parameters/model_parameters.xlsx','Population_M\
		P' , 'FERTILITY' )
	|

MALE_MORTALITY_MP[AGE_COHORTS_I]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'population' , 'TIME_POP' , 'MALE_MORTALITY'\
		 )
	~	people/Year
	~		|

Population[GENDER_I,C0]= INTEG (
	MAX(0, (Births[GENDER_I] - Deaths[GENDER_I,C0]) - Population[GENDER_I,C0]),
		INITIAL_POPULATION_MP[GENDER_I,C0]) ~~|
Population[GENDER_I,age_middle]= INTEG (
	(Population[GENDER_I,age_young] - Deaths[GENDER_I,age_middle]) - Population[GENDER_I\
		,age_middle],
		INITIAL_POPULATION_MP[GENDER_I,age_middle]) ~~|
Population[GENDER_I,C100]= INTEG (
	(Population[GENDER_I,C99] - Deaths[GENDER_I,C100]) + Population[GENDER_I,C100],
		INITIAL_POPULATION_MP[GENDER_I,C100])
	~	people
	~	This variable represents the total number of individuals within a defined \
		population at a specific point in time. It is calculated by aggregating \
		the counts of individuals based on various demographic factors, including \
		birth rates, death rates, and migration patterns. Population_Stock \
		provides a snapshot of the current population size and serves as a \
		foundational element for analyzing demographic dynamics over time. It is \
		essential for understanding trends in population growth, age distribution, \
		and the potential implications of demographic changes on social and \
		economic systems.
	|

ELEC_generation[RENEWABLES]=
	HOURS_IN_A_YEAR * CF_PERIODICAL[RENEWABLES]*RES_installed[RENEWABLES]*RES_BASE_EFFICIENCY\
		[RENEWABLES] ~~|
ELEC_generation[FOSSIL]=
	FOSSIL_CF[FOSSIL]*HOURS_IN_A_YEAR*fossil_installed[FOSSIL]
	~	MWh/Year
	~	Maximum electricity level that could be produced by the local power system
	|

TI_for_ELEC[RENEWABLES]=
	0 ~~|
TI_for_ELEC[FOSSIL]=
	ZIDZ(ALLOCATE_DEMAND_TO_TECHS[FOSSIL],FOSSIL_BASE_EFFICIENCY[FOSSIL]) ~~|
TI_for_ELEC[IMPORTS]=
	0
	~	MWh/Year
	~	Transformation input refers to the amount of energy (such as coal, natural \
		gas, oil, or biomass) that a power plant consumes to produce electricity. \
		This input includes all energy sources fed into the power generation \
		process before conversion losses occur.
	|

EXOGENOUS_INVESTMENT:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'INVESTMENT' )
	~	M$
	~	Values to develop scenarios for the evolution of the investment in the \
		future
	|

INVESTMENT=
	IF_THEN_ELSE(Time<=2020, EXOGENOUS_INVESTMENT , EXPECTED_INVESTMENT )
	~	
	~		|

ECONOMY_GDP= INTEG (
	1,
		1)
	~	
	~		|

ECONOMY_LABOUR= INTEG (
	1,
		1)
	~	
	~		|

ECONOMY_SCARCITY= INTEG (
	1,
		1)
	~	
	~		|

ECONOMY_ENERGY_SCARCITY= INTEG (
	1,
		1)
	~	
	~		|

ECONOMY_CONSUMPTION= INTEG (
	1,
		1)
	~	
	~		|

Scarcity_indicator_0=
	IF_THEN_ELSE( SWITCH_SCARCITY_INDICATOR_0=0 , EXOGENOUS_SCARCITY_INDICATOR_0 , 
	min( Land_scarcity_indicator,Water_scarcity_indicator))
	~	
	~	This variable aggregates both Land_Scarcity_Indicator and \
		Water_Scarcity_Indicator to provide a comprehensive assessment of resource \
		scarcity in the economy. It is calculated as a weighted average or \
		composite score that reflects the availability of both land and water \
		relative to their respective demands. The indicator ranges from 0 to 1, \
		where a value of 1 signifies that both land and water resources are \
		sufficient to meet demand, while a value closer to 0 indicates increasing \
		levels of scarcity for one or both resources. This indicator is essential \
		for understanding the combined effects of land and water constraints on \
		production capabilities, economic activities, and sustainable development \
		across all sectors.
	|

POPULATION_MODULE= INTEG (
	1,
		1)
	~	
	~		|

AGE_COHORTS_I:
	C0, C1, C2, C3, C4, C5, C6, C7, C8, C9, C10, C11, C12, C13, C14, C15, C16, C17, C18,\
		 C19, C20, C21, C22, C23, C24, C25, C26, C27, C28, C29, C30, C31, C32, C33, C34, C35\
		, C36, C37, C38, C39, C40, C41, C42, C43, C44, C45, C46, C47, C48, C49, C50, C51, C52\
		, C53, C54, C55, C56, C57, C58, C59, C60, C61, C62, C63, C64, C65, C66, C67, C68, C69\
		, C70, C71, C72, C73, C74, C75, C76, C77, C78, C79, C80, C81, C82, C83, C84, C85, C86\
		, C87, C88, C89, C90, C91, C92, C93, C94, C95, C96, C97, C98, C99, C100
	~	
	~		|

age_middle:
	C1, C2, C3, C4, C5, C6, C7, C8, C9, C10, C11, C12, C13, C14, C15, C16, C17, C18, C19\
		, C20, C21, C22, C23, C24, C25, C26, C27, C28, C29, C30, C31, C32, C33, C34, C35, C36\
		, C37, C38, C39, C40, C41, C42, C43, C44, C45, C46, C47, C48, C49, C50, C51, C52, C53\
		, C54, C55, C56, C57, C58, C59, C60, C61, C62, C63, C64, C65, C66, C67, C68, C69, C70\
		, C71, C72, C73, C74, C75, C76, C77, C78, C79, C80, C81, C82, C83, C84, C85, C86, C87\
		, C88, C89, C90, C91, C92, C93, C94, C95, C96, C97, C98, C99
	~	
	~		|

age_young:
	C0, C1, C2, C3, C4, C5, C6, C7, C8, C9, C10, C11, C12, C13, C14, C15, C16, C17, C18,\
		 C19, C20, C21, C22, C23, C24, C25, C26, C27, C28, C29, C30, C31, C32, C33, C34, C35\
		, C36, C37, C38, C39, C40, C41, C42, C43, C44, C45, C46, C47, C48, C49, C50, C51, C52\
		, C53, C54, C55, C56, C57, C58, C59, C60, C61, C62, C63, C64, C65, C66, C67, C68, C69\
		, C70, C71, C72, C73, C74, C75, C76, C77, C78, C79, C80, C81, C82, C83, C84, C85, C86\
		, C87, C88, C89, C90, C91, C92, C93, C94, C95, C96, C97, C98 -> age_middle
	~	
	~		|

INITIAL_POPULATION_MP[GENDER_I,AGE_COHORTS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx' , 'population' , 'INITIAL_POPULATION')
	~	people
	~	Initial population by cohort and age.
	|

Total_births=
	SUM( Births[GENDER_I!] )
	~	people/Year
	~	Sum of male and female births
	|

Total_deaths[GENDER_I]=
	SUM(Deaths[GENDER_I,AGE_COHORTS_I!])
	~	people/Year
	~	Sum of total deaths
	|

Deaths[GENDER_I,C0]=
	MAX(0,Mortality_rate_per_person[GENDER_I,C0]*Births[GENDER_I]*YEAR_MP) ~~|
Deaths[GENDER_I,age_middle]=
	MAX (0, Mortality_rate_per_person[GENDER_I,age_middle]*Population[GENDER_I,age_young\
		]) ~~|
Deaths[GENDER_I,C100]=
	MAX(0, Mortality_rate_per_person[GENDER_I,C100]*(Population[GENDER_I,C99]+Population\
		[GENDER_I,C100]))
	~	people/Year
	~	Annual death flow.
	|

Births[GENDER_I]=
	MAX(0, SUM(Population[female,AGE_COHORTS_I!]*Fertility_per_person[AGE_COHORTS_I!])*GENDER_BIRTHS_RATE_MP\
		[GENDER_I])
	~	people/Year
	~	Annual birth flow.
	|

Population_Variation[GENDER_I]=
	Births[GENDER_I]-SUM(Deaths[GENDER_I,AGE_COHORTS_I!])
	~	
	~	Change in population
	|

working_age:
	C15, C16, C17, C18, C19, C20, C21, C22, C23, C24, C25, C26, C27, C28, C29, C30, C31,\
		 C32, C33, C34, C35, C36, C37, C38, C39, C40, C41, C42, C43, C44, C45, C46, C47, C48\
		, C49, C50, C51, C52, C53, C54, C55, C56, C57, C58, C59, C60, C61, C62, C63, C64
	~	
	~		|

GENDER_BIRTHS_RATE_MP[GENDER_I]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'population' , 'TIME_POP' , 'BIRTH_RATIO'\
		 )
	~	Dmnl
	~	Ratio of male to female births. Currently, for every 100 females, there \
		are 105 males.
	|

YEAR_MP=
	1
	~	Year
	~		|

GENDER_I:
	male, female
	~	
	~		|

Real_Value_Added_by_sector[PRODUCTIVE_SECTORS]=
	Expected_Real_Value_Added_by_sector[PRODUCTIVE_SECTORS]*VMIN(elec_scarcity_factors_by_sector\
		[PRODUCTIVE_SECTORS!])
	~	M$
	~	This variable calculates the actual real value added for each productive \
		sector—Industry, Transport, Commercial, and Agriculture, Forestry, and \
		Fishing. It adjusts the Expected_Real_Value_Added_by_Sector using \
		sector-specific scarcity factors that account for resource constraints, \
		including limitations in water, energy, food, and labor. These adjustments \
		ensure that each sector’s output realistically reflects the impact of \
		potential shortages in these essential resources, providing a measure of \
		economic production by sector under constrained conditions.
	|

Min_scarcity_indicator=
	1
	~	
	~	min(VMIN(elec_scarcity_factors_by_sector[PRODUCTIVE_SECTORS!]),Labour_scarcity_indica\
		tor)
		min(elec scarcity factors by sector[PRODUCTIVE SECTORS!])
	|

Real_Value_Added_Growth_Rate=
	ZIDZ(Real_Value_Added-Real_Value_Added_Delay, Real_Value_Added )
	~	M$
	~	This variable calculates the growth rate of Real_Value_Added, measuring \
		the change in actual economic output over time. By comparing the current \
		Real_Value_Added with its delayed value (Real_Value_Added_Delay), the \
		model assesses the trajectory of economic growth, highlighting expansion \
		or contraction trends. This growth rate helps reveal how the economy \
		responds to resource constraints, indicating resilience or susceptibility \
		to shortages.
	|

EXOGENOUS_HOUR_PER_WORKER=
	2236
	~	h
	~	43x52
	|

HOUSEHOLDS_SCARCITY=
	1
	~	
	~	Distribution of electricity to households in a manner that equitably \
		allocates shortages between households and the productive sectors.
	|

Real_Value_Added_Delay=
	DELAY_FIXED(Real_Value_Added, 1 , 0 )
	~	M$
	~	This variable introduces a time delay to the Real_Value_Added, smoothing \
		fluctuations and reflecting the gradual adjustment of economic output to \
		changes in resource availability or sectoral production. This delayed \
		value is also used to calculate the Real_Value_Added_Growth_Rate, \
		providing a lagged reference point that helps simulate the inertia in \
		economic adjustments over time. This approach allows the model to capture \
		more realistic growth dynamics by accounting for the economy’s \
		adjustment period.
	|

abundance_allocate[SECT_PRODUCT_AUX]=
	ALLOCATE_BY_PRIORITY(demand_of_elec_productive_sectors_correction[SECT_PRODUCT_AUX],\
		PRIORITIES_FOR_SECTORS[SECT_PRODUCT_AUX], 
	ELMCOUNT(SECT_PRODUCT_AUX),WIDTH_FOR_SECTORS ,effective_elec_disponibility_for_productive_purposes\
		)
	~	MWh/Year
	~	This variable is an allocation designed to distribute electricity \
		shortages between productive sectors, after a shortage has been assigned \
		to households. It enables the formulation of priority policies for certain \
		sectors and subsequently impacts the economy.
	|

elec_scarcity_factors_by_sector[INDUSTRY]=
	ZIDZ(abundance_allocate[INDUSTRIA], demand_of_elec_productive_sectors[INDUSTRY] ) ~~|
elec_scarcity_factors_by_sector[TRANSPORT]=
	1 ~~|
elec_scarcity_factors_by_sector[COMMERCIAL]=
	ZIDZ(abundance_allocate[COMERCIO], demand_of_elec_productive_sectors[COMMERCIAL] ) ~~|
elec_scarcity_factors_by_sector[AGRICULTURE_FORESTRY_FISHING]=
	ZIDZ(abundance_allocate[AGRICULTURA], demand_of_elec_productive_sectors[AGRICULTURE_FORESTRY_FISHING\
		] )
	~	1
	~	This variable represents the shortage of electricity that each sector \
		ultimately experiences based on the electricity demand of that sector.
	|

demand_of_elec_productive_sectors_correction[INDUSTRIA]=
	demand_of_elec_productive_sectors[INDUSTRY] ~~|
demand_of_elec_productive_sectors_correction[TRANSPORTE]=
	demand_of_elec_productive_sectors[TRANSPORT] ~~|
demand_of_elec_productive_sectors_correction[COMERCIO]=
	demand_of_elec_productive_sectors[COMMERCIAL] ~~|
demand_of_elec_productive_sectors_correction[AGRICULTURA]=
	demand_of_elec_productive_sectors[AGRICULTURE_FORESTRY_FISHING]
	~	MWh/Year
	~	Programming auxiliary variable
	|

SECT_PRODUCT_AUX:
	INDUSTRIA,TRANSPORTE,COMERCIO,AGRICULTURA
	~	
	~		|

WIDTH_FOR_SECTORS=
	1
	~	
	~	Programming auxiliary variable
	|

PRIORITIES_FOR_SECTORS[SECT_PRODUCT_AUX]=
	1
	~	
	~	This variable is a priority vector used to determine which sectors should \
		experience less electricity shortage, based on their strategic importance \
		to the economy.
	|

demand_of_elec_households=
	demand_of_ELEC_by_sector[HOUSEHOLDS,ELEC]
	~	MWh/Year
	~	Electricity demand of households for domestic uses
	|

demand_of_elec_productive_sectors[INDUSTRY]=
	demand_of_ELEC_by_sector[INDUSTRY,ELEC] ~~|
demand_of_elec_productive_sectors[TRANSPORT]=
	demand_of_ELEC_by_sector[TRANSPORT,ELEC] ~~|
demand_of_elec_productive_sectors[COMMERCIAL]=
	demand_of_ELEC_by_sector[COMMERCIAL,ELEC] ~~|
demand_of_elec_productive_sectors[AGRICULTURE_FORESTRY_FISHING]=
	demand_of_ELEC_by_sector[AGRICULTURE_FORESTRY_FISHING,ELEC]
	~	MWh/Year
	~	Electricity demand of the productive sectors
	|

REAL_VALUE_ADDED_RESTO_HH_PER_SECTOR[PRODUCTIVE_SECTORS]=
	REAL_VALUE_ADDED_RESTO_HH*Sector_share[PRODUCTIVE_SECTORS]
	~	
	~		|

EXOGENOUS_TAXES_LESS_SUBSIDIES_ON_PRODUCTS:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'HISTORICAL_TAXES_LESS_SUBSIDIES'\
		 )
	~	M$
	~	This variable captures the historical value of taxes less subsidies on \
		products, defined externally for years up to 2020. It provides a baseline \
		fiscal adjustment in monetary terms, reflecting past government \
		intervention in the economy through taxes and subsidies. This value is \
		used to calculate Real_GDP by adding it to Real_Value_Added, ensuring that \
		the model accurately represents the fiscal component of GDP based on \
		historical data. After 2020, this value is replaced by scenario-based \
		projections through variables like \
		EXPECTED_TAXES_LESS_SUBSIDIES_ON_PRODUCT_SP.
	|

Land_scarcity_indicator=
	min(1,ZIDZ(Land_availability,Land_demand_by_sector))
	~	
	~	This variable represents the ratio of available land resources to \
		Land_Demand, calculated as a value between 0 and 1. A value of 1 indicates \
		that land availability meets or exceeds demand, while a value closer to 0 \
		indicates a higher level of land scarcity, suggesting potential \
		constraints on agricultural and urban development. This indicator is \
		essential for assessing the impact of land scarcity on production \
		capabilities and economic growth.
	|

Water_demand_by_sector=
	Water_intensity*SUM (Expected_Real_Value_Added_by_sector[PRODUCTIVE_SECTORS!])
	~	
	~	This variable quantifies the total demand for water resources across \
		different sectors, derived from the Water_Intensity and the \
		Expected_Real_Value_Added (RVA). The equation captures the dependency of \
		production activities on water consumption relative to the expected \
		economic output. Analyzing water demand in this context allows the model \
		to evaluate the impact of water scarcity on production capacities and \
		overall economic performance.
	|

INITIAL_NPISH:INTERPOLATE::=
	0
	~	
	~		|

Compensation_of_employees=
	Real_Value_Added*Labour_share
	~	M$
	~	This variable calculates the total remuneration paid to workers, based on \
		the Real_Value_Added and the Labour_Share of the economy. It represents \
		the wage component in GDP and provides an alternative approach to \
		calculating economic output, complementing Gross_Operational_Surplus. Up \
		to 2021, it relies on historical data, while in later years it adjusts \
		based on the share of labor compensation expected under various scenarios. \
		This variable is essential for understanding the distribution of GDP \
		between labor and capital.
	|

Delayed_real_gdp_by_sector_1[PRODUCTIVE_SECTORS]= DELAY_FIXED (
	Real_Value_Added_by_sector[PRODUCTIVE_SECTORS] , TIME_STEP , 0)
	~	$
	~		|

Land_availability=
	826285
	~	km2
	~	This variable represents the total area of land resources available for \
		productive use in the economy, sourced from the Land Module. It includes \
		agricultural land, urban development areas, and other land not constrained \
		by environmental protections or regulations. This measure is essential for \
		assessing land scarcity and determining how much land can be allocated to \
		meet Land_Demand across various sectors.
	|

Land_demand_by_sector=
	Land_intensity*SUM (Expected_Real_Value_Added_by_sector[PRODUCTIVE_SECTORS!])
	~	
	~	This variable represents the total demand for land resources across \
		various sectors, calculated based on the Land_Intensity and the \
		Expected_Real_Value_Added (RVA). The equation reflects the relationship \
		between the expected output of different sectors and the amount of land \
		required for production. Understanding this demand is essential for \
		assessing how land scarcity influences economic activities and resource \
		allocation.
	|

Land_intensity=
	ZIDZ( 426285 , SUM(Delayed_real_gdp_by_sector_1[PRODUCTIVE_SECTORS!]))
	~	km2/$
	~	This variable measures the amount of land required for production \
		activities across various sectors. It is calculated based on the \
		consumption data sourced from the land module, reflecting how land \
		resources are utilized in agricultural and industrial processes. \
		Understanding land intensity is crucial for assessing land scarcity \
		impacts on production and overall economic activity.
	|

Water_scarcity_indicator=
	min(1,ZIDZ(Water_availability,Water_demand_by_sector))
	~	
	~	This variable quantifies the ratio of available water resources to \
		Water_Demand, expressed as a value between 0 and 1. A value of 1 signifies \
		sufficient water availability to meet demand, while a value closer to 0 \
		indicates increasing levels of water scarcity, which could limit \
		agricultural and industrial production. This indicator provides critical \
		insights into the effects of water scarcity on overall economic \
		performance and resource management.
	|

Water_availability=
	1.17187e+11
	~	m3
	~	This variable quantifies the total volume of water resources available for \
		use in the economy, derived from the Water Module. It includes surface \
		water (such as rivers, lakes, and reservoirs), groundwater, and renewable \
		water supplies accessible for agricultural, industrial, and domestic use. \
		Understanding available water is crucial for evaluating water scarcity and \
		its impact on meeting Water_Demand in different sectors.
	|

EXOGENOUS_SCARCITY_INDICATOR_0=
	1
	~	
	~		|

Labour_share=
	IF_THEN_ELSE(Time<=2021, EXOGENOUS_LABOUR_SHARE , EXPECTED_LABOUR_SHARE_SP )
	~	Dmnl
	~	This variable represents the proportion of Real_Value_Added allocated to \
		employee compensation, indicating the share of economic output distributed \
		as wages. It is essential for calculating Compensation_of_Employees, as it \
		determines the split between labor income and capital income in GDP. The \
		Labour_Share reflects income distribution trends within the economy and \
		can vary across scenarios, showing how shifts in policy or market dynamics \
		impact the share of GDP earned by workers.
	|

Water_intensity=
	ZIDZ( 1.07187e+11 , SUM(Delayed_real_gdp_by_sector_1[PRODUCTIVE_SECTORS!]))
	~	m3/$
	~	This variable quantifies the amount of water needed for production across \
		different sectors. It relies on consumption data from the water module to \
		capture the relationship between water use and production output. By \
		analyzing water intensity, the model can evaluate the effects of water \
		scarcity on production capabilities and resource allocation, ensuring a \
		comprehensive understanding of how limited water resources influence \
		economic performance.
	|

EXOGENOUS_GOVERNMENT_EXPENDITURE:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'GOVERNMENT_EXPENDITURE'\
		 )
	~	M$
	~	This variable captures historical government spending on public goods and \
		services up to 2020. It serves as a baseline for government expenditure, \
		reflecting past fiscal policies and budget allocations. This historical \
		value is used to understand the impact of government spending on overall \
		consumption and economic activity.
	|

SWITCH_SCARCITY_INDICATOR_0=
	0
	~	
	~	Transversal module SWITCH which can take two values:
		0: exogenous scarcity (no restrictions)
		1: endogenous scarcity
	|

Real_Value_Added=
	SUM (Real_Value_Added_by_sector[PRODUCTIVE_SECTORS!])
	~	M$
	~	This variable represents the actual economic output or real value added of \
		the economy, calculated by summing the Real_Value_Added_by_Sector across \
		all productive sectors. Each sector’s contribution is adjusted for \
		resource scarcity factors—water, energy, food, and labor—which \
		constrain output according to available resources. This aggregation \
		provides a realistic measure of total economic production, accounting for \
		the limitations imposed by essential resource shortages across the entire \
		economy.
	|

Millon_Dollars_to_Dollars=
	1e+06
	~	$/M$
	~	Unit conversion
	|

Gross_operational_surplus=
	Real_Value_Added-Compensation_of_employees
	~	M$
	~	This variable represents the profits or surplus generated by the \
		productive sectors after compensating employees, derived from the portion \
		of Real_Value_Added not allocated to wages. It forms the capital share of \
		GDP, providing another component of total economic output alongside \
		Compensation_of_Employees. Together, these variables offer an alternative \
		way to calculate GDP by summing returns to both labor and capital, \
		allowing insights into the income distribution within the economy.
	|

HISTORICAL_GDP:INTERPOLATE::=
	0
	~	M$
	~		|

Sector_share[PRODUCTIVE_SECTORS]=
	IF_THEN_ELSE(Time<=2020, EXOGENOUS_SECTOR_SHARE[PRODUCTIVE_SECTORS] , EXPECTED_SECTOR_SHARE_SP\
		[PRODUCTIVE_SECTORS] )
	~	Dmnl
	~	This variable represents the proportion of Expected_Real_Value_Added \
		attributed to each productive sector—Industry, Transport, Commercial, \
		and Agriculture, Forestry, and Fishing. Until 2021, the shares are \
		exogenously defined based on historical data. After 2021, they are \
		adjusted according to various scenario assumptions, allowing the model to \
		explore different future pathways in sectoral contributions to the \
		economy. This allocation enables accurate distribution of \
		Expected_Real_Value_Added across sectors, reflecting their relative \
		economic importance.
	|

EXTERNAL_COMPENSATION_OF_EMPLOYEES:INTERPOLATE::=
	0
	~	M$
	~		|

EXTERNAL_GROSS_OPERATIONAL_SURPLUS:INTERPOLATE::=
	0
	~	M$
	~		|

EXOGENOUS_SECTOR_SHARE[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'SECTOR_SHARE' )
	~	Dmnl
	~	This variable captures the historical shares of each productive sector in \
		the Expected_Real_Value_Added up to 2021. Defined by external data, it \
		represents the baseline distribution of economic value across sectors, \
		serving as a reference for past sectoral contributions. After 2021, this \
		share is replaced by Expected_Sector_Share, which adjusts to various \
		scenario assumptions.
	|

HISTORICAL_RVA_BY_SECTOR[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	0
	~	M$
	~		|

HISTORICAL_VALUE_ADDED_BY_SECTOR[PRODUCTIVE_SECTORS]:INTERPOLATE::=
	0
	~	M$
	~		|

Expected_Real_Value_Added_by_sector[PRODUCTIVE_SECTORS]=
	Expected_Real_Value_Added*Sector_share[PRODUCTIVE_SECTORS]
	~	M$
	~	This variable distributes the Expected_Real_Value_Added across individual \
		productive sectors—Industry, Transport, Commercial, and Agriculture, \
		Forestry, and Fishing—according to their specific shares. Up to 2021, \
		this allocation is based on the Exogenous_Sector_Share, with \
		Expected_Sector_Share applied afterward to allow for scenario-driven \
		adjustments. This breakdown gives a detailed view of sectoral \
		contributions to the economy, indicating how each sector’s value is \
		expected to evolve.
	|

PRODUCTIVE_SECTORS:
	INDUSTRY, TRANSPORT, COMMERCIAL, AGRICULTURE_FORESTRY_FISHING
	~	
	~		|

EXOGENOUS_NET_EXPORTS:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'TIME_ECO' , 'NET_EXPORTS' )
	~	M$
	~	This variable represents the difference between a country's exports and \
		imports, calculated as Exports - Imports. It reflects the contribution of \
		trade to the economy, where a positive value indicates a trade surplus and \
		a negative value indicates a trade deficit. Net_Exports is a key component \
		of Expected_GDP, as it captures the external demand for domestically \
		produced goods and services. This variable helps in understanding the \
		impact of trade on overall economic performance within the model.
	|

direct_electricity_CO2_emissions[ELEC_SUPPLIERS]=
	TI_for_ELEC[ELEC_SUPPLIERS]*CO2_EMISSION_FACTORS[ELEC_SUPPLIERS]*(1/GJ_to_MWh)
	~	kg/Year
	~	Carbon dioxide released directly into the atmosphere results from the \
		on-site combustion of fossil fuels (such as coal, oil, or natural gas) to \
		generate electricity. Emissions from biomass and other greenhouse gases \
		(GHGs) are not included in this measure.
	|

total_TI_for_ELEC=
	SUM(TI_for_ELEC[FOSSIL!])
	~	MWh/Year
	~	Total aggregate energy consumption by power plants to produce electricity.
	|

Million_dollar_to_dollar=
	10^6
	~	$/M$
	~		|

kilotonne_to_kg=
	10^6
	~	kg/Kilotonne
	~		|

TJ_to_J=
	10^-12
	~	TJ/J
	~		|

total_installed_capacity=
	SUM(fossil_installed[FOSSIL!])+SUM(RES_installed[RENEWABLES!])
	~	
	~	Evolution of total annual aggregate installed capacity.
	|

total_electricity_mix[ELEC_SUPPLIERS]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS] , (SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS\
		!])))
	~	
	~	The total or general electricity mix refers to the combination of energy \
		sources used to generate electricity in a country or region, including \
		both locally produced power and electricity imported from other countries. \
		This mix reflects the overall energy supply, considering all \
		sources—renewable and non-renewable—as well as the role of electricity \
		imports. The general electricity mix provides insight into a region’s \
		energy security, with a greater reliance on imports indicating higher \
		energy dependency.
	|

GJ_to_MWh=
	0.277778
	~	MWh/GJ
	~		|

RES_participation_in_mix=
	SUM( local_electricity_mix[RENEWABLES!] )
	~	
	~	The share of renewables in the indigenous electricity mix refers to the \
		percentage of electricity generated from renewable energy sources (such as \
		wind, solar, hydro, and biomass) within the region, excluding imports.
	|

f1_construction[RENEWABLES]=
	f1_planification_delay[RENEWABLES]+RES_INI_PLANIFICATION_DELAY[RENEWABLES]
	~	MW/Year
	~	Construction annual power flow by type of renewable technology.
	|

f1_construction_delay[PV]= DELAY_FIXED (
	 f1_construction[PV], RES_TIME_CONSTRUCTION[PV] , 0) ~~|
f1_construction_delay[WIND]= DELAY_FIXED (
	 f1_construction[WIND], RES_TIME_CONSTRUCTION[WIND] , 0) ~~|
f1_construction_delay[HYDRO]= DELAY_FIXED (
	 f1_construction[HYDRO], RES_TIME_CONSTRUCTION[HYDRO] , 0) ~~|
f1_construction_delay[BIOMASS_PP]= DELAY_FIXED (
	 f1_construction[BIOMASS_PP], RES_TIME_CONSTRUCTION[BIOMASS_PP] , 0)
	~	
	~	Programming auxiliary variable
	|

f1_decommision_delay[PV]= DELAY_FIXED (
	  f1_installation[PV], RES_LIFETIME[PV] , 0) ~~|
f1_decommision_delay[WIND]= DELAY_FIXED (
	  f1_installation[WIND], RES_LIFETIME[WIND] , 0) ~~|
f1_decommision_delay[HYDRO]= DELAY_FIXED (
	  f1_installation[HYDRO], RES_LIFETIME[HYDRO] , 0) ~~|
f1_decommision_delay[BIOMASS_PP]= DELAY_FIXED (
	  f1_installation[BIOMASS_PP], RES_LIFETIME[BIOMASS_PP] , 0)
	~	
	~	Programming auxiliary variable
	|

f1_installation[RENEWABLES]=
	f1_construction_delay[RENEWABLES]+RES_INI_CONSTRUCTION_DELAY[RENEWABLES]
	~	MW/Year
	~	Annual power installation flow by type of renewable technology.
	|

f1_planification_delay[PV]= DELAY_FIXED (
	 f1_effective_planned[PV], RES_TIME_PLAN[PV] , 0) ~~|
f1_planification_delay[WIND]= DELAY_FIXED (
	 f1_effective_planned[WIND], RES_TIME_PLAN[WIND] , 0) ~~|
f1_planification_delay[HYDRO]= DELAY_FIXED (
	f1_effective_planned[HYDRO], RES_TIME_PLAN[HYDRO] , 0) ~~|
f1_planification_delay[BIOMASS_PP]= DELAY_FIXED (
	 f1_effective_planned[BIOMASS_PP], RES_TIME_PLAN[BIOMASS_PP] , 0)
	~	
	~	Programming auxiliary variable
	|

RES_INI_TIME_DECOMMISION[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_lifetime_pv'\
		 ) ~~|
RES_INI_TIME_DECOMMISION[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_lifetime_wind'\
		 ) ~~|
RES_INI_TIME_DECOMMISION[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_lifetime_hydro'\
		 ) ~~|
RES_INI_TIME_DECOMMISION[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_lifetime_biomass_pp'\
		 )
	~	
	~	Programming auxiliary variable
	|

RES_INI_TIME_PLANIFICATION[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_pv'\
		 ) ~~|
RES_INI_TIME_PLANIFICATION[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_wind'\
		 ) ~~|
RES_INI_TIME_PLANIFICATION[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_hydro'\
		 ) ~~|
RES_INI_TIME_PLANIFICATION[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_plan_biomass_pp'\
		 )
	~	
	~	Programming auxiliary variable
	|

INI_RENEWABLE_PLANNED[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_planned_pv'\
		 ) ~~|
INI_RENEWABLE_PLANNED[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_planned_wind'\
		 ) ~~|
INI_RENEWABLE_PLANNED[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_planned_hydro'\
		 ) ~~|
INI_RENEWABLE_PLANNED[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_planned_biomass_pp'\
		 )
	~	
	~	Programming auxiliary variable
	|

RES_INI_PLANIFICATION_DELAY[PV]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[PV], RES_INI_TIME_PLANIFICATION[PV] ,\
		 0) ~~|
RES_INI_PLANIFICATION_DELAY[WIND]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[WIND], RES_INI_TIME_PLANIFICATION[WIND\
		] , 0) ~~|
RES_INI_PLANIFICATION_DELAY[HYDRO]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[HYDRO], RES_INI_TIME_PLANIFICATION[HYDRO\
		] , 0) ~~|
RES_INI_PLANIFICATION_DELAY[BIOMASS_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*INI_RENEWABLE_PLANNED[BIOMASS_PP], RES_INI_TIME_PLANIFICATION\
		[BIOMASS_PP] , 0)
	~	
	~	Programming auxiliary variable
	|

RES_INI_TIME_CONSTRUCTION[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_construction_pv'\
		 ) ~~|
RES_INI_TIME_CONSTRUCTION[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_construction_wind'\
		 ) ~~|
RES_INI_TIME_CONSTRUCTION[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_construction_hydro'\
		 ) ~~|
RES_INI_TIME_CONSTRUCTION[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_ini_time_construction_biomass_pp'\
		 )
	~	
	~	Programming auxiliary variable
	|

RES_construction[RENEWABLES]= INTEG (
	f1_construction[RENEWABLES]-f1_installation[RENEWABLES],
		RES_INI_CONSTRUCTION[RENEWABLES])
	~	MW
	~	Annualpower stock of renewable technologies under construction
	|

potential_degradation[RENEWABLES]=
	IF_THEN_ELSE(f1_effective_planned[RENEWABLES]+INI_RENEWABLE_PLANNED[RENEWABLES]>RES_potential\
		[RENEWABLES] , RES_potential[RENEWABLES
	], f1_effective_planned[RENEWABLES] + INI_RENEWABLE_PLANNED[RENEWABLES]*PULSE(INITIAL_TIME
	,1))
	~	MW/Year
	~	Flow of degradation of the region's renewable potential, by type of \
		renewable technology, as new power plants are built.
	|

RES_planned[RENEWABLES]= INTEG (
	f1_effective_planned[RENEWABLES]-f1_construction[RENEWABLES],
		INI_RENEWABLE_PLANNED[RENEWABLES])
	~	MW
	~	Annual planned power stock of renewable technologies
	|

RES_INI_CONSTRUCTION_DELAY[PV]= DELAY_FIXED (
	  PULSE(INITIAL_TIME, 1 )*RES_INI_CONSTRUCTION[PV], RES_INI_TIME_CONSTRUCTION[PV] ,
	 0) ~~|
RES_INI_CONSTRUCTION_DELAY[WIND]= DELAY_FIXED (
	  PULSE(INITIAL_TIME, 1 )*RES_INI_CONSTRUCTION[HYDRO], RES_INI_TIME_CONSTRUCTION[WIND\
		] ,
	 0) ~~|
RES_INI_CONSTRUCTION_DELAY[HYDRO]= DELAY_FIXED (
	  PULSE(INITIAL_TIME, 1 )*RES_INI_CONSTRUCTION[HYDRO], RES_INI_TIME_CONSTRUCTION[HYDRO\
		] ,
	 0) ~~|
RES_INI_CONSTRUCTION_DELAY[BIOMASS_PP]= DELAY_FIXED (
	  PULSE(INITIAL_TIME, 1 )*RES_INI_CONSTRUCTION[BIOMASS_PP], RES_INI_TIME_CONSTRUCTION\
		[BIOMASS_PP] ,
	 0)
	~	
	~	Programming auxiliary variable
	|

FOSSIL_INI_TIME_PLANIFICATION[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_time_plan_coal_pp'\
		 ) ~~|
FOSSIL_INI_TIME_PLANIFICATION[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_time_plan_gas_pp'\
		 ) ~~|
FOSSIL_INI_TIME_PLANIFICATION[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_time_plan_oil'\
		 )
	~	
	~	Programming auxiliary variable
	|

ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS]=
	ALLOCATE_BY_PRIORITY(electricity_supply[ELEC_SUPPLIERS],PRIORITIES_FOR_ALLOCATE_DEMAND_TO_TECHS\
		[ELEC_SUPPLIERS], ELMCOUNT
	(ELEC_SUPPLIERS) , WIDTH_FOR_ALLOCATE_DEMAND_TO_TECHS ,total_demand_of_ELEC[ELEC] )
	~	MWh/Year
	~	This "allocate" is used to compute the electricity generation mix based on \
		demand coverage priorities, the production capacity of installed plants \
		and demand.
	|

fossil_f1_construction[FOSSIL]=
	FOSSIL_INI_PLANIFICATION_DELAY[FOSSIL]+fossil_f1_planification_delay[FOSSIL]
	~	MW/Year
	~	Construction annual power flow by type of renewable technology.
	|

fossil_f1_decomision_delay[COAL_PP]= DELAY_FIXED (
	 fossil_f1_installation[COAL_PP], FOSSIL_LIFETIME[COAL_PP] , 0) ~~|
fossil_f1_decomision_delay[GAS_PP]= DELAY_FIXED (
	fossil_f1_installation[GAS_PP], FOSSIL_LIFETIME[GAS_PP] , 0) ~~|
fossil_f1_decomision_delay[OIL]= DELAY_FIXED (
	 fossil_f1_installation[OIL], FOSSIL_LIFETIME[OIL] , 0)
	~	
	~	Programming auxiliary variable
	|

FOSSIL_INI_PLANNED[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_planned_coal_pp'\
		 ) ~~|
FOSSIL_INI_PLANNED[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_planned_gas_pp'\
		 ) ~~|
FOSSIL_INI_PLANNED[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_planned_oil' )
	~	
	~	Programming auxiliary variable
	|

fossil_f1_installation[FOSSIL]=
	fossil_f1_construction_delay[FOSSIL] + FOSSIL_INI_CONSTRUCTION_DELAY[FOSSIL]
	~	MW/Year
	~	Annual power installation flow by type of renewable technology.
	|

fossil_f1_planification_delay[COAL_PP]= DELAY_FIXED (
	 fossil_f1_effective_planned[COAL_PP], FOSSIL_TIME_PLAN[COAL_PP] , 0) ~~|
fossil_f1_planification_delay[GAS_PP]= DELAY_FIXED (
	 fossil_f1_effective_planned[GAS_PP], FOSSIL_TIME_PLAN[GAS_PP] , 0) ~~|
fossil_f1_planification_delay[OIL]= DELAY_FIXED (
	 fossil_f1_effective_planned[OIL], FOSSIL_TIME_PLAN[OIL] , 0)
	~	
	~	Programming auxiliary variable
	|

FOSSIL_INI_TIME_DECOMMISION[COAL_PP]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_ini_lifetime_coal_pp'\
		 ) ~~|
FOSSIL_INI_TIME_DECOMMISION[GAS_PP]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_ini_lifetime_gas_pp'\
		 ) ~~|
FOSSIL_INI_TIME_DECOMMISION[OIL]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_ini_lifetime_oil' )
	~	
	~	Programming auxiliary variable
	|

ELEC_techs_supply_impose_mix[IMPORTS]=
	ELEC_techs_supply[IMPORTS] ~~|
ELEC_techs_supply_impose_mix[PV]=
	IF_THEN_ELSE( ELEC_techs_supply[PV]>MAX_PERCENTAGE_OF_PV_IN_MIX*total_demand_of_ELEC\
		[ELEC] , MAX_PERCENTAGE_OF_PV_IN_MIX*total_demand_of_ELEC
	[ELEC] , ELEC_techs_supply[PV] ) ~~|
ELEC_techs_supply_impose_mix[COAL_PP]=
	ELEC_techs_supply[COAL_PP] ~~|
ELEC_techs_supply_impose_mix[BIOMASS_PP]=
	ELEC_techs_supply[BIOMASS_PP] ~~|
ELEC_techs_supply_impose_mix[GAS_PP]=
	ELEC_techs_supply[GAS_PP] ~~|
ELEC_techs_supply_impose_mix[WIND]=
	IF_THEN_ELSE(ELEC_techs_supply[WIND]>MAX_PERCENTAGE_OF_WIND_IN_MIX*total_demand_of_ELEC\
		[ELEC], MAX_PERCENTAGE_OF_WIND_IN_MIX*total_demand_of_ELEC[ELEC] , ELEC_techs_supply\
		[WIND] ) ~~|
ELEC_techs_supply_impose_mix[HYDRO]=
	ELEC_techs_supply[HYDRO] ~~|
ELEC_techs_supply_impose_mix[OIL]=
	ELEC_techs_supply[OIL]
	~	MWh
	~	Maximum capacity to generate electricity by type of renewable and fossil technology, \
		with limitations due to the intermittency of renewables.
		IF_THEN_ELSE( \
		ELEC_techs_supply[PV]>MAX_PERCENTAGE_OF_PV_IN_MIX*(total_demand_of_ELEC[ELE\
		C]-elec_imports_delay[IMPORTS]) , \
		MAX_PERCENTAGE_OF_PV_IN_MIX*(total_demand_of_ELEC
		[ELEC]-elec_imports_delay[IMPORTS]) , ELEC_techs_supply[PV] )
	|

electricity_supply[ELEC_SUPPLIERS]=
	IF_THEN_ELSE(SWITCH_TO_LIMIT_THE_MIX=1, ELEC_techs_supply[ELEC_SUPPLIERS] , ELEC_techs_supply_impose_mix
	[ELEC_SUPPLIERS])
	~	MWh/Year
	~	Maximum capacity to generate electricity by type of renewable and fossil \
		technology after the technical limitations to renewables due to mix \
		security reasons regarding the intermittency of renewables.
	|

fossil_construction[FOSSIL]= INTEG (
	fossil_f1_construction[FOSSIL]-fossil_f1_installation[FOSSIL],
		FOSSIL_INI_CONSTRUCTION[FOSSIL])
	~	MW
	~	Annual power stock of fossil technologies under construction
	|

fossil_planned[FOSSIL]= INTEG (
	fossil_f1_effective_planned[FOSSIL]-fossil_f1_construction[FOSSIL],
		FOSSIL_INI_PLANNED[FOSSIL])
	~	MW
	~	Annual planned power stock of fossil technologies
	|

FOSSIL_INI_PLANIFICATION_DELAY[COAL_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_PLANNED[COAL_PP], FOSSIL_INI_TIME_PLANIFICATION[\
		COAL_PP] , 0) ~~|
FOSSIL_INI_PLANIFICATION_DELAY[GAS_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_PLANNED[GAS_PP], FOSSIL_INI_TIME_PLANIFICATION[GAS_PP\
		] , 0) ~~|
FOSSIL_INI_PLANIFICATION_DELAY[OIL]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_PLANNED[OIL], FOSSIL_INI_TIME_PLANIFICATION[OIL]\
		 , 0)
	~	
	~	Programming auxiliary variable
	|

FOSSIL_INI_CONSTRUCTION_DELAY[COAL_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_CONSTRUCTION[COAL_PP], FOSSIL_INI_TIME_CONSTRUCTION\
		[COAL_PP] , 0) ~~|
FOSSIL_INI_CONSTRUCTION_DELAY[GAS_PP]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_CONSTRUCTION[GAS_PP], FOSSIL_INI_TIME_CONSTRUCTION\
		[GAS_PP] , 0) ~~|
FOSSIL_INI_CONSTRUCTION_DELAY[OIL]= DELAY_FIXED (
	 PULSE(INITIAL_TIME, 1 )*FOSSIL_INI_CONSTRUCTION[OIL], FOSSIL_INI_TIME_CONSTRUCTION[\
		OIL] , 0)
	~	
	~	Programming auxiliary variable
	|

fossil_f1_construction_delay[COAL_PP]= DELAY_FIXED (
	 fossil_f1_construction[COAL_PP], FOSSIL_TIME_CONSTRUCTION[COAL_PP] , 0) ~~|
fossil_f1_construction_delay[GAS_PP]= DELAY_FIXED (
	 fossil_f1_construction[GAS_PP], FOSSIL_TIME_CONSTRUCTION[GAS_PP] , 0) ~~|
fossil_f1_construction_delay[OIL]= DELAY_FIXED (
	 fossil_f1_construction[OIL], FOSSIL_TIME_CONSTRUCTION[OIL] , 0)
	~	
	~	Programming auxiliary variable
	|

SWITCH_TO_LIMIT_THE_MIX=
	-1
	~	
	~	SWITCH = 1 (No limit is imposed on the electricity mix)
		
		SWITCH = -1 (Maximum percentages of renewables in the mix are imposed)
	|

FOSSIL_INI_TIME_CONSTRUCTION[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_time_construction_coal_pp'\
		 ) ~~|
FOSSIL_INI_TIME_CONSTRUCTION[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_time_construction_gas_pp'\
		 ) ~~|
FOSSIL_INI_TIME_CONSTRUCTION[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_time_construction_oil'\
		 )
	~	
	~	Programming auxiliary variable
	|

MAX_PERCENTAGE_OF_WIND_IN_MIX=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'MAX_PERCENTAGE_OF_WIND_IN_MIX'\
		 )
	~	
	~	Percentage of non-dispatchable renewables (like wind) that can be safely integrated \
		into an energy mix without compromising grid reliability. We have based \
		our quantification of this parameter on this study: \
		https://doi.org/10.1007/978-3-030-86884-0_16. "The highest share of \
		combined generation of wind and solar PV in the world on average in 2018 \
		was reached in Denmark, where about 50% of total annual generation came \
		from non-dispatchable sources, primarily wind (IEA Statistics 2020). This \
		high level was reached thanks to several factors, with high levels of \
		interconnection with the neighbouring countries playing a primary role.
		
		While solar PV is still limited as a share of total generation, with only \
		California passing the double-digit share (at around 14%) and Italy \
		ranking second in the world at around 8%, several countries have surpassed \
		the 15% threshold of wind share in their power mix, with some even \
		exceeding the 30% threshold. This is the case for several States in the \
		centre of the United States (EIA 2020) (with a high quality of wind \
		resources), while several countries in Europe produced more than 20% of \
		their mix from wind and solar PV combined (e.g. Ireland, Germany, Spain, \
		the United Kingdom), and a similar level is being approached in other \
		areas in Asia, such as in the Inner Mongolia province in China."
	|

MAX_PERCENTAGE_OF_PV_IN_MIX=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'MAX_PERCENTAGE_OF_PV_IN_MIX'\
		 )
	~	
	~	Percentage of non-dispatchable renewables (like solar) that can be safely integrated \
		into an energy mix without compromising grid reliability. We have based \
		our quantification of this parameter on this study: \
		https://doi.org/10.1007/978-3-030-86884-0_16. "The highest share of \
		combined generation of wind and solar PV in the world on average in 2018 \
		was reached in Denmark, where about 50% of total annual generation came \
		from non-dispatchable sources, primarily wind (IEA Statistics 2020). This \
		high level was reached thanks to several factors, with high levels of \
		interconnection with the neighbouring countries playing a primary role.
		
		While solar PV is still limited as a share of total generation, with only \
		California passing the double-digit share (at around 14%) and Italy \
		ranking second in the world at around 8%, several countries have surpassed \
		the 15% threshold of wind share in their power mix, with some even \
		exceeding the 30% threshold. This is the case for several States in the \
		centre of the United States (EIA 2020) (with a high quality of wind \
		resources), while several countries in Europe produced more than 20% of \
		their mix from wind and solar PV combined (e.g. Ireland, Germany, Spain, \
		the United Kingdom), and a similar level is being approached in other \
		areas in Asia, such as in the Inner Mongolia province in China."
	|

local_electricity_mix[IMPORTS]=
	0 ~~|
local_electricity_mix[PV]=
	ZIDZ(ALLOCATE_DEMAND_TO_TECHS[PV], (SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS!]) )\
		-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) ~~|
local_electricity_mix[COAL_PP]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[COAL_PP] ,(SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS\
		!]))-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) ~~|
local_electricity_mix[BIOMASS_PP]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[BIOMASS_PP] , (SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS\
		!]) )-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) ~~|
local_electricity_mix[GAS_PP]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[GAS_PP] , (SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS\
		!]))-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) ~~|
local_electricity_mix[WIND]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[WIND] , (SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS!\
		]))-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) ~~|
local_electricity_mix[HYDRO]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[HYDRO] ,(SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS!\
		]) )-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) ~~|
local_electricity_mix[OIL]=
	ZIDZ( ALLOCATE_DEMAND_TO_TECHS[OIL] , (SUM(ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS!]\
		)-ALLOCATE_DEMAND_TO_TECHS[IMPORTS]) )
	~	
	~	The indigenous electricity mix refers to the combination of energy sources \
		used to generate electricity within a country or region, excluding any \
		electricity imported from other countries. It includes all locally \
		produced power, derived from renewable sources and non-renewable sources.
	|

SWITCH_POWER_INSTALATION=
	2
	~	
	~	 1  = -
		
		-1 = EXOGENOUS POLICY + ALLOCATE WITH PRIORITIES
		
		 2  = EXOGENOUS POLICY BY TECHNOLOGY (WITHOUT ALLOCATE)
	|

INI_CF_PERIODICAL[PV]=
	0.255 ~~|
INI_CF_PERIODICAL[WIND]=
	0.28 ~~|
INI_CF_PERIODICAL[HYDRO]=
	0.57 ~~|
INI_CF_PERIODICAL[BIOMASS_PP]=
	0.47
	~	
	~	Initialization of the renewables capacity factor, if there is seasonality \
		of the resource.
	|

cumulative_CO2_emissions_from_electricity= INTEG (
	f_Co2_emissions,
		0)
	~	kg
	~	Cumulative direct CO2 emissions from electricity production and grid \
		electricity consumption based on the mix of the nation in which the case \
		study is located.
	|

CO2_EMISSION_FACTORS[ELEC_SUPPLIERS]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'CO2_EMISSION_FACTORS' )
	~	kg/GJ
	~	A CO2 emission factor is a coefficient that estimates the amount of carbon \
		dioxide emitted per unit of energy or activity. Typically expressed in \
		kilograms or tons of CO2 per unit (such as per megajoule of fuel burned or \
		per kilowatt-hour of electricity generated), it provides a standardized \
		way to calculate emissions based on fuel type, combustion efficiency, or \
		industrial activity. Source: Danish Energy Agency (CO2-factors)
	|

aux_delay2[RENEWABLES]= DELAY_FIXED (
	IF_THEN_ELSE( Time>INITIAL_TIME+1, aux_delay1[RENEWABLES], CF_ONE_PERIOD[RENEWABLES]\
		(Time) ), 1, INI_CF)
	~	
	~	Programming auxiliary variable
	|

J_to_MWh=
	3.6 *10^9
	~	J/MWh
	~	Unit conversion
	|

INI_CF=
	0
	~	
	~	Programming auxiliary variable
	|

aux_delay1[RENEWABLES]= DELAY_FIXED (
	aux_delay2[RENEWABLES], 1 , INI_CF)
	~	
	~	Programming auxiliary variable
	|

HOURS_IN_A_YEAR=
	8760
	~	h
	~		|

PRIORITIES_FOR_ALLOCATE_DEMAND_TO_TECHS[ELEC_SUPPLIERS]=
	GET_DIRECT_CONSTANTS('scenario_parameters.xlsx', 'energy' , 'ALLOCATE_DEMAND_TO_TECHS_PRIORITIES'\
		 )
	~	
	~	Priorities indicating which technologies should enter first to meet \
		electricity demand.
	|

FE:
	ELEC, LIQUIDS, SOLIDS, GAS, BIOMASS
	~	
	~		|

MAXIMUM_EXCHANGE_CAPACITY_OF_INTERCONNECTIONS[IMPORTS]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO' , 'MAXIMUM_EXCHANGE_CAPACITY_OF_INTERCONNECTIONS'\
		 )
	~	MWh/Year
	~	Annual electricity transmission capacity in the networks interconnecting \
		the study region with the outside environment.
	|

demand_of_ELEC_by_sector[SECTORS,ELEC]=
	FE_Demand[SECTORS,ELEC]
	~	MWh/Year
	~	Annual electricity demand disaggregated by sector.
	|

WIDTH_FOR_ALLOCATE_DEMAND_TO_TECHS=
	GET_DIRECT_CONSTANTS('scenario_parameters.xlsx', 'energy' , 'ALLOCATE_DEMAND_TO_TECHS_WIDTH'\
		 )
	~	
	~	Technical parameter of the allocate function influencing electricity \
		demand distribution.
	|

ELEC_SUPPLIERS:
	IMPORTS, PV, WIND, HYDRO, BIOMASS_PP, COAL_PP, GAS_PP, OIL
	~	
	~		|

ELEC_techs_supply[ENERGY_TECHS]=
	ELEC_generation[ENERGY_TECHS] ~~|
ELEC_techs_supply[IMPORTS]=
	MAXIMUM_EXCHANGE_CAPACITY_OF_INTERCONNECTIONS[IMPORTS]
	~	MWh/Year
	~	Maximum capacity to generate electricity by type of renewable and fossil \
		technology, also includes the maximum transmission capacity of the \
		electrical networks that interconnect the case study with the environment.
	|

FOSSIL_LIFETIME[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_lifetime_coal_pp' \
		) ~~|
FOSSIL_LIFETIME[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_lifetime_gas_pp' )\
		 ~~|
FOSSIL_LIFETIME[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_lifetime_oil' )
	~	
	~	The lifetime of a power plant refers to the total operational period \
		before it is decommissioned or replaced. Renewable energy plants, such as \
		wind and solar, typically have a shorter lifetime (around 20-30 years) \
		compared to fossil fuel plants, which can operate for 30-50 years or more \
		with proper maintenance.
	|

FOSSIL_TIME_CONSTRUCTION[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_time_construction_coal_pp'\
		 ) ~~|
FOSSIL_TIME_CONSTRUCTION[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_time_construction_gas_pp'\
		 ) ~~|
FOSSIL_TIME_CONSTRUCTION[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_time_construction_oil'\
		 )
	~	Year
	~	The construction period for a power plant refers to the time needed to \
		physically build and complete the facility before it becomes operational. \
		Renewable energy plants, like solar and wind, typically have shorter \
		construction periods compared to fossil fuel plants, due to their simpler \
		infrastructure and faster installation processes. However, hydroelectric \
		plants usually have longer construction periods, as they involve more \
		complex and large-scale civil works, including dams and reservoirs, which \
		require more time to build.
	|

fossil_decommisioned[FOSSIL]= INTEG (
	fossil_f1_decommision[FOSSIL],
		0)
	~	MW
	~	Annual stock of decommissioned plants
	|

fossil_f1_effective_planned[FOSSIL]=
	fossil_power_desire[FOSSIL]
	~	MW/Year
	~	Planned annual power flow by type of renewable technology.
	|

FOSSIL_INI_CONSTRUCTION[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_construction_coal_pp'\
		 ) ~~|
FOSSIL_INI_CONSTRUCTION[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_construction_gas_pp'\
		 ) ~~|
FOSSIL_INI_CONSTRUCTION[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_ini_construction_oil'\
		 )
	~	MW
	~	Programming auxiliary variable
	|

FOSSIL_INI_INSTALLED[COAL_PP]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_ini_installed_coal_pp'\
		 ) ~~|
FOSSIL_INI_INSTALLED[GAS_PP]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_ini_installed_gas_pp'\
		 ) ~~|
FOSSIL_INI_INSTALLED[OIL]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_ini_installed_oil' \
		)
	~	MW
	~	Programming auxiliary variable
	|

fossil_installed[FOSSIL]= INTEG (
	fossil_f1_installation[FOSSIL]-fossil_f1_decommision[FOSSIL],
		FOSSIL_INI_INSTALLED[FOSSIL])
	~	MW
	~	Annual power stock of fossil technologies installed,this is the rated \
		power that determines the electricity production, once the efficiency has \
		been applied.
	|

FOSSIL_CF[FOSSIL]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'FOSSIL_CAPACITY_FACTOR' )
	~	Dmnl
	~	The capacity factor of fossil fuel technologies is a measure of how often \
		a power plant operates at its maximum capacity over a given period, \
		typically expressed as a percentage. It reflects the ratio of the actual \
		energy produced to the maximum possible energy the plant could produce if \
		it ran at full capacity continuously. Fossil fuel plants, like coal, \
		natural gas, or oil-based facilities, typically have high capacity factors \
		(often between 50-90%) due to their ability to provide consistent, \
		on-demand power with relatively few interruptions. This high capacity \
		factor makes fossil fuels a reliable, dispatchable source of energy in the \
		grid.
	|

FOSSIL_BASE_EFFICIENCY[FOSSIL]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'fossil_base_efficiency' )
	~	Dmnl
	~	It is considered base efficiency as the maximum efficiency at which a \
		power plant starts in the model, when it has just been installed. This \
		efficiency has been calibrated by type of technology.
	|

FOSSIL_TIME_PLAN[COAL_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_time_plan_coal_pp'\
		 ) ~~|
FOSSIL_TIME_PLAN[GAS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_time_plan_gas_pp' \
		) ~~|
FOSSIL_TIME_PLAN[OIL]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'fossil_time_plan_oil' )
	~	Year
	~	The planning time for a power plant refers to the period required to \
		design and approve the facility before it construction. For renewable \
		energy plants, such as wind and solar, this planning time is typically \
		shorter than for fossil fuel plants.
	|

RES_installed[RENEWABLES]= INTEG (
	f1_installation[RENEWABLES]-f1_decommision[RENEWABLES],
		RES_INI_INSTALLED[RENEWABLES])
	~	MW
	~	Annual power stock of renewable technologies installed,this is the rated \
		power that determines the electricity production, once the efficiency has \
		been applied.
	|

RES_LIFETIME[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_lifetime_pv' ) ~~|
RES_LIFETIME[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_lifetime_wind' \
		) ~~|
RES_LIFETIME[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_lifetime_hydro'\
		 ) ~~|
RES_LIFETIME[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'renewable_lifetime_biomass_pp'\
		 )
	~	
	~	The lifetime of a power plant refers to the total operational period \
		before it is decommissioned or replaced. Renewable energy plants, such as \
		wind and solar, typically have a shorter lifetime (around 20-30 years) \
		compared to fossil fuel plants, which can operate for 30-50 years or more \
		with proper maintenance.
	|

f1_effective_planned[RENEWABLES]=
	IF_THEN_ELSE(  RES_power_desire[RENEWABLES]>RES_potential[RENEWABLES], RES_potential\
		[RENEWABLES] , RES_power_desire[RENEWABLES] )
	~	MW/Year
	~	Planned annual power flow by type of renewable technology.
	|

RES_decommisioned[RENEWABLES]= INTEG (
	f1_decommision[RENEWABLES],
		0)
	~	MW
	~	Annual stock of decommissioned plants
	|

RENEWABLES:
	PV, WIND, HYDRO, BIOMASS_PP
	~	
	~		|

RES_potential[RENEWABLES]= INTEG (
	potential_increase[RENEWABLES]-potential_degradation[RENEWABLES],
		RES_INI_POTENTIAL[RENEWABLES])
	~	MW
	~	Stock of maximum renewable potential in the region by type of renewable \
		technology.
	|

FOSSIL:
	COAL_PP, GAS_PP, OIL
	~	
	~		|

FE_con_CTE_cte=
	0
	~	
	~		|

potential_increase[RENEWABLES]=
	f1_decommision[RENEWABLES]
	~	MW/Year
	~	Recovery flow of the region's renewable potential, by type of renewable \
		technology, as power plants are decommissioned after the end of their \
		useful life.
	|

ENERGY_TECHS:
	PV, COAL_PP, BIOMASS_PP, GAS_PP, WIND, HYDRO, OIL
	~	
	~		|

RES_BASE_EFFICIENCY[RENEWABLES]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'base_efficiency' )
	~	
	~	It is considered base efficiency as the maximum efficiency at which a \
		power plant starts in the model, when it has just been installed. This \
		efficiency has been calibrated by type of technology.
	|

SECTORS:
	INDUSTRY, TRANSPORT, HOUSEHOLDS, COMMERCIAL, AGRICULTURE_FORESTRY_FISHING
	~	
	~		|

ENERGY_TYPES:
	ELEC, LIQUIDS, SOLIDS, GAS, BIOMASS
	~	
	~		|

PE:
	BIOMASS, GAS, LIQUIDS, SOLIDS
	~	
	~		|

CF_ONE_PERIOD[PV](
	(2015,0.2),(2015.25,0.2),(2015.5,0.2),(2015.75,0.2),(2016,0.2)) ~~|
CF_ONE_PERIOD[WIND](
	(2015,0.28),(2015.25,0.28),(2015.5,0.28),(2015.75,0.28),(2016,0.28)) ~~|
CF_ONE_PERIOD[HYDRO](
	(2015,0.37),(2015.25,0.37),(2015.5,0.37),(2015.75,0.37),(2016,0.37)) ~~|
CF_ONE_PERIOD[BIOMASS_PP](
	(2015,0.47),(2015.25,0.47),(2015.5,0.47),(2015.75,0.47),(2016,0.47)) ~~|
CF_ONE_PERIOD[IMPORTS](
	(2015,0),(2015.25,0),(2015.5,0),(2015.75,0),(2016,0)) ~~|
CF_ONE_PERIOD[COAL_PP](
	(2015,0),(2015.25,0),(2015.5,0),(2015.75,0),(2016,0)) ~~|
CF_ONE_PERIOD[GAS_PP](
	(2015,0),(2015.25,0),(2015.5,0),(2015.75,0),(2016,0)) ~~|
CF_ONE_PERIOD[OIL](
	(2015,0),(2015.25,0),(2015.5,0),(2015.75,0),(2016,0))
	~	
	~	CF PV summer -> 0,274
		CF PV autumn -> 0,255
		CF PV winter -> 0,205
		CF PV spring -> 0,257
	|

Energia_generada_acumulada_CF_cte= INTEG (
	VAR,
		0)
	~	
	~		|

CF_CTE=
	0.5
	~	
	~		|

VAR=
	FE_con_CTE_cte
	~	
	~		|

LEAKS_FROM_NATURAL_GAS_PIPELINES:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO' , 'GAS_LOSSES_EVOLUTION'\
		 )
	~	Dmnl
	~	Gas distribution losses in pipelines. This parameter increases local \
		primary energy consumption.
	|

RES_INI_CONSTRUCTION[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_construction_pv' ) ~~|
RES_INI_CONSTRUCTION[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_construction_wind' ) ~~|
RES_INI_CONSTRUCTION[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_construction_hydro' )\
		 ~~|
RES_INI_CONSTRUCTION[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_construction_biomass_pp'\
		 )
	~	MW
	~	Programming auxiliary variable
	|

RES_INI_POTENTIAL[RENEWABLES]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'energy' , 'ini_potential' )
	~	MW
	~	Renewable potential in the region by type of renewable technology in the \
		initial year of simulation.
	|

RES_INI_INSTALLED[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_installed_pv' ) ~~|
RES_INI_INSTALLED[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_installed_wind' ) ~~|
RES_INI_INSTALLED[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_installed_hydro' ) ~~|
RES_INI_INSTALLED[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'ini_installed_biomass_pp'\
		 )
	~	MW
	~	Programming auxiliary variable
	|

RES_TIME_PLAN[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_plan_pv' ) ~~|
RES_TIME_PLAN[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_plan_hydro' ) ~~|
RES_TIME_PLAN[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_plan_hydro' ) ~~|
RES_TIME_PLAN[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_plan_biomass_pp' )
	~	Year
	~	The planning time for a power plant refers to the period required to \
		design and approve the facility before it construction. For renewable \
		energy plants, such as wind and solar, this planning time is typically \
		shorter than for fossil fuel plants.
	|

RES_TIME_CONSTRUCTION[PV]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_construction_pv' ) ~~|
RES_TIME_CONSTRUCTION[WIND]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_construction_wind' )\
		 ~~|
RES_TIME_CONSTRUCTION[HYDRO]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_construction_hydro' \
		) ~~|
RES_TIME_CONSTRUCTION[BIOMASS_PP]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'energy' , 'time_construction_biomass_pp'\
		 )
	~	Year
	~	The construction period for a power plant refers to the time needed to \
		physically build and complete the facility before it becomes operational. \
		Renewable energy plants, like solar and wind, typically have shorter \
		construction periods compared to fossil fuel plants, due to their simpler \
		infrastructure and faster installation processes. However, hydroelectric \
		plants usually have longer construction periods, as they involve more \
		complex and large-scale civil works, including dams and reservoirs, which \
		require more time to build.
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL_TIME  = 2050
	~	Year
	~	The final time for the simulation.
	|

INITIAL_TIME  = 2015
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME_STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME_STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

