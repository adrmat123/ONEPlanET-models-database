	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_HOUSEHOLDS_ELECTRIFICATION'\
		 ) ~~|
FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION[COMMERCIAL,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_ELECTRIFICATION_COMMERCIAL'\
		 ) ~~|
FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION[AGRICULTURE_FORESTRY_FISHING,FE]:INTERPOLATE:\
		:=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_ELECTRIFICATION_AGRICULTURE'\
		 )
	~	J/$
	~	Energy intensity is a measure of the amount of energy used to produce a unit of \
		output or service in a given sector. It reflects the energy efficiency of \
		that sector: lower energy intensity means less energy is required, \
		indicating higher efficiency.
		
		In this context, the energy intensities of various sectors are analyzed, \
		specifically characterized for the local case and by type of final energy \
		used. For households, a pseudo energy intensity has been calculated based \
		on consumption patterns, offering an approximate view of their energy \
		usage efficiency.Intensities are subject to future scenarios that project \
		the level of development of the sectors and improvements in their \
		efficiency.
	|

POLICY_FE_SUBSTITUTION[PRODUCTIVE_SECTORS,FE]=
	IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=0, FE_INTENSITIES_SECTORS_CURRENT_TRENDS\
		[PRODUCTIVE_SECTORS,FE] , IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=1, FE_INTENSITIES_SECTORS_CURRENT_TRENDS\
		[PRODUCTIVE_SECTORS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=2 , \
		FE_INTENSITIES_SECTORS_CURRENT_TRENDS[PRODUCTIVE_SECTORS,FE] , IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION\
		=3 , FE_INTENSITIES_SECTORS_CURRENT_TRENDS[PRODUCTIVE_SECTORS,FE], IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION\
		=4, FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION[PRODUCTIVE_SECTORS,FE], IF_THEN_ELSE\
		( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=5, FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION\
		[PRODUCTIVE_SECTORS,FE], IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=6, FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION\
		[PRODUCTIVE_SECTORS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=7 , \
		FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION[PRODUCTIVE_SECTORS,FE] , IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION\
		=8, FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION[PRODUCTIVE_SECTORS,FE], IF_THEN_ELSE\
		(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=9,FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION\
		[PRODUCTIVE_SECTORS,FE], FE_INTENSITIES_SECTORS_USER_DEFINED[PRODUCTIVE_SECTORS,FE]\
		 ) ) ) ) ) ) ) ) ) ) ~~|
POLICY_FE_SUBSTITUTION[HOUSEHOLDS,FE]=
	IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=0, FE_INTENSITIES_SECTORS_CURRENT_TRENDS\
		[HOUSEHOLDS,FE] , IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=1, FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION\
		[HOUSEHOLDS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=2 , FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION\
		[HOUSEHOLDS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=3, FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION\
		[HOUSEHOLDS,FE] , IF_THEN_ELSE(SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=4, FE_INTENSITIES_SECTORS_CURRENT_TRENDS\
		[HOUSEHOLDS,FE] , IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=5 , FE_INTENSITIES_SECTORS_CURRENT_TRENDS\
		[HOUSEHOLDS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=6 , FE_INTENSITIES_SECTORS_CURRENT_TRENDS\
		[HOUSEHOLDS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=7 ,FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION\
		[HOUSEHOLDS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=8 , FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION\
		[HOUSEHOLDS,FE], IF_THEN_ELSE( SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=9 , FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION\
		[HOUSEHOLDS,FE], FE_INTENSITIES_SECTORS_USER_DEFINED[HOUSEHOLDS,FE] ) ) ) ) ) ) ) )\
		 ) )
	~	
	~		|

FE_Demand[PRODUCTIVE_SECTORS,FE]=
	Expected_Real_Value_Added_by_sector[PRODUCTIVE_SECTORS]*(
	1/J_to_MWh)*POLICY_FE_SUBSTITUTION[PRODUCTIVE_SECTORS,FE]*Millon_Dollars_to_Dollars ~~|
FE_Demand[HOUSEHOLDS,FE]=
	HH_Consumption*(1/J_to_MWh)*Millon_Dollars_to_Dollars * POLICY_FE_SUBSTITUTION[HOUSEHOLDS\
		,FE]
	~	MWh
	~	Final energy refers to the total energy consumed by end users, including \
		households, industries, and services, after it has been converted from \
		primary energy sources (like oil, gas, or renewables) into usable forms \
		(such as electricity, heat, or fuel). In this model, final energy \
		consumption is calculated endogenously, meaning it is determined within \
		the model based on economic growth projections. This calculation is done \
		with a high level of sectoral disaggregation, allowing detailed insights \
		into energy use across sectors and by specific types of final energy.
	|

FE_INTENSITIES_SECTORS_USER_DEFINED[INDUSTRY,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_USER_DEFINED_INDUSTRY'\
		 ) ~~|
FE_INTENSITIES_SECTORS_USER_DEFINED[TRANSPORT,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO', 'FE_INTENSITIES_PRODUCTIVE_SECTORS_USER_DEFINED_TRANSPORT'\
		 ) ~~|
FE_INTENSITIES_SECTORS_USER_DEFINED[HOUSEHOLDS,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO', 'FE_INTENSITIES_HOUSEHOLDS_USER_DEFINED'\
		 ) ~~|
FE_INTENSITIES_SECTORS_USER_DEFINED[COMMERCIAL,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO', 'FE_INTENSITIES_PRODUCTIVE_SECTORS_USER_DEFINED_COMMERCIAL'\
		 ) ~~|
FE_INTENSITIES_SECTORS_USER_DEFINED[AGRICULTURE_FORESTRY_FISHING,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'energy', 'TIME_SCENARIO', 'FE_INTENSITIES_PRODUCTIVE_SECTORS_USER_DEFINED_AGRICULTURE'\
		 )
	~	J/$
	~	Energy intensity is a measure of the amount of energy used to produce a unit of \
		output or service in a given sector. It reflects the energy efficiency of \
		that sector: lower energy intensity means less energy is required, \
		indicating higher efficiency.
		
		In this context, the energy intensities of various sectors are analyzed, \
		specifically characterized for the local case and by type of final energy \
		used. For households, a pseudo energy intensity has been calculated based \
		on consumption patterns, offering an approximate view of their energy \
		usage efficiency.Intensities are subject to future scenarios that project \
		the level of development of the sectors and improvements in their \
		efficiency.
	|

Energy_demand[PRODUCTIVE_SECTORS,FE]=
	FE_INTENSITIES_SECTORS_USER_DEFINED[PRODUCTIVE_SECTORS,FE]*Million_dollar_to_dollar*\
		Expected_Real_Value_Added_by_sector[PRODUCTIVE_SECTORS
	]
	~	
	~		|

FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION[INDUSTRY,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_LOW_ELECTRIFICATION_INDUSTRY'\
		 ) ~~|
FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION[TRANSPORT,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_LOW_ELECTRIFICATION_TRANSPORT'\
		 ) ~~|
