		 )
	~	
	~		|

total_demand_of_ELEC[ELEC]=
	ZIDZ( SUM(demand_of_ELEC_by_sector[SECTORS!,ELEC]) , POLICY_ELECTRICITY_DISTRIBUTION_LOSSES\
		)
	~	MWh/Year
	~	Total aggregate annual electricity demand.
	|

FE_INTENSITIES_SECTORS_CURRENT_TRENDS[INDUSTRY,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_CURRENT_TRENDS_INDUSTRY'\
		 ) ~~|
FE_INTENSITIES_SECTORS_CURRENT_TRENDS[TRANSPORT,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_CURRENT_TRENDS_TRANSPORT'\
		 ) ~~|
FE_INTENSITIES_SECTORS_CURRENT_TRENDS[HOUSEHOLDS,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_HOUSEHOLDS_CURRENT_TRENDS'\
		 ) ~~|
FE_INTENSITIES_SECTORS_CURRENT_TRENDS[COMMERCIAL,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_CURRENT_TRENDS_COMMERCIAL'\
		 ) ~~|
FE_INTENSITIES_SECTORS_CURRENT_TRENDS[AGRICULTURE_FORESTRY_FISHING,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_CURRENT_TRENDS_AGRICULTURE'\
		 )
	~	J/$
	~	Energy intensity is a measure of the amount of energy used to produce a unit of \
		output or service in a given sector. It reflects the energy efficiency of \
		that sector: lower energy intensity means less energy is required, \
		indicating higher efficiency.
		
		In this context, the energy intensities of various sectors are analyzed, \
		specifically characterized for the local case and by type of final energy \
		used. For households, a pseudo energy intensity has been calculated based \
		on consumption patterns, offering an approximate view of their energy \
		usage efficiency.Intensities are subject to future scenarios that project \
		the level of development of the sectors and improvements in their \
		efficiency.
	|

FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION[INDUSTRY,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_ELECTRIFICATION_INDUSTRY'\
		 ) ~~|
FE_INTENSITIES_SECTORS_HIGH_ELECTRIFICATION[TRANSPORT,FE]:INTERPOLATE::=
