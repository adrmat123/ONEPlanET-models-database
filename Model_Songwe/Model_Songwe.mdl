RVA_in_Dollar_Indust=
	0
	~	
	~		|

water_intensity_agriculture=
	agri_water_use/RVA_Agriculture_Dollar
	~	m3/$
	~	Agricultural water use per unit of agricultural value added.
	|

Domestic_Water_Intensity=
	Household_Consumption_in_Dollar/total_domestic_water_use
	~	$/m3
	~	Household consumption per unit of domestic water use.
	|

Agriculture_Water_Demand=
	IF_THEN_ELSE(Time>=2021, Average_Water_Intensity_Agriculture*RVA_Agriculture_Dollar \
		, agri_water_use )
	~	
	~		|

RVA_Agriculture_Dollar=
	RVA_Agriculture*UNIT_MILLION_DOLLAR_TO_DOLLAR
	~	$
	~	Real value added in agriculture (USD)
	|

Energy_Indicators=
	0
	~	
	~		|

Average_Water_Intensity_Agriculture=
	0.300194
	~	
	~	Average water intensity (m³ per million dollars of value added). \
		Calibrated from observed data (2015–2020).
	|

UNIT_MILLION_DOLLAR_TO_DOLLAR=
	1e+06
	~	
	~	Unit conversion: 1 million USD → USD.
	|

Average_Domestic_Water_Intensity=
	11
	~	
	~	Average water intensity (m³ per million dollars of value added). \
		Calibrated from observed data (2015–2020).
	|

RVA_in_dollar_agri=
	0
	~	$
	~		|

Household_Consumption_in_Dollar=
	HH_Consumption*UNIT_MILLION_DOLLAR_TO_DOLLAR
	~	$
	~		|

RVA_Agriculture=
	Real_Value_Added_by_sector[AGRICULTURE_FORESTRY_FISHING]
	~	M$
	~		|

Domestic_Water_Demand=
	IF_THEN_ELSE(Time>=2021, Average_Domestic_Water_Intensity*Household_Consumption_in_Dollar\
		 , total_domestic_water_use )
	~	
	~		|

self_sufficiency_index[LAND_PRODUCTS_I]=
	IF_THEN_ELSE(land_products_demanded_for_food[LAND_PRODUCTS_I] > 0,
	    MAX(0, min(1, land_products_available_from_croplands[LAND_PRODUCTS_I] / land_products_demanded_for_food\
		[LAND_PRODUCTS_I])),
	    1
	  )
	~	Dmnl
	~		|

land_products_demanded_per_capita[LAND_PRODUCTS_I]=
	land_products_demanded_for_food[LAND_PRODUCTS_I]/Total_population
	~	t/(person*Year)
	~		|

Food_Self_Sufficiency=
	0
	~	
	~		|

land_products_available_per_capita[LAND_PRODUCTS_I]=
	land_products_available_from_croplands[LAND_PRODUCTS_I]/Total_population
	~	t/(person*Year)
	~		|

