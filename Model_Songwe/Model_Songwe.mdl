	INITIAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS_MP[LANDS_I,GRASSLAND] ~~|
share_of_land_use_changes_from_others_up[LANDS_I,WETLAND]=
	INITIAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS_MP[LANDS_I,WETLAND] ~~|
share_of_land_use_changes_from_others_up[LANDS_I,URBAN_LAND]=
	INITIAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS_MP[LANDS_I,URBAN_LAND] ~~|
share_of_land_use_changes_from_others_up[LANDS_I,WATERBODIES]=
	INITIAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS_MP[LANDS_I,WATERBODIES] ~~|
