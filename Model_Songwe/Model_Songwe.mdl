{UTF-8}
WEF_water_indicator=
	IF_THEN_ELSE(Switch_P2_Build_new_dam=0, 1-ZIDZ((total_water_output-MIN_TOTAL_WATER_OUTPUT\
		),(MAX_TOTAL_WATER_OUTPUT-MIN_TOTAL_WATER_OUTPUT)), 1-ZIDZ((total_water_output-MIN_TOTAL_WATER_OUTPUT\
		),(MAX_TOTAL_WATER_OUTPUT-MIN_TOTAL_WATER_OUTPUT))+0.05)
	~	
	~		|

GDP_MEDIO:=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'time_GDP' , 'GDP_med' )
	~	
	~		|

MIN_TOTAL_FOOD_PRODUCED=
	4.6*10^9
	~	t/Year
	~		|

WEF_economy_indicator=
	IF_THEN_ELSE(SWITCH_POPULATION=0,ZIDZ((GDP_MEDIO-GDP_per_capita_min), (GDP_per_capita_max\
		-GDP_per_capita_min)),ZIDZ((GDP_per_capita-GDP_per_capita_min), (GDP_per_capita_max\
		-GDP_per_capita_min)))
	~	
	~		|

stress=
	total_water_output/total_water_available
	~	
	~		|

WEF_land_indicator=
	ZIDZ( ("total_forest_area-world"-MIN_TOTAL_FOREST) , (MAX_TOTAL_FOREST-MIN_TOTAL_FOREST\
		) )
	~	
	~		|

sum_total_food=
	SUM(total_food_produced[LAND_PRODUCTS_I!])
	~	t/Year
	~		|

MIN_TOTAL_WATER_OUTPUT=
	450*10^6
	~	
	~		|

MIN_TOTAL_FOREST=
	175000
	~	
	~		|

MAX_TOTAL_FOOD_PRODUCED=
	5.5*10^9
	~	t/Year
	~		|

MAX_TOTAL_FOREST=
	177000
	~	
	~		|

GDP_per_capita_min:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'time_GDP' , 'GDP_min' )
	~	
	~		|

GDP_per_capita_max:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx' , 'economy' , 'time_GDP' , 'GDP_max' )
	~	
	~		|

WEF_food_indicator=
	ZIDZ((sum_total_food-MIN_TOTAL_FOOD_PRODUCED), (MAX_TOTAL_FOOD_PRODUCED-MIN_TOTAL_FOOD_PRODUCED\
		) )
	~	
	~		|

MAX_TOTAL_WATER_OUTPUT=
	600*10^6
	~	
	~	Maximum water output (water demand) obtained under the most demanding \
		scenario (P2, P3 & P4 = off, P1 = on, population = endogenous)
	|

POLICY_NEW_POWER_DESIRE_BY_TECHNOLOGY[ENERGY_TECHS]=
	IF_THEN_ELSE(SELECT_PLANIFICATION_OF_POWER_DESIRE_BY_TECH_MODE = 0, POWER_DESIRE_BY_TECH_CURRENT_TRENDS\
		[ENERGY_TECHS] , 
	IF_THEN_ELSE(SELECT_PLANIFICATION_OF_POWER_DESIRE_BY_TECH_MODE=1, POWER_DESIRE_BY_TECH_LOW_EXPANSION\
		[ENERGY_TECHS],IF_THEN_ELSE(SELECT_PLANIFICATION_OF_POWER_DESIRE_BY_TECH_MODE=2, POWER_DESIRE_BY_TECH_MED_EXPANSION\
		[ENERGY_TECHS], IF_THEN_ELSE(PLANIFICATION_OF_POWER_DESIRE_BY_TECH_USER_DEFINED_SCENARIO\
		[ENERGY_TECHS]=3, POWER_DESIRE_BY_TECH_RES_EXPANSION[ENERGY_TECHS],
	 PLANIFICATION_OF_POWER_DESIRE_BY_TECH_USER_DEFINED_SCENARIO[ENERGY_TECHS] ) )))
	~	MW/Year
	~	Exogenous policy for power capacity installation in the case study to generate \
		electricity.
		BAU      -> ENERGY_INSTALLATION_BAU
		POLICY 1 -> ENERGY_INSTALLATION_RES_NO_COAL
	|

CURRENT_TRENDS_DISTRIBUTION_ELECTRICITY_LOSSES:=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS', 'CURRENT_TRENDS_DISTRIBUTION_ELECTRICITY_LOSSES'\
		 )
	~	
	~		|

POWER_DESIRE_BY_TECH_MED_EXPANSION[ENERGY_TECHS]:=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'POWER_DESIRE_BY_TECH_MED'\
		 )
	~	
	~		|

POWER_DESIRE_BY_TECH_LOW_EXPANSION[ENERGY_TECHS]:=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'POWER_DESIRE_BY_TECH_LOW'\
		 )
	~	
	~		|

POLICY_ELECTRICITY_DISTRIBUTION_LOSSES=
	IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES=0, CURRENT_TRENDS_DISTRIBUTION_ELECTRICITY_LOSSES\
		 , IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES
	=1, HIGH_DISTRIBUTION_ELECTRICITY_LOSSES , IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES\
		=2, MEDIUM_DISTRIBUTION_ELECTRICITY_LOSSES, IF_THEN_ELSE(SELECT_ELECTRICITY_DISTRIBUTION_LOSSES\
		=3, LOW_DISTRIBUTION_ELECTRICITY_LOSSES, USER_DEFINED_DISTRIBUTION_ELECTRICITY_LOSSES\
		 ) ) ))
	~	
	~		|

"To_see_more_specific_indicators_related_to_the_energy_module,_it_is_recommended_to_go_to_the_energy_view_and_display_the_variables_in_blue."\
		= INTEG (
	0,
		0)
	~	
	~		|

Energy=
	0
	~	
	~		|

Socioeconomy=
	0
	~	
	~		|

"To_see_more_specific_indicators_related_to_energy,_it_is_recommended_to_go_to_the_energy_view_and_display_the_variables_in_blue."\
		=
	0
	~	
