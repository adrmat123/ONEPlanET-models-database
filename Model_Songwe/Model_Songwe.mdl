		 )
	~	Dmnl
	~		|

SHARE_REST_N2O_MANURE_MANAGEMENT_EMISSIONS=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'SHARE_REST_N2O_MANURE_MANAGEMENT_EMISSIONS'\
		 )
	~	Dmnl
	~		|

