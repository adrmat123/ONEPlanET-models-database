land_products_demanded_for_food_before_losses[LAND_PRODUCTS_I]=
	AGROFOOD_TRANSFORM_MATRIX[CEREALS_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[CEREALS_DIET
	] + 
	AGROFOOD_TRANSFORM_MATRIX[TUBERS_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[TUBERS_DIET
	] + 
	AGROFOOD_TRANSFORM_MATRIX[PULSES_LEGUMES_NUTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[
	PULSES_LEGUMES_NUTS] + 
	AGROFOOD_TRANSFORM_MATRIX[FRUITS_VEGETABLES_DIET,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FRUITS_VEGETABLES_DIET] + 
	AGROFOOD_TRANSFORM_MATRIX[FATS_VEGETAL,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FATS_VEGETAL
	] + 
	AGROFOOD_TRANSFORM_MATRIX[FATS_ANIMAL,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[FATS_ANIMAL
	] + 
	AGROFOOD_TRANSFORM_MATRIX[DAIRY,LAND_PRODUCTS_I]*food_demanded_from_land_products[DAIRY\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[EGGS,LAND_PRODUCTS_I]*food_demanded_from_land_products[EGGS\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[MEAT_RUMINANTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[MEAT_RUMINANTS
	] + 
	AGROFOOD_TRANSFORM_MATRIX[MEAT_MONOGASTRIC,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[MEAT_MONOGASTRIC
	] + 
	AGROFOOD_TRANSFORM_MATRIX[FISH,LAND_PRODUCTS_I]*food_demanded_from_land_products[FISH\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[SUGARS,LAND_PRODUCTS_I]*food_demanded_from_land_products[SUGARS\
		] + 
	AGROFOOD_TRANSFORM_MATRIX[BEVERAGES,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[BEVERAGES]
	 + 
	AGROFOOD_TRANSFORM_MATRIX[STIMULANTS,LAND_PRODUCTS_I]*food_demanded_from_land_products\
		[STIMULANTS
	]
	~	t/Year
	~		|

