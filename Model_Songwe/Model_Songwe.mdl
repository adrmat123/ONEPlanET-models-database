	0 ~~|
trends_of_land_use_changes[FOREST_PLANTATIONS]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[FOREST_PLANTATIONS
	] , 
	
	TRENDS_OF_LAND_USE_DEMAND[FOREST_PLANTATIONS]) ~~|
trends_of_land_use_changes[SHRUBLAND]=
	0 ~~|
trends_of_land_use_changes[GRASSLAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[GRASSLAND] ,
	
	
	TRENDS_OF_LAND_USE_DEMAND[GRASSLAND]) ~~|
trends_of_land_use_changes[WETLAND]=
	0 ~~|
trends_of_land_use_changes[URBAN_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[URBAN_LAND] , 
	
	
	TRENDS_OF_LAND_USE_DEMAND[URBAN_LAND]) ~~|
trends_of_land_use_changes[ WATERBODIES]=
	0 ~~|
trends_of_land_use_changes[OTHER_LAND]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE,HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[OTHER_LAND
	], TRENDS_OF_LAND_USE_DEMAND[OTHER_LAND])
	~	ha/Year
	~		|

