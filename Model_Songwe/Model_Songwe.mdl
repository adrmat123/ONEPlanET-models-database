HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,FOREST_PLANTATIONS]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'INITIAL_SHARE_OF_FOREST_PLANTATIONS_FROM_OTHERS_BY_REGION'\
		 ) ~~|
HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,SHRUBLAND]=
