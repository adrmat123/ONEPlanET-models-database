	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'INITIAL_LAND_BY_REGION_2015*'\
		 )
	~	ha
	~		|

INITIAL_MEAT_OBTAINED_FROM_GRASSLANDS=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'MEAT_GRASSLANDS*' )
	~	tonne/Year
	~		|

plantations_harvesting=
	0
	~	
	~		|

diet[FOODS_I]=
	DIETS_INITIAL[FOODS_I]
	~	kg/(Year*person)
	~		|

DIETS_INITIAL[FOODS_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'DIETS_INITIAL')
	~	kg/(Year*person)
	~		|

growth_of_plantation_area=
	IF_THEN_ELSE(land_use_changes_productive_uses[FOREST_PLANTATIONS]>0, land_use_changes_productive_uses\
		[FOREST_PLANTATIONS], 0)
	~	ha/Year
	~		|

UNIT_CONVERSION_Mt_t=
	1/UNIT_CONVERSION_t_Mt
	~	Mt/t
	~		|

SWITCH_CROPLAND_IRRIGATED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_CROPLAND_IRRIGATED_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

UNIT_CONVERSION_N2ON_N2O=
	44/28
	~	N2O/N2ON
	~	N2O-N_TO_N2O
		N2O = N2O-N ? 44/28 (IPCC)
	|

irrigated_crops_available_by_region[LAND_PRODUCTS_I]=
	area_of_irrigated_crops_0[LAND_PRODUCTS_I]*yields_of_irrigated_crops[LAND_PRODUCTS_I
	]
	~	t/Year
	~		|

N2O_emissions_fertilizers=
	(N_application*FACTOR_EMISSION_N_APPLICATION + N_application*N_FRACTION_VOLATILISES*\
		FACTOR_EMISSION_N_APPLICATION_INDIRECT
	)*UNIT_CONVERSION_N2ON_N2O*UNIT_CONVERSION_t_kg* (1/UNIT_CONVERSION_t_Mt)
	~	Mt_N2O/Year
	~		|

