	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_LOW_ELECTRIFICATION_COMMERCIAL'\
		 ) ~~|
FE_INTENSITIES_SECTORS_LOW_ELECTRIFICATION[AGRICULTURE_FORESTRY_FISHING,FE]:INTERPOLATE:\
		:=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_LOW_ELECTRIFICATION_AGRICULTURE'\
		 )
	~	J/$
	~	Energy intensity is a measure of the amount of energy used to produce a unit of \
		output or service in a given sector. It reflects the energy efficiency of \
		that sector: lower energy intensity means less energy is required, \
		indicating higher efficiency.
		
		In this context, the energy intensities of various sectors are analyzed, \
		specifically characterized for the local case and by type of final energy \
		used. For households, a pseudo energy intensity has been calculated based \
		on consumption patterns, offering an approximate view of their energy \
		usage efficiency.Intensities are subject to future scenarios that project \
		the level of development of the sectors and improvements in their \
		efficiency.
	|

FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION[INDUSTRY,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_MEDIUM_ELECTRIFICATION_INDUSTRY'\
		 ) ~~|
FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION[TRANSPORT,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_MEDIUM_ELECTRIFICATION_TRANSPORT'\
		 ) ~~|
FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION[HOUSEHOLDS,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_HOUSEHOLDS_MEDIUM_ELECTRIFICATION'\
		 ) ~~|
FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION[COMMERCIAL,FE]:INTERPOLATE::=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_MEDIUM_ELECTRIFICATION_COMMERCIAL'\
		 ) ~~|
FE_INTENSITIES_SECTORS_MEDIUM_ELECTRIFICATION[AGRICULTURE_FORESTRY_FISHING,FE]:INTERPOLATE:\
		:=
	GET_DIRECT_DATA( 'model_parameters.xlsx', 'energy', 'TIME_PARAMETERS' , 'FE_INTENSITIES_PRODUCTIVE_SECTORS_MEDIUM_ELECTRIFICATION_AGRICULTURE'\
		 )
	~	J/$
	~	Energy intensity is a measure of the amount of energy used to produce a unit of \
		output or service in a given sector. It reflects the energy efficiency of \
		that sector: lower energy intensity means less energy is required, \
		indicating higher efficiency.
		
		In this context, the energy intensities of various sectors are analyzed, \
		specifically characterized for the local case and by type of final energy \
		used. For households, a pseudo energy intensity has been calculated based \
		on consumption patterns, offering an approximate view of their energy \
		usage efficiency.Intensities are subject to future scenarios that project \
		the level of development of the sectors and improvements in their \
		efficiency.
	|

SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'energy' , 'SELECT_POLICY_FINAL_ENERGY_SUBSTITUTION'\
		 )
	~	
	~		|

SWITCH_SEASONALITY=
	GET_DIRECT_CONSTANTS('scenario_parameters.xlsx', 'energy' , 'SWITCH_SEASONALITY' )
	~	
	~		|

CF_PERIODICAL[RENEWABLES]=
	IF_THEN_ELSE(SWITCH_SEASONALITY=1, INI_CF_PERIODICAL[RENEWABLES] , MAX(aux_delay2[RENEWABLES\
		],aux_delay1[RENEWABLES])+IF_THEN_ELSE(Time<INITIAL_TIME+1, INI_CF_PERIODICAL[RENEWABLES\
		], 0 ) )
	~	
	~	The ratio of the electrical energy produced by a renewable generating unit \
		in a year to the electrical energy that could have been produced in \
		continuous operation at full power during that year.
	|

Sum_Food_Balance[LAND_PRODUCTS_I]=
	SUM( total_food_produced[LAND_PRODUCTS_I!] )-SUM( land_products_demanded_for_food[LAND_PRODUCTS_I\
		!])
	~	
	~		|

rice_water_use=
	CWR_RICE*WEF_area_of_irrigated_crops[RICE]
	~	m3
	~	rice_water_use
	|

PERI_URBAN_POPULATION=
	Total_population*Share_of_Periurban
	~	person
	~	PERI_URBAN_POPULATION
		GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', \
		'peri_urban_population' )
	|

URBAN_POPULATION=
	Total_population*Share_of_Urban_pop
	~	person
	~	URBAN_POPULATION
		GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', \
		'urban_population' )
	|

Total_population_0=
	Total_population
	~	people
	~	Population of Inkomati
		GET_DIRECT_DATA('model_parameters/land_and_water/land_and_water.xlsx', \
		'exogeneous_inputs' , 'YEARS', 'POPULATION' )
	|

Share_of_Rural_pop=
	0.69
	~	Dmnl
	~	GET_DIRECT_CONSTANTS( 'model_parameters' , 'water' , 'RURAL_POP_SHARE' )
	|

Share_of_Urban_pop=
	0.19
	~	Dmnl
	~	GET_DIRECT_CONSTANTS( 'model_parameters' , 'water' , 'URBAN_POP_SHARE' )
	|

maize_water_use=
	CWR_MAIZE*WEF_area_of_irrigated_crops[CORN]
	~	m3
	~	Maize water use
	|

RURAL_POPULATION=
	Total_population*Share_of_Rural_pop
	~	person
	~	RURAL_POPULATION
		GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', \
		'rural_population' )
	|

Share_of_Periurban=
	0.12
	~	
	~		|

RVA_in_Dollar=
	Real_Value_Added*MILLION_DOLLARS_TO_DOLLARS
	~	
	~		|

MILLION_DOLLARS_TO_DOLLARS=
	1e+06
	~	
	~		|

HH_Consum_in_Dollar=
	HH_Consumption*MILLION_DOLLARS_TO_DOLLARS
	~	
	~		|

MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,LANDS_MAP_I]=
	INITIAL_LAND_USE_BY_REGION_2015[LANDS_I]*LIMITS_TO_LAND_USE_CHANGES_BY_REGION[LANDS_I\
		,LANDS_MAP_I
	]
	~	ha
	~		|

factor_of_maximum_land_limit[LANDS_I,LANDS_MAP_I] :EXCEPT:               [LANDS_I,CROPLAND_RAINFED
], [
LANDS_I,FOREST_PLANTATIONS]=
	IF_THEN_ELSE( matrix_of_accumulated_land_use_changes[LANDS_I,LANDS_MAP_I]>= 
	
	MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,LANDS_MAP_I]  :AND: land_use_changes_demanded\
		[LANDS_MAP_I
	]>0  ,
	
	0, 1) ~~|
factor_of_maximum_land_limit[LANDS_I,CROPLAND_RAINFED]=
	IF_THEN_ELSE( SWITCH_LAW_LIMITS_LAND_BY_SOURCE=0,
	
	IF_THEN_ELSE( matrix_of_accumulated_land_use_changes[LANDS_I,CROPLAND_RAINFED]>= 
	
	MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,CROPLAND_RAINFED]:AND: land_use_changes_demanded\
		[CROPLAND_RAINFED]>0 , 0, 1),
	
	IF_THEN_ELSE(  land_use_area_by_region[CROPLAND_RAINFED]  >=  MAXIMUM_LAND_USES_BY_SOURCE\
		[CROPLAND_RAINFED]*INITIAL_LAND_USE_BY_REGION_2015[CROPLAND_RAINFED] ,0, 1)
	
	) ~~|
factor_of_maximum_land_limit[LANDS_I,FOREST_PLANTATIONS]=
	IF_THEN_ELSE( SWITCH_LAW_LIMITS_LAND_BY_SOURCE=0,
	
	IF_THEN_ELSE( matrix_of_accumulated_land_use_changes[LANDS_I,FOREST_PLANTATIONS]>= 
	
	MATRIX_OF_MAXIMUM_LAND_CHANGES[LANDS_I,FOREST_PLANTATIONS] :AND: land_use_changes_demanded\
		[FOREST_PLANTATIONS]>0 , 0, 1),
	
	IF_THEN_ELSE(  land_use_area_by_region[FOREST_PLANTATIONS]  >=  MAXIMUM_LAND_USES_BY_SOURCE\
		[FOREST_PLANTATIONS]*INITIAL_LAND_USE_BY_REGION_2015[FOREST_PLANTATIONS] ,0, 1)
	
	)
	~	Dmnl
	~	factor of maximum land use changes by region
	|

area_of_irrigated_crops_0[LAND_PRODUCTS_I]=
	land_use_area_by_region[CROPLAND_IRRIGATED]*LAND_AREA_ADJUST_COEFFICIENT
	~	ha
	~		|

yields_of_rainfed_industrial_crops[LAND_PRODUCTS_I]= INTEG (
	increase_of_yields_industrial_R_and_I[LAND_PRODUCTS_I],
		INITIAL_YIELDS_OF_INDUSTRIAL_RAINFED_CROPS[LAND_PRODUCTS_I])
	~	t/(ha*Year)
	~		|

afforestation_due_to_policies=
	IF_THEN_ELSE( SWITCH_AFFORESTATION_SP=1:AND:Time>YEAR_INITIAL_AFFORESTATION_SP :AND:\
		Time<YEAR_FINAL_AFFORESTATION_SP
	,
	 (OBJECTIVE_AFFORESTATION_SP*INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED] )/
	
	(YEAR_FINAL_AFFORESTATION_SP-YEAR_INITIAL_AFFORESTATION_SP) , 0
	 )
	~	ha/Year
	~		|

LIMITS_TO_LAND_USE_CHANGES_BY_REGION[LANDS_I,LANDS_MAP_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'LIMITS_TO_LAND_USE_CHANGES_SONGWE'
	 )
	~	Dmnl
	~	maximum land use change allowed from use LANDS_I to use LANDS_I_MAP  in \
		percent of the initial land of the use that gives (LANDS_I)
	|

SWINE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT[MANURE_MANAGEMENT_SYSTEM_I]=
	METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]*SWINE_MANURE_SYSTEM[\
		MANURE_MANAGEMENT_SYSTEM_I
	]
	~	kg/(Year*number_animals)
	~		|

SWINE_MANURE_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'SWINE_CATTLE_MANURE_SYSTEM'
	 )
	~	Dmnl
	~	% MS by default. The "less emissions" options are: solid storage, dry lot, \
		range/paddock, daily spread and Pit storage <1month
		From IPCC 2006 Chapter livestock, adapted to WILIAM regions
		 % of the types  manure systems by type of animal , for the calculation of \
		methane emissions due to manure management.
	|

LOSS_FACTOR_OF_LAND_PRODUCTS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'LOSS_FACTOR_LAND_PRODUCTS*'\
		)
	~	Dmnl
	~		|

AGROFOOD_TRANSFORM_MATRIX[FOODS_I,LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'AGROFOOD_TRANSFORM_MATRIX' \
		)
	~	Dmnl
	~		|

SWITCH_CROPLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_CROPLAND_PROTECTION_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

SWITCH_CROPLAND_RAINFED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_CROPLAND_RAINFED_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

SWITCH_FOREST_PLANTATIONS_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_FOREST_PLANTATIONS_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter , increase of plantations land driven \
		only by trends
		1: Activate the scenario parameter
	|

SWITCH_GRASSLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_GRASSLAND_PROTECTION_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

area_for_plantations= INTEG (
	increase_of_area_for_plantations-increase_of_effective_area_for_plantations,
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS])
	~	ha
	~		|

SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS'\
		)
	~	Dmnl
	~		|

area_of_forests= INTEG (
	increase_of_area_of_forests-increase_of_efective_area_of_forests,
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED])
	~	ha
	~		|

area_of_irrigated_wheat=
	area_of_irrigated_crops_0[RICE]
	~	ha
	~		|

area_of_rainfed_crops[LAND_PRODUCTS_I]=
	land_use_area_by_region[CROPLAND_RAINFED]*LAND_AREA_ADJUST_COEFFICIENT
	~	ha
	~		|

area_of_rainfed_wheat=
	area_of_rainfed_crops[RICE]
	~	ha
	~		|

MATURATION_TIME_OF_FOREST_MANAGED_MP=
	20
	~	Year
	~		|

MATURATION_TIME_OF_PLANTATIONS_MP=
	20
	~	Year
	~		|

increase_of_efective_area_of_forests=
	IF_THEN_ELSE(increase_of_area_of_forests>0, area_of_forests*(1/MATURATION_TIME_OF_FOREST_MANAGED_MP\
		), 0)
	~	
	~		|

aux_trends_of_yield_change_R_and_I[LAND_PRODUCTS_I]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE,
	
	TRENDS_OF_YIELD_CHANGE_RAINFED[LAND_PRODUCTS_I],
	
	MAX(0, TRENDS_OF_YIELD_CHANGE_RAINFED[LAND_PRODUCTS_I]))
	~	t/(ha*Year)
	~		|

SWITCH_PRIMARY_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_PRIMARY_FOREST_PROTECTION_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

increase_of_yields_rainfed_industrial[LAND_PRODUCTS_I]=
	IF_THEN_ELSE( yields_of_irrigated_industrial_crops[LAND_PRODUCTS_I]<MAXIMUM_YIELDS_IRRIGATED_INDUSTRIAL_CROPS\
		[LAND_PRODUCTS_I],  TRENDS_OF_INDUSTRIAL_IRRIGATED_YIELDS[LAND_PRODUCTS_I], 0)
	~	t/(ha*Year*Year)
	~		|

MAXIMUM_LAND_USES_BY_SOURCE[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'MAXIMUM_INCREASE_OF_LAND_SOURCE'\
		)
	~	Dmnl
	~		|

MAXIMUM_YIELDS_IRRIGATED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'MAXIMUM_YIELDS_IRRIGATED_INDUSTRIAL'
	 )
	~	t/(ha*Year)
	~		|

MAXIMUM_YIELDS_RAINFED_INDUSTRIAL_CROPS[LAND_PRODUCTS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'MAXIMUM_YIELDS_R_AND_I' )
	~	t/(ha*Year)
	~		|

meat_obtained_from_grasslands=
	INITIAL_MEAT_OBTAINED_FROM_GRASSLANDS*ZIDZ(land_use_area_by_region[GRASSLAND],INITIAL_LAND_USE_BY_REGION
	[GRASSLAND])
	~	tonne/Year
	~		|

METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'METHANE_CONVERSION_FACTOR_BY_SYSTEM'\
		 )
	~	
	~	 methane conversion factors for each manure management system S by WILIAM \
		region. From IPCC 2006 Chapter livestock, adapted to WILIAM regions
	|

fertilizers_demanded=
	CHEMICAL_FERTILIZERS_PER_CROPLAND_AREA* (land_use_area_by_region[CROPLAND_RAINFED]+land_use_area_by_region
	[CROPLAND_IRRIGATED])
	~	t
	~	Fertilizers demanded depending of the type of cropland management (share of \
		industrial agriculture)
		
		**NOTES-TODO: potential improvement:  demand of fertilizers or fertilizers \
		quantity applied based on type of crop management be better quantified \
		(include more data about management--> excel calibrate "industrial area vs \
		tradictional and agricological?) We could use this information to \
		calibrate Nitrogen demand.
	|

food_balance[LAND_PRODUCTS_I]= INTEG (
	food_supply[LAND_PRODUCTS_I]-food_demand[LAND_PRODUCTS_I],
		0)
	~	t
	~		|

food_demand[LAND_PRODUCTS_I]=
	land_products_demanded_for_food[LAND_PRODUCTS_I]/Total_population_0
	~	t
	~		|

food_demanded_by_households_per_region[FOODS_I]=
	diet[FOODS_I]*Total_population_0*UNIT_CONVERSION_t_kg
	~	t/Year
	~		|

CH4_emissions_agriculture=
	CH4_emissions_livestock
	~	Mt/Year
	~	Total CH4 emissions from agricultur BY region.
		Important note: the emissions calculated in this variable from agriculture \
		are ONLY those related to "Enteric fermentation", "Manure management", \
		"Rice cultivation" , and "Synthetic Fertilizers. The rest of agriculture \
		emissions are not included in this variable such as crop residues, burning \
		of crop residues, manure left on pasture, manure applied to soils, or \
		energy use in agriculture.
	|

CH4_emissions_enteric_fermentation[ANIMALS_TYPES_I]=
	FACTOR_EMISSIONS_ENTERIC_FERMENTATION[ANIMALS_TYPES_I]*EXOGENOUS_NUMBER_OF_ANIMALS[ANIMALS_TYPES_I
	]*(UNIT_CONVERSION_Mt_t
	*UNIT_CONVERSION_t_kg)
	~	kg/(Year*person)
	~	Equation for CH4 emissiones based on activity data (animals) and factor \
		emissions (from IPCC)
	|

CH4_emissions_enteric_fermentation_by_animal[ANIMALS_TYPES_I]=
	SUM (CH4_emissions_enteric_fermentation[ANIMALS_TYPES_I!])
	~	Mt/Year
	~	ch4 emissions from enteric fermentation by type of animal at world scale
	|

CH4_emissions_enteric_fermentation_by_region=
	SUM(CH4_emissions_enteric_fermentation[ANIMALS_TYPES_I!])*(1+SHARE_REST_CH4_ENTERIC_FERMENTATION_EMISSIONS\
		)
	~	MtCH4/Year
	~	Equation for CH4 emissions based on activity data (animals) and factor \
		emissions (from IPCC),
	|

CH4_emissions_livestock=
	CH4_emissions_enteric_fermentation_by_region+CH4_emissions_manure_management_by_region
	~	MtCH4/Year
	~		|

CH4_emissions_manure_management[ANIMALS_TYPES_I]=
	EXOGENOUS_NUMBER_OF_ANIMALS[ANIMALS_TYPES_I]*EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED\
		[ANIMALS_TYPES_I]*UNIT_CONVERSION_t_kg*UNIT_CONVERSION_Mt_t
	~	MtCH4/Year
	~		|

CH4_emissions_manure_management_by_region=
	SUM(CH4_emissions_manure_management[ANIMALS_TYPES_I!])*(1+SHARE_REST_CH4_MANURE_MANAGEMENT_EMISSIONS\
		)
	~	MtCH4/Year
	~		|

CH4_emissions_wheat=
	area_of_irrigated_wheat* ((FACTOR_EMISSIONS_BASELINE_WHEAT*CULTIVATION_PERIOD_WHEAT)\
		*SCALING_FACTOR_WATER_REGIME_WHEAT_IRRIGATED
	*SCALING_FACTOR_WATER_REGIME_PRESEASON
	*SCALING_FACTOR_ORGANIC_AMENDMENT*UNIT_CONVERSION_t_kg
	*UNIT_CONVERSION_Mt_t) +
	
	area_of_rainfed_wheat
	
	*((FACTOR_EMISSIONS_BASELINE_WHEAT*CULTIVATION_PERIOD_WHEAT)*SCALING_FACTOR_WATER_REGIME_WHEAT_RAINFED\
		*(1-SHARE_UPLAND_WHEAT_BY_REGION
	)*SCALING_FACTOR_ORGANIC_AMENDMENT
	*UNIT_CONVERSION_t_kg
	*SCALING_FACTOR_WATER_REGIME_PRESEASON
	*UNIT_CONVERSION_Mt_t)
	~	Mt/Year
	~		|

CHECK_EXOGENOUS_LAND_USE_DEMANDS[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'EXOGENOUS_LAND_USE_DEMANDS')
	~	Dmnl
	~		|

N20_emissions_agriculture=
	N2O_emissions_fertilizers+N2O_emissions_livestock
	~	Mt/Year
	~		|

CHEMICAL_FERTILIZERS_PER_CROPLAND_AREA=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'CHEMICAL_FERTILIZERS_PER_CROPLAND_AREA'\
		 )
	~	tonnes/ha
	~		|

N2O_emissions_livestock=
	N2O_emissions_manure_management
	~	Mton_N/Year
	~		|

N2O_emissions_manure_management=
	CH4_emissions_manure_management_by_region*SHARE_REST_N2O_MANURE_MANAGEMENT_EMISSIONS
	~	Mton_N/Year
	~		|

HISTORICAL_LAND_USE_BY_REGION[CROPLAND_RAINFED]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_CROPLAND_RAINFED_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_CROPLAND_IRRIGATED_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[FOREST_MANAGED]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_MANAGED_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[FOREST_PRIMARY]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PRIMARY_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_FOREST_PLANTATIONS_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[SHRUBLAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_SHRUBLAND_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[GRASSLAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_GRASSLAND_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[WETLAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_WETLAND_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[URBAN_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_URBAN_LAND_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[WATERBODIES]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_WATERBODIES_BY_REGION'\
		) ~~|
HISTORICAL_LAND_USE_BY_REGION[OTHER_LAND]=
	GET_DIRECT_LOOKUPS('model_parameters.xlsx', 'land'   , 'TIME_LAND_USE', 'HISTORICAL_OTHER_LAND_BY_REGION'\
		)
	~	ha
	~		|

wood_production_of_plantations=
	effective_area_for_plantations
	~	
	~		|

EXOGENOUS_NUMBER_OF_ANIMALS[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'ANIMALS_DISTRIBUTION_REGIONS'\
		 )
	~	number_animals
	~	total number of animals by type and by case study
	|

YEAR_FINAL_AFFORESTATION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_YEAR_FINAL_AFFORESTATION_SP*'\
		 )
	~	Year
	~	Scenario parameter final year
	|

total_food_produced[LAND_PRODUCTS_I]=
	dairy_obtained_from_grasslands[GRASSLAND] +land_products_available_from_croplands[LAND_PRODUCTS_I\
		]+meat_obtained_from_grasslands
	~	t/Year
	~		|

OBJECTIVE_AFFORESTATION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_OBJECTIVE_AFFORESTATION_SP*'\
		 )
	~	Dmnl
	~	-Policy of increase of managed forest.
		-This is an increase of the hihg biodiversity forest (not the increase of tree \
		plantations)
		-The OBJECTIVE area of forest is achieved in the FINAL TIME with a lineal evolution.
		-OBJECTIVE of this policy is expressed as a % of the historical value of the area of \
		forest of 2015 (0=0%, means that there is no increse of forest;  1=100%,  \
		means that the area reforested equals forest area in 2015).
		-This policy competes with the rest of land uses, therefore, the forest \
		area objective might not be achiven in the final year due to land use \
		changes from forest to other uses.
	|

OBJECTIVE_CROPLAND_IRRIGATED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_OBJECTIVE_CROPLAND_IRRIGATED_SP*'\
		 )
	~	Dmnl
	~		|

OBJECTIVE_CROPLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_OBJECTIVE_CROPLAND_PROTECTION_SP*'\
		)
	~	Dmnl
	~	-If this policy is applied, the cropland (Sum of irrigated and rainfed cropland) is \
		protected and its area does not go down the value given in OBJECTIVE. 
		-The protection starts in INITIAL YEAR and ends in FINAL YEAR.
		-If cropland area in INITIAL YEAR is lower than OBJECTIVE*cropland area in 2015 \
		(TIME HISTORICAL DATA LAND MODULE), the area in INITIAL YEAR is maintained.
		-OBJECTIVE of policy is expressed as a share of the initial area of \
		cropland in 2015 (from 0 to 1; =1 means that an area equal to the cropland \
		we had in 2015 is protected, =0 means that there are no limits to cropland \
		loss).
	|

OBJECTIVE_CROPLAND_RAINFED_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_OBJECTIVE_CROPLAND_RAINFED_SP*'\
		 )
	~	Dmnl
	~		|

OBJECTIVE_FOREST_PLANTATIONS_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'OBJECTIVE_FOREST_PLANTATIONS*'\
		 )
	~	Dmnl
	~	-This is an increase of tree plantations.
		-The OBJECTIVE area of forest is achieved in the FINAL TIME with a linear evolution.
		-OBJECTIVE of this policy is expressed as a % of the historical value of the area of \
		PLANTATIONS of 2015 (0=0%, means that there is no increse of plantations;  \
		1=100%,  means that the area planted equals plantations area in 2015).
		-This policy competes with the rest of land uses, therefore, the  area \
		objective might not be achived in the final year due to land use changes \
		to other uses.
	|

OBJECTIVE_GRASSLAND_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_OBJECTIVE_GRASSLAND_PROTECTION_SP*'\
		)
	~	Dmnl
	~	-If this policy is applied, the grassland is protected and its area does not go down \
		the value given in OBJECTIVE. 
		-The protection starts in INITIAL YEAR and ends in FINAL YEAR.
		-If grassland area in INITIAL YEAR is lower than OBJECTIVE*grassland area in 2015 \
		(TIME HISTORICAL DATA LAND MODULE), the area in INITIAL YEAR is maintained.
		-OBJECTIVE of policy is expressed as a share of the initial area of \
		grassland in 2015 (from 0 to 1; =1 means that an area equal to the \
		grassland we had in 2015 is protected, =0 means that there are no limits \
		to grassland loss).
	|

objective_land_protection_policy[CROPLAND_RAINFED]=
	OBJECTIVE_CROPLAND_PROTECTION_SP ~~|
objective_land_protection_policy[CROPLAND_IRRIGATED]=
	OBJECTIVE_CROPLAND_PROTECTION_SP ~~|
objective_land_protection_policy[FOREST_MANAGED]=
	OBJECTIVE_MANAGED_FOREST_PROTECTION_SP ~~|
objective_land_protection_policy[FOREST_PRIMARY]=
	OBJECTIVE_PRIMARY_FOREST_PROTECTION_SP ~~|
objective_land_protection_policy[FOREST_PLANTATIONS]=
	0 ~~|
objective_land_protection_policy[SHRUBLAND]=
	OBJECTIVE_NATURAL_LAND_PROTECTION_SP ~~|
objective_land_protection_policy[GRASSLAND]=
	OBJECTIVE_GRASSLAND_PROTECTION_SP ~~|
objective_land_protection_policy[OTHER_LAND]=
	OBJECTIVE_NATURAL_LAND_PROTECTION_SP ~~|
objective_land_protection_policy[WETLAND]=
	0 ~~|
objective_land_protection_policy[URBAN_LAND]=
	0 ~~|
objective_land_protection_policy[WATERBODIES]=
	0
	~	Dmnl
	~		|

OBJECTIVE_MANAGED_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_OBJECTIVE_MANAGED_FOREST_PROTECTION_SP*'\
		)
	~	Dmnl
	~	-If this policy is applied, the managed forest is protected and its area does not go \
		down the value given in OBJECTIVE. 
		-The protection starts in INITIAL YEAR and ends in FINAL YEAR.
		-If managed forest area in INITIAL YEAR is lower than OBJECTIVE*forest area in 2015 \
		(TIME HISTORICAL DATA LAND MODULE), the area in INITIAL YEAR is maintained.
		-OBJECTIVE of policy is expressed as a share of the initial area of \
		managed forest in 2015 (from 0 to 1; =1 means that an area equal to the \
		managed forest we had in 2015 is protected, =0 means that there are no \
		limits to deforestation).
	|

CROPLAND_LOST_DUE_TO_FLOODS[LANDS_I]=
	0
	~	ha
	~	land lost due to floods
	|

CULTIVATION_PERIOD_WHEAT=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'CULTIVATION_PERIOD_RICE')
	~	days/Year
	~	cultivation period! (120 days?)--> \
		https://www.fao.org/3/s2022e/s2022e02.htm (total grown period:Rice 90-150) \
		(average value)
	|

OTHER_CATLLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT[MANURE_MANAGEMENT_SYSTEM_I\
		]=
	METHANE_CONVERSION_FACTOR_BY_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]*OTHER_CATTLE_MANURE_SYSTEM\
		[MANURE_MANAGEMENT_SYSTEM_I]
	~	kg/(number_animals*Year)
	~	IPCC 2006 Guidelines (Tier 1) (Eggleston, Buendia, Miwa, Ngara, & Tanabe, 2006) \
		tABLES 10.14 TO 10.16
		Adapted to WILIAM regions. 
		Not used the ones of "goat", sheep and chkens, as this factor is to \
		applied to the rest in which policies about manure system can be applied
	|

OTHER_CATTLE_MANURE_SYSTEM[MANURE_MANAGEMENT_SYSTEM_I]=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'OTHER_CATTLE_MANURE_SYSTEM'
	 )
	~	Dmnl
	~	% MS by default. The "less emissions" options are: solid storage, dry lot, \
		range/paddock, daily spread and Pit storage <1month
		From IPCC 2006 Chapter livestock
		 % of the types  manure systems by type of animal , for the calculation of \
		methane emissions due to manure management .
	|

trends_of_land_use_changes[CROPLAND_RAINFED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[CROPLAND_RAINFED
	]
	, TRENDS_OF_LAND_USE_DEMAND[CROPLAND_RAINFED]) ~~|
trends_of_land_use_changes[CROPLAND_IRRIGATED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE,HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[CROPLAND_IRRIGATED
	], TRENDS_OF_LAND_USE_DEMAND[CROPLAND_IRRIGATED]) ~~|
trends_of_land_use_changes[FOREST_MANAGED]=
	IF_THEN_ELSE( Time<=TIME_HISTORICAL_DATA_LAND_MODULE, HISTORICAL_TRENDS_OF_LAND_USE_DEMAND\
		[FOREST_MANAGED],
	 
	
	
	TRENDS_OF_LAND_USE_DEMAND[FOREST_MANAGED] ) ~~|
