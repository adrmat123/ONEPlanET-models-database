	0
	~	Dmnl
	~		|

effective_area_for_plantations= INTEG (
	increase_of_effective_area_for_plantations-plantations_harvesting,
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS])
	~	ha
	~		|

effective_area_of_forests= INTEG (
	increase_of_efective_area_of_forests-deforested_area,
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED])
	~	
	~		|

FACTOR_EMISSION_N_APPLICATION_INDIRECT=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'EF_N2O_direct_fertilizers')
	~	kg_N2ON/kgN
	~	IPCC 2006 (Tier 1, Chapter 11, Table 11.1) default values for direct emissions  N2O \
		emitted from the various synthetic and organic N applications to soils, \
		including crop residue and mineralisation of soil organic carbon in \
		mineral soils due to land-use change or management
		"Conversion of N2O-N emissions to N2O emissions for reporting purposes is performed \
		by using the following 
		equation: N2O = N2O-N * 44/28 
		1 kg N2O-N = 1 kg de N= (44/28)*1 kg N2O (factor from kg of N to kg of \
		N2O) (N2O= 44 g/mol and N=28 g/mol, and 1N2Omol=1N mol)
	|

FACTOR_EMISSIONS_BASELINE_WHEAT=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'FACTOR_EMISSIONS_BASELINE_WHEAT'\
		)
	~	kgCH4/(ha*Year)
	~	1,3 kgCH4/(ha*day)--> cultivation period! (120 days?)
		"FACTOR_EMISSIONS_BASELINE_RICE"  Baseline emission factor: the IPCC \
		default for EFc is 1.30 kg CH4 ha-1 day-1 (with error range of 0.80 - \
		2.20, Table 5.11), estimated by a statistical analysis of available field \
		measurement data (Yan et al., 2005,
	|

rainfed_crops_available_by_region[LAND_PRODUCTS_I]=
	area_of_rainfed_crops[LAND_PRODUCTS_I]*yields_of_rainfed_crops[LAND_PRODUCTS_I]
	~	t/Year
	~		|

increase_of_area_for_plantations=
	growth_of_plantation_area
	~	ha/Year
	~		|

increase_of_area_of_forests=
	IF_THEN_ELSE (land_use_changes_productive_uses[FOREST_MANAGED]>0, land_use_changes_productive_uses\
		[FOREST_MANAGED], 0)
	~	ha/Year
	~		|

YEAR_FINAL_MANAGED_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_YEAR_FINAL_MANAGED_FOREST_PROTECTION_SP*'\
		)
	~	Year
	~	Scenario parameter final year
	|

increase_of_effective_area_for_plantations=
	IF_THEN_ELSE(increase_of_area_for_plantations>0, area_for_plantations*(1/MATURATION_TIME_OF_PLANTATIONS_MP
	), 0)
	~	ha/Year
	~		|

increase_of_yields_industrial_R_and_I[LAND_PRODUCTS_I]=
	IF_THEN_ELSE( 
	yields_of_rainfed_industrial_crops[LAND_PRODUCTS_I]<MAXIMUM_YIELDS_RAINFED_INDUSTRIAL_CROPS\
		[LAND_PRODUCTS_I
	],
	
	aux_trends_of_yield_change_R_and_I[LAND_PRODUCTS_I],
	0)
	~	t/(ha*Year*Year)
	~		|

variation_of_wetland_area=
	0
	~	ha
	~		|

increment_of_cropland_irrigated_demanded=
	IF_THEN_ELSE( SWITCH_CROPLAND_IRRIGATED_SP=1:AND:Time>YEAR_INITIAL_CROPLAND_IRRIGATED_SP\
		 :AND:Time
	<YEAR_FINAL_CROPLAND_IRRIGATED_SP
	,
	 (OBJECTIVE_CROPLAND_IRRIGATED_SP*INITIAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED] )/
	
	(YEAR_FINAL_CROPLAND_IRRIGATED_SP-YEAR_INITIAL_CROPLAND_IRRIGATED_SP) , 0
	 )
	~	ha
	~		|

increment_of_cropland_rainfed_demanded=
	IF_THEN_ELSE( SWITCH_CROPLAND_RAINFED_SP=1:AND:Time>YEAR_INITIAL_CROPLAND_RAINFED_SP\
		 :AND:Time
	<YEAR_FINAL_CROPLAND_RAINFED_SP
	,
	 (OBJECTIVE_CROPLAND_RAINFED_SP*INITIAL_LAND_USE_BY_REGION[CROPLAND_RAINFED] )/
	
	(YEAR_FINAL_CROPLAND_RAINFED_SP-YEAR_INITIAL_CROPLAND_RAINFED_SP) , 0
	 )
	~	ha
	~		|

EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT'\
		 )
	~	
	~		|

EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[DAIRY_CATTLE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT\
		[DAIRY_CATTLE]* SUM
	 (model_explorer_manure_management_system
	[DAIRY_CATTLE,MANURE_MANAGEMENT_SYSTEM_I!]) , 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[DAIRY_CATTLE]* SUM (DAIRY_CATLLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) ) ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[OTHER_CATTLE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[OTHER_CATTLE]* SUM (model_explorer_manure_management_system
	[OTHER_CATTLE,MANURE_MANAGEMENT_SYSTEM_I!]) ,
	 
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[OTHER_CATTLE]* SUM (OTHER_CATLLE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) ) ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[GOATS]=
	EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[GOATS] ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[CHICKENS]=
	EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_BY_DEFAULT[CHICKENS] ~~|
EMISSION_FACTOR_METHANE_MANURE_MANAGEMENT_CALCULATED[SWINE]=
	IF_THEN_ELSE(SWITCH_MODEL_EXPLORER=1, EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT\
		[SWINE]*SUM(model_explorer_manure_management_system
	[SWINE,MANURE_MANAGEMENT_SYSTEM_I!]) , 
	
	EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[SWINE]*SUM(SWINE_EMISSION_SECOND_FACTOR_METHANE_MANURE_MANAGEMENT
	[MANURE_MANAGEMENT_SYSTEM_I!]) )
	~	kg/(number_animals*Year)
	~		|

EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT[ANIMALS_TYPES_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'EMISSION_FIRST_FACTOR_METHANE_MANURE_MANAGEMENT'\
		 )
	~	kg/(Year*number_animals)
	~		|

land_use_area_productive_uses[CROPLAND_RAINFED]= INTEG (
	land_use_changes_productive_uses[CROPLAND_RAINFED],
		INITIAL_LAND_USE_BY_REGION[CROPLAND_RAINFED]) ~~|
land_use_area_productive_uses[CROPLAND_IRRIGATED]= INTEG (
	land_use_changes_productive_uses[CROPLAND_IRRIGATED],
		INITIAL_LAND_USE_BY_REGION[CROPLAND_IRRIGATED]) ~~|
land_use_area_productive_uses[FOREST_MANAGED]= INTEG (
	land_use_changes_productive_uses[FOREST_MANAGED],
		INITIAL_LAND_USE_BY_REGION[FOREST_MANAGED]) ~~|
land_use_area_productive_uses[FOREST_PRIMARY]= INTEG (
	land_use_changes_productive_uses[FOREST_PRIMARY],
		INITIAL_LAND_USE_BY_REGION[FOREST_PRIMARY]) ~~|
land_use_area_productive_uses[FOREST_PLANTATIONS]= INTEG (
	land_use_changes_productive_uses[FOREST_PLANTATIONS],
		INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS]) ~~|
land_use_area_productive_uses[SHRUBLAND]= INTEG (
	land_use_changes_productive_uses[SHRUBLAND],
		0) ~~|
land_use_area_productive_uses[GRASSLAND]= INTEG (
	land_use_changes_productive_uses[GRASSLAND],
		INITIAL_LAND_USE_BY_REGION[GRASSLAND]) ~~|
land_use_area_productive_uses[WETLAND]= INTEG (
	land_use_changes_productive_uses[WETLAND],
		0) ~~|
land_use_area_productive_uses[URBAN_LAND]= INTEG (
	land_use_changes_productive_uses[URBAN_LAND],
		INITIAL_LAND_USE_BY_REGION[URBAN_LAND]) ~~|
land_use_area_productive_uses[WATERBODIES]= INTEG (
	land_use_changes_productive_uses[ WATERBODIES],
		0) ~~|
land_use_area_productive_uses[OTHER_LAND]= INTEG (
	land_use_changes_productive_uses[OTHER_LAND]+land_use_changes_productive_uses[WATERBODIES
	]+land_use_changes_productive_uses[WETLAND]+land_use_changes_productive_uses[SHRUBLAND\
		],
		 INITIAL_LAND_USE_BY_REGION[OTHER_LAND]+INITIAL_LAND_USE_BY_REGION
		[WATERBODIES]+INITIAL_LAND_USE_BY_REGION[WETLAND]+INITIAL_LAND_USE_BY_REGION[
		SHRUBLAND])
	~	ha
	~	stock of land uses area productive uses by region
	|

share_of_land_use_change_from_others[LANDS_I,LANDS_MAP_I]=
	IF_THEN_ELSE( Time<TIME_HISTORICAL_DATA_LAND_MODULE , HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS\
		[LANDS_I
	,LANDS_MAP_I
	],share_of_land_use_changes_from_others_up[LANDS_I,LANDS_MAP_I])
	~	Dmnl
	~		|

land_use_changes_demanded[LANDS_I]=
	IF_THEN_ELSE( Time<TIME_HISTORICAL_DATA_LAND_MODULE,
	trends_of_land_use_changes[LANDS_I],
	
	SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS*(land_use_changes_demanded_before_exogenous[LANDS_I\
		])+
	
	(1-SWITCH_LAW_EXOGENOUS_LAND_USE_DEMANDS)*CHECK_EXOGENOUS_LAND_USE_DEMANDS[LANDS_I] \
		)
	~	ha
	~		|

land_use_changes_demanded_before_exogenous[CROPLAND_RAINFED]=
	trends_of_land_use_changes[CROPLAND_RAINFED]+land_use_changes_driven_by_demands[CROPLAND_RAINFED
	] ~~|
land_use_changes_demanded_before_exogenous[CROPLAND_IRRIGATED]=
	trends_of_land_use_changes[CROPLAND_IRRIGATED] ~~|
land_use_changes_demanded_before_exogenous[FOREST_MANAGED]=
	trends_of_land_use_changes[FOREST_MANAGED]+land_use_changes_driven_by_demands[FOREST_MANAGED\
		] ~~|
land_use_changes_demanded_before_exogenous[FOREST_PRIMARY]=
	trends_of_land_use_changes[FOREST_PRIMARY]+land_use_changes_driven_by_demands[FOREST_PRIMARY\
		] ~~|
land_use_changes_demanded_before_exogenous[FOREST_PLANTATIONS]=
	trends_of_land_use_changes[FOREST_PLANTATIONS]+land_use_changes_driven_by_demands[FOREST_PLANTATIONS
	] ~~|
land_use_changes_demanded_before_exogenous[SHRUBLAND]=
	0 ~~|
land_use_changes_demanded_before_exogenous[GRASSLAND]=
	trends_of_land_use_changes[GRASSLAND] ~~|
land_use_changes_demanded_before_exogenous[WETLAND]=
	0 ~~|
land_use_changes_demanded_before_exogenous[URBAN_LAND]=
	land_use_changes_driven_by_demands[URBAN_LAND] ~~|
land_use_changes_demanded_before_exogenous[WATERBODIES]=
	0 ~~|
land_use_changes_demanded_before_exogenous[OTHER_LAND]=
	0
	~	ha/Year
	~		|

SHARE_REST_CH4_ENTERIC_FERMENTATION_EMISSIONS=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'SHARE_REST_CH4_ENTERIC_FERMENTATION_EMISSIONS'\
		 )
	~	Dmnl
	~		|

food_demanded_from_land_products[CEREALS_DIET]=
	food_demanded_by_households_per_region[CEREALS_DIET] ~~|
food_demanded_from_land_products[TUBERS_DIET]=
	food_demanded_by_households_per_region[TUBERS_DIET] ~~|
food_demanded_from_land_products[PULSES_LEGUMES_NUTS]=
	food_demanded_by_households_per_region[PULSES_LEGUMES_NUTS] ~~|
food_demanded_from_land_products[FRUITS_VEGETABLES_DIET]=
	food_demanded_by_households_per_region[FRUITS_VEGETABLES_DIET] ~~|
food_demanded_from_land_products[FATS_VEGETAL]=
	food_demanded_by_households_per_region[FATS_VEGETAL] ~~|
food_demanded_from_land_products[FATS_ANIMAL]=
	food_demanded_by_households_per_region[FATS_ANIMAL] ~~|
food_demanded_from_land_products[DAIRY]=
	MAX(0, food_demanded_by_households_per_region[DAIRY]-dairy_obtained_from_grasslands[\
		GRASSLAND] ) ~~|
food_demanded_from_land_products[EGGS]=
	food_demanded_by_households_per_region[EGGS] ~~|
food_demanded_from_land_products[MEAT_RUMINANTS]=
	MAX(0,  food_demanded_by_households_per_region[MEAT_RUMINANTS]-meat_obtained_from_grasslands\
		) ~~|
food_demanded_from_land_products[MEAT_MONOGASTRIC]=
	food_demanded_by_households_per_region[MEAT_MONOGASTRIC] ~~|
food_demanded_from_land_products[FISH]=
	0 ~~|
food_demanded_from_land_products[SUGARS]=
	food_demanded_by_households_per_region[SUGARS] ~~|
food_demanded_from_land_products[BEVERAGES]=
	food_demanded_by_households_per_region[BEVERAGES] ~~|
food_demanded_from_land_products[STIMULANTS]=
	food_demanded_by_households_per_region[STIMULANTS]
	~	t*people/(Year*person)
	~	diets of households by regions and without meat and dairy from grasslands \
		and without fish
	|

INITIAL_DAIRY_OBTAINED_FROM_GRASSLANDS=
	GET_DIRECT_CONSTANTS( 'model_parameters.xlsx', 'land' , 'DAIRY_GRASSLANDS*' )
	~	
	~		|

INITIAL_LAND_USE_BY_REGION[LANDS_I]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'INITIAL_LAND_BY_REGION_2015*'\
		 )
	~	ha
	~		|

TIME_HISTORICAL_DATA_LAND_MODULE=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'TIME_HISTORICAL_DATA_LAND_MODULE'\
		 )
	~	Year
	~		|

food_supply[LAND_PRODUCTS_I]=
	total_food_produced[LAND_PRODUCTS_I]
	~	t
	~		|

forest_plantations_growth_due_to_policies=
	IF_THEN_ELSE( SWITCH_FOREST_PLANTATIONS_SP=1:AND:Time>YEAR_INITIAL_FOREST_PLANTATIONS_SP\
		 :AND:Time<YEAR_FINAL_FOREST_PLANTATIONS_SP
	,
	 (OBJECTIVE_FOREST_PLANTATIONS_SP*INITIAL_LAND_USE_BY_REGION[FOREST_PLANTATIONS] )/
	
	(YEAR_FINAL_FOREST_PLANTATIONS_SP-YEAR_INITIAL_FOREST_PLANTATIONS_SP) , 0
