	SWITCH_MANAGED_FOREST_PROTECTION_SP ~~|
switch_land_production_policy[FOREST_PRIMARY]=
	SWITCH_PRIMARY_FOREST_PROTECTION_SP ~~|
switch_land_production_policy[FOREST_PLANTATIONS]=
	0 ~~|
switch_land_production_policy[SHRUBLAND]=
	SWITCH_NATURAL_LAND_PROTECTION_SP ~~|
switch_land_production_policy[GRASSLAND]=
	SWITCH_GRASSLAND_PROTECTION_SP ~~|
switch_land_production_policy[OTHER_LAND]=
	SWITCH_NATURAL_LAND_PROTECTION_SP ~~|
switch_land_production_policy[WETLAND]=
	0 ~~|
switch_land_production_policy[URBAN_LAND]=
	0 ~~|
switch_land_production_policy[WATERBODIES]=
	0
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,CROPLAND_RAINFED]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'HISTORICAL_SHARE_OF_CROPLAND_RAINFED_FROM_OTHERS_BY_REGION'\
		 ) ~~|
