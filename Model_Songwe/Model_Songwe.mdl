		, OTHER_LAND
	~	
	~		|

rural_pop_water_access_baseline=
	RURAL_POPULATION*0.5
	~	person
	~	rural_pop_water_access_baseline
	|

rural_pop_water_access_P1=
	RURAL_POPULATION*0.85
	~	person
	~	rural_pop_water_access_with P1
	|

new_dam_P2_on:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'new_dam_P2_on' )
	~	m3
	~	dam contribution with P2 on
	|

rural_domestic_water_use_P1_on_off=
	IF_THEN_ELSE (switch_P1=1, rural_domestic_water_use_P1, rural_domestic_water_use_baseline\
		)
	~	m3
	~	rural_domestic_water_use_ the value changes if the policy is on or off
	|

agri_water_use=
	crop_water_use_P3_on_off+livestock_water_use
	~	m3
	~	Agri water use, so crop water use + livestock water use
	|

total_water_withdrawal_per_capita:=
	GET_DIRECT_DATA( 'scenario_parameters.xlsx', 'water', 'YEARS', 'total_water_withdrawal_per_capita'\
		 )
	~	m3/person
	~	total_water_withdrawal_per_capita
	|

livestock_water_use=
	cattle_water_use+chicken_water_use+goat_water_use+pig_water_use
	~	m3
	~	total livestock water use
	|

