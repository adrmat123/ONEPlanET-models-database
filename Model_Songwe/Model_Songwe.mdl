	~	m3
	~	environmental_flow_requirement_with P4
	|

environmental_flow_requirement_P4_on_off=
	IF_THEN_ELSE (switch_P4=1, environmental_flow_requirement_P4, ENVIRONMENTAL_FLOW_REQUIREMENT_BASELINE\
		)
	~	m3
	~	Environmental flow requirement; switches to policy value when P4 is ON, \
		otherwise baseline.
	|

