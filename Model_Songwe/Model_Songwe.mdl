HISTORICAL_SHARE_OF_LAND_USE_CHANGES_FROM_OTHERS[LANDS_I,GRASSLAND]=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land' , 'HISTORICAL_SHARE_OF_GRASSLAND_FROM_OTHERS_BY_REGION'\
