matrix_of_land_use_change_demands[LANDS_I,FOREST_MANAGED]=
	land_use_changes_demanded[FOREST_MANAGED]
	*share_of_land_use_change_from_others[LANDS_I,FOREST_MANAGED] ~~|
matrix_of_land_use_change_demands[LANDS_I,FOREST_PRIMARY]=
	land_use_changes_demanded[FOREST_PRIMARY]*share_of_land_use_change_from_others[LANDS_I\
		,FOREST_PRIMARY] ~~|
matrix_of_land_use_change_demands[LANDS_I,FOREST_PLANTATIONS]=
	land_use_changes_demanded[FOREST_PLANTATIONS]*share_of_land_use_change_from_others[LANDS_I\
		,FOREST_PLANTATIONS] ~~|
matrix_of_land_use_change_demands[LANDS_I,SHRUBLAND]=
	land_use_changes_demanded[SHRUBLAND]*share_of_land_use_change_from_others
	[LANDS_I,SHRUBLAND] ~~|
matrix_of_land_use_change_demands[LANDS_I,GRASSLAND]=
	land_use_changes_demanded[GRASSLAND]*share_of_land_use_change_from_others
	[LANDS_I,GRASSLAND] ~~|
matrix_of_land_use_change_demands[LANDS_I,WETLAND]=
	land_use_changes_demanded[WETLAND]*share_of_land_use_change_from_others[LANDS_I
	,WETLAND] ~~|
matrix_of_land_use_change_demands[LANDS_I,URBAN_LAND]=
	land_use_changes_demanded[URBAN_LAND]*share_of_land_use_change_from_others[LANDS_I,URBAN_LAND\
		] ~~|
matrix_of_land_use_change_demands[LANDS_I,WATERBODIES]=
	land_use_changes_demanded[WATERBODIES]*share_of_land_use_change_from_others[
	LANDS_I, WATERBODIES] ~~|
matrix_of_land_use_change_demands[LANDS_I,OTHER_LAND]=
	land_use_changes_demanded[OTHER_LAND]*share_of_land_use_change_from_others[LANDS_I,OTHER_LAND\
		]
	~	ha/Year
	~		|

SWITCH_MANAGED_FOREST_PROTECTION_SP=
	GET_DIRECT_CONSTANTS( 'scenario_parameters.xlsx', 'land' , 'POLICY_SWITCH_MANAGED_FOREST_PROTECTION_SP*'\
		 )
	~	Dmnl
	~	0: deactivate policy the scenario parameter 
		1: Activate the scenario parameter
	|

FACTOR_EMISSION_N_APPLICATION=
	GET_DIRECT_CONSTANTS('model_parameters.xlsx', 'land', 'EF_N2O_direct_fertilizers')
	~	kg_N2ON/kgN
	~	IPCC 2006 (Tier 1, Chapter 11, Table 11.1) default values for direct emissions  N2O \
		emitted from the various synthetic and organic N applications to soils, \
		including crop residue and mineralisation of soil organic carbon in \
		mineral soils due to land-use change or management
		"Conversion of N2O-N emissions to N2O emissions for reporting purposes is performed \
		by using the following 
		equation: N2O = N2O-N * 44/28 
		1 kg N2O-N = 1 kg de N= (44/28)*1 kg N2O (factor from kg of N to kg of \
		N2O) (N2O= 44 g/mol and N=28 g/mol, and 1N2Omol=1N mol)
	|

matrix_of_land_use_changes[LANDS_I,LANDS_MAP_I]=
	factor_of_minimum_land_limit[LANDS_I]*factor_of_maximum_land_limit[LANDS_I,LANDS_MAP_I\
		]* (matrix_of_land_use_change_demands[LANDS_I,LANDS_MAP_I])
	~	ha/Year
	~	matrix of land use changes
	|

vector_of_land_use_changes[CROPLAND_RAINFED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,CROPLAND_RAINFED])-
	SUM(matrix_of_land_use_changes[CROPLAND_RAINFED,LANDS_I!])- CROPLAND_LOST_DUE_TO_FLOODS\
		[CROPLAND_RAINFED] ~~|
vector_of_land_use_changes[CROPLAND_IRRIGATED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,CROPLAND_IRRIGATED])-
	SUM(matrix_of_land_use_changes[CROPLAND_IRRIGATED,LANDS_I!])-CROPLAND_LOST_DUE_TO_FLOODS\
		[CROPLAND_IRRIGATED] ~~|
vector_of_land_use_changes[FOREST_MANAGED]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_MANAGED])-
	SUM(matrix_of_land_use_changes[FOREST_MANAGED,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_PRIMARY]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_PRIMARY])-
	SUM(matrix_of_land_use_changes[FOREST_PRIMARY,LANDS_I!]) ~~|
vector_of_land_use_changes[FOREST_PLANTATIONS]=
	SUM(matrix_of_land_use_changes[LANDS_I!,FOREST_PLANTATIONS])-
	SUM(matrix_of_land_use_changes[FOREST_PLANTATIONS,LANDS_I!]) ~~|
vector_of_land_use_changes[SHRUBLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,SHRUBLAND])-
	SUM(matrix_of_land_use_changes[SHRUBLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[GRASSLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,GRASSLAND])-
	SUM(matrix_of_land_use_changes[GRASSLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[WETLAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,WETLAND])-
	SUM(matrix_of_land_use_changes[WETLAND,LANDS_I!]) ~~|
vector_of_land_use_changes[URBAN_LAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,URBAN_LAND])-
	SUM(matrix_of_land_use_changes[URBAN_LAND,LANDS_I!]) ~~|
vector_of_land_use_changes[WATERBODIES]=
	SUM(matrix_of_land_use_changes[LANDS_I!,WATERBODIES])-
	SUM(matrix_of_land_use_changes[WATERBODIES,LANDS_I!]) ~~|
vector_of_land_use_changes[OTHER_LAND]=
	SUM(matrix_of_land_use_changes[LANDS_I!,OTHER_LAND])-
	SUM(matrix_of_land_use_changes[OTHER_LAND,LANDS_I!])
	~	ha/Year
	~		|

